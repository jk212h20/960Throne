<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — Live Board</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #0f0f1a;
            color: #fff;
            font-family: system-ui, -apple-system, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 16px;
        }
        .board-wrap {
            width: min(90vw, 90vh, 600px);
            display: flex;
            flex-direction: column;
            gap: 0;
        }
        .board {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            aspect-ratio: 1;
            border-left: 2px solid #444;
            border-right: 2px solid #444;
            overflow: hidden;
        }
        .sq {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .sq-light { background: #f0d9b5; }
        .sq-dark { background: #b58863; }
        .sq-highlight { background: #cdd26a !important; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }

        /* Player bar — name + clock on each side of the board */
        .player-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 12px;
            background: #1a1a2e;
            border: 2px solid #444;
            min-height: 44px;
        }
        .player-bar-top {
            border-radius: 6px 6px 0 0;
            border-bottom: none;
        }
        .player-bar-bottom {
            border-radius: 0 0 6px 6px;
            border-top: none;
        }
        .player-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .player-dot {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            border: 1px solid #555;
            flex-shrink: 0;
        }
        .player-dot-white { background: #fff; }
        .player-dot-black { background: #222; }
        .player-name {
            font-size: 1rem;
            font-weight: 600;
            color: #e0e0e0;
        }
        .player-clock {
            font-family: 'SF Mono', 'Menlo', 'Consolas', monospace;
            font-size: 1.3rem;
            font-weight: bold;
            color: #aaa;
            padding: 2px 10px;
            border-radius: 4px;
            background: #111;
        }
        .player-clock-active {
            color: #4ade80;
            background: #0a1a0a;
        }

        /* Hidden when no data */
        .hidden { display: none; }

        /* Status line */
        .status {
            text-align: center;
            font-size: 0.8rem;
            color: #555;
            margin-top: 8px;
        }
        .status-connected { color: #4ade80; }
        .status-disconnected { color: #ef4444; }
    </style>
</head>
<body>
    <%
        // Derive white/black player names from game state
        // game.king_color tells us which color the king plays
        var whiteName = '';
        var blackName = '';
        if (game) {
            var kc = game.king_color || 'white';
            whiteName = kc === 'white' ? (game.king_name || '') : (game.challenger_name || '');
            blackName = kc === 'white' ? (game.challenger_name || '') : (game.king_name || '');
        }
    %>
    <div class="board-wrap">
        <!-- Black player (top — rank 8 side) -->
        <div class="player-bar player-bar-top" id="bar-black">
            <div class="player-info">
                <span class="player-dot player-dot-black"></span>
                <span class="player-name" id="name-black"><%= blackName %></span>
            </div>
            <span class="player-clock" id="clock-black"><%= (dgt && dgt.clock) ? Math.floor(dgt.clock.black/60)+':'+String(dgt.clock.black%60).padStart(2,'0') : '' %></span>
        </div>

        <div class="board" id="board">
            <% if (dgt && dgt.board) { %>
                <% dgt.board.forEach((row, ri) => { %>
                    <% row.forEach((sq, fi) => { %>
                        <div class="sq <%= (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark' %>">
                            <% if (sq.piece) { %>
                                <img src="/pieces/<%= sq.color %><%= sq.piece %>.svg" class="piece-img" alt="<%= sq.color === 'w' ? 'White' : 'Black' %> <%= sq.piece %>">
                            <% } %>
                        </div>
                    <% }) %>
                <% }) %>
            <% } else { %>
                <% for (let ri = 0; ri < 8; ri++) { %>
                    <% for (let fi = 0; fi < 8; fi++) { %>
                        <div class="sq <%= (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark' %>"></div>
                    <% } %>
                <% } %>
            <% } %>
        </div>

        <!-- White player (bottom — rank 1 side) -->
        <div class="player-bar player-bar-bottom" id="bar-white">
            <div class="player-info">
                <span class="player-dot player-dot-white"></span>
                <span class="player-name" id="name-white"><%= whiteName %></span>
            </div>
            <span class="player-clock" id="clock-white"><%= (dgt && dgt.clock) ? Math.floor(dgt.clock.white/60)+':'+String(dgt.clock.white%60).padStart(2,'0') : '' %></span>
        </div>

        <div class="status" id="status">
            <% if (dgt && dgt.connected) { %>
                <span class="status-connected">● Board connected</span>
            <% } else { %>
                <span class="status-disconnected">● Waiting for board</span>
            <% } %>
        </div>
    </div>

    <script>
        const socket = io();

        // Track current game info (updated via socket)
        let currentGame = <%- JSON.stringify(game || null) %>;

        socket.on('dgt_board', (data) => {
            const boardEl = document.getElementById('board');
            const statusEl = document.getElementById('status');

            // Update connection status
            if (data.connected) {
                statusEl.innerHTML = '<span class="status-connected">● Board connected</span>';
            } else {
                statusEl.innerHTML = '<span class="status-disconnected">● Waiting for board</span>';
            }

            // Rebuild board if we have data
            if (data.board) {
                let html = '';
                data.board.forEach((row, ri) => {
                    row.forEach((sq, fi) => {
                        const light = (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark';
                        const hl = (data.lastMove && (sq.square === data.lastMove.from || sq.square === data.lastMove.to)) ? 'sq-highlight' : '';
                        html += '<div class="sq ' + light + ' ' + hl + '">';
                        if (sq.piece) {
                            html += '<img src="/pieces/' + sq.color + sq.piece + '.svg" class="piece-img" alt="' + (sq.color === 'w' ? 'White' : 'Black') + ' ' + sq.piece + '">';
                        }
                        html += '</div>';
                    });
                });
                boardEl.innerHTML = html;
            }

            // Update clocks
            if (data.clock) {
                const wm = Math.floor(data.clock.white / 60);
                const ws = String(data.clock.white % 60).padStart(2, '0');
                const bm = Math.floor(data.clock.black / 60);
                const bs = String(data.clock.black % 60).padStart(2, '0');
                document.getElementById('clock-white').textContent = wm + ':' + ws;
                document.getElementById('clock-black').textContent = bm + ':' + bs;
            }
        });

        // Listen for game state changes to update player names
        socket.on('game_started', () => location.reload());
        socket.on('game_ended', () => location.reload());
        socket.on('new_king', () => location.reload());
    </script>
</body>
</html>
