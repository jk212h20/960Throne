<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= player.name %> — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
        @keyframes pulseGold { 0%, 100% { box-shadow: 0 0 0 0 rgba(255,215,0,0.4); } 50% { box-shadow: 0 0 20px 5px rgba(255,215,0,0.2); } }
        .pulse-gold { animation: pulseGold 2s infinite; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker p-4 pb-24">
    <div class="max-w-lg mx-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold">Hey, <%= player.name %> 👋</h1>
                <div class="text-xs text-gray-500 mt-1">⚡ Lightning login</div>
            </div>
            <div class="text-right">
                <div class="text-2xl font-mono text-throne-gold font-bold">⚡ <%= player.sat_balance.toLocaleString() %></div>
                <div class="text-xs text-gray-400">sats earned</div>
            </div>
        </div>

        <!-- ====== KING BANNER ====== -->
        <% if (state.king && state.king.id === player.id) { %>
        <div class="card border-throne-gold mb-4 text-center pulse-gold">
            <div class="text-4xl mb-2">👑</div>
            <div class="text-xl font-bold text-throne-gold">You are the King!</div>
            <div class="text-sm text-gray-400 mt-1">Earning <span class="text-throne-gold font-bold"><%= state.config.satRate %></span> sats/sec right now</div>
            <div class="text-4xl font-mono text-throne-gold mt-3" id="live-sats"><%= state.liveSats.toLocaleString() %></div>
            <div class="text-xs text-gray-500">sats this reign</div>
            <div class="text-sm text-gray-400 mt-3">Defend your throne against all challengers!</div>
        </div>
        <% } %>

        <!-- ====== ACTIVE GAME BANNER ====== -->
        <% if (state.game && (state.game.king_id === player.id || state.game.challenger_id === player.id)) { %>
        <a href="/game" class="block card border-throne-gold mb-4 text-center pulse-gold">
            <div class="text-2xl font-bold text-throne-gold">⚔️ Game in Progress!</div>
            <div class="text-gray-300 mt-2">
                <%= state.game.king_name %> <span class="text-gray-500">vs</span> <%= state.game.challenger_name %>
            </div>
            <div class="text-sm text-gray-500 mt-1">Position #<%= state.game.chess960_position %></div>
            <div class="btn-gold inline-block mt-3 text-sm">Report Result →</div>
        </a>
        <% } %>

        <!-- ====== ON DECK ====== -->
        <% if (queueEntry && queueEntry.status === 'on_deck') { %>
        <div class="card border-throne-gold mb-4 text-center pulse-gold">
            <div class="text-3xl font-bold text-throne-gold mb-2">🔔 YOU'RE UP NEXT!</div>
            <div class="text-lg text-gray-300">Head to the board now!</div>
            <div class="text-5xl font-mono text-red-400 mt-3" id="on-deck-timer">30</div>
            <div class="text-xs text-gray-500">seconds to show up</div>
        </div>

        <!-- ====== IN QUEUE ====== -->
        <% } else if (queueEntry) { %>
        <div class="card mb-4">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm text-gray-400">Your position in line</div>
                    <div class="text-4xl font-bold text-throne-gold">#<%= queueEntry.position %></div>
                    <div class="text-xs text-gray-500 mt-1">
                        <% if (queueEntry.position === 1) { %>
                            You're next! Wait for the current game to finish.
                        <% } else if (queueEntry.position <= 3) { %>
                            Almost there — stay close to the board!
                        <% } else { %>
                            Hang tight, games move fast ⚡
                        <% } %>
                    </div>
                </div>
                <button onclick="leaveQueue()" class="text-sm text-red-400 hover:text-red-300 border border-red-800 px-3 py-2 rounded-lg">Leave Line</button>
            </div>
        </div>

        <!-- ====== NOT IN QUEUE — CTA TO JOIN ====== -->
        <% } else if (!state.king || state.king.id !== player.id) { %>
        <div class="card mb-4 text-center">
            <div class="text-lg font-bold mb-2">Ready to play?</div>
            <% if (state.king) { %>
            <div class="text-gray-400 mb-4">
                <span class="text-throne-gold font-bold"><%= state.king.name %></span> is on the throne.
                <% if (state.queue.length === 0) { %>
                    No one in line — you could be next!
                <% } else { %>
                    <%= state.queue.length %> challenger<%= state.queue.length === 1 ? '' : 's' %> in line.
                <% } %>
            </div>
            <% } else { %>
            <div class="text-gray-400 mb-4">No King yet — be the first to claim the throne!</div>
            <% } %>
            <a href="/join" class="btn-gold inline-block text-lg px-8">📋 Get in Line</a>
            <div class="text-xs text-gray-500 mt-3">You'll need the venue code (displayed at the event)</div>
        </div>
        <% } %>

        <!-- ====== THE LINE (full queue) ====== -->
        <% if (state.queue.length > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3">📋 The Line</h3>
            <% if (state.king) { %>
            <div class="flex items-center gap-3 p-2 mb-2 bg-throne-gold/10 border border-throne-gold/30 rounded-lg">
                <span class="text-xl">👑</span>
                <span class="font-bold text-throne-gold"><%= state.king.name %></span>
                <span class="text-xs text-gray-500 ml-auto">defending</span>
            </div>
            <% } %>
            <div class="space-y-1">
                <% state.queue.forEach((entry, i) => { %>
                <div class="flex items-center gap-3 p-2 rounded-lg <%= entry.player_id === player.id ? 'bg-throne-gold/10 border border-throne-gold/30' : 'bg-throne-darker' %> <%= entry.status === 'on_deck' ? 'border border-throne-gold' : '' %>">
                    <span class="text-sm font-mono w-6 text-center <%= entry.status === 'on_deck' ? 'text-throne-gold' : 'text-gray-600' %>">
                        <%= entry.status === 'on_deck' ? '🔔' : entry.position %>
                    </span>
                    <span class="<%= entry.player_id === player.id ? 'text-throne-gold font-bold' : '' %>">
                        <%= entry.player_name %><%= entry.player_id === player.id ? ' (you)' : '' %>
                    </span>
                    <% if (entry.status === 'on_deck') { %>
                    <span class="text-xs text-throne-gold ml-auto">UP NEXT</span>
                    <% } %>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- ====== CLAIM SATS ====== -->
        <% if (player.sat_balance > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3">⚡ Cash Out</h3>
            <p class="text-sm text-gray-400 mb-3">Send your <span class="text-throne-gold font-bold"><%= player.sat_balance.toLocaleString() %> sats</span> to your Lightning wallet</p>
            <form id="claim-form" onsubmit="return handleClaim(event)">
                <input type="text" id="ln-address" class="input mb-2" placeholder="Lightning address (e.g. you@walletofsatoshi.com)">
                <input type="number" id="claim-amount" class="input mb-3" placeholder="Amount (leave blank for all)" max="<%= player.sat_balance %>">
                <button type="submit" class="btn-gold w-full">⚡ Send <%= player.sat_balance.toLocaleString() %> sats</button>
            </form>
            <div id="claim-result" class="hidden mt-3 p-3 rounded-lg text-sm"></div>
        </div>
        <% } %>

        <!-- ====== STATS ====== -->
        <% if (player.games_played > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3">📊 Your Stats</h3>
            <div class="grid grid-cols-3 gap-2 text-center">
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= player.games_played %></div>
                    <div class="text-xs text-gray-400">Games</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-green-400"><%= player.games_won %></div>
                    <div class="text-xs text-gray-400">Wins</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-throne-gold"><%= player.times_as_king %></div>
                    <div class="text-xs text-gray-400">👑 Reigns</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-throne-gold"><%= player.total_sats_earned.toLocaleString() %></div>
                    <div class="text-xs text-gray-400">Total Sats</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= player.longest_win_streak %></div>
                    <div class="text-xs text-gray-400">Best Streak</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= Math.floor(player.longest_reign_seconds / 60) %>m</div>
                    <div class="text-xs text-gray-400">Long Reign</div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- ====== RECENT GAMES ====== -->
        <% if (games.length > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3">Recent Games</h3>
            <div class="space-y-2">
                <% games.forEach(g => { %>
                <div class="bg-throne-darker rounded-lg p-3 flex items-center justify-between">
                    <div>
                        <span class="text-sm">
                            <% if (g.king_id === player.id) { %>
                                👑 vs <%= g.challenger_name %>
                            <% } else { %>
                                ⚔️ vs <%= g.king_name %> (King)
                            <% } %>
                        </span>
                        <span class="text-xs text-gray-500 ml-2">#<%= g.chess960_position %></span>
                    </div>
                    <div>
                        <% if (g.result === 'king_won') { %>
                            <span class="text-sm font-bold <%= g.king_id === player.id ? 'text-green-400' : 'text-red-400' %>">
                                <%= g.king_id === player.id ? 'Won' : 'Lost' %>
                            </span>
                        <% } else if (g.result === 'challenger_won') { %>
                            <span class="text-sm font-bold <%= g.challenger_id === player.id ? 'text-green-400' : 'text-red-400' %>">
                                <%= g.challenger_id === player.id ? 'Won' : 'Lost' %>
                            </span>
                        <% } else { %>
                            <span class="text-sm font-bold text-gray-400">Draw</span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- Nav -->
        <div class="flex justify-center gap-6 text-sm text-gray-500 mb-4">
            <a href="/throne" class="hover:text-throne-gold transition-colors">👑 Throne</a>
            <a href="/leaderboard" class="hover:text-throne-gold transition-colors">🏆 Leaderboard</a>
        </div>
    </div>

    <script>
        const socket = io();
        const playerId = <%= player.id %>;

        // Live sat counter for king
        <% if (state.king && state.king.id === player.id) { %>
        let liveSats = <%= state.liveSats %>;
        const satRate = <%= state.config.satRate %>;
        setInterval(() => {
            liveSats += satRate;
            const el = document.getElementById('live-sats');
            if (el) el.textContent = liveSats.toLocaleString();
        }, 1000);
        <% } %>

        // On-deck countdown
        <% if (queueEntry && queueEntry.status === 'on_deck') { %>
        let timeLeft = <%= state.config.queueTimeout %>;
        <% if (queueEntry.on_deck_since) { %>
        timeLeft -= Math.floor((Date.now() - new Date('<%= queueEntry.on_deck_since %>').getTime()) / 1000);
        <% } %>
        const timerEl = document.getElementById('on-deck-timer');
        setInterval(() => {
            timeLeft--;
            if (timerEl) timerEl.textContent = Math.max(0, timeLeft);
        }, 1000);
        <% } %>

        // Socket events — reload on any state change
        socket.on('game_started', (data) => {
            if (data.king.id === playerId || data.challenger.id === playerId) {
                window.location.href = '/game';
            }
        });
        socket.on('on_deck', () => location.reload());
        socket.on('new_king', () => location.reload());
        socket.on('game_ended', () => location.reload());
        socket.on('queue_updated', () => location.reload());

        async function leaveQueue() {
            if (!confirm('Leave the line?')) return;
            await fetch('/api/queue/leave', { method: 'POST' });
            location.reload();
        }

        async function handleClaim(e) {
            e.preventDefault();
            const address = document.getElementById('ln-address').value.trim();
            const amount = document.getElementById('claim-amount').value;
            const resultEl = document.getElementById('claim-result');

            if (!address) { alert('Enter a Lightning address'); return; }

            resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-blue-900/50 border border-blue-700 text-blue-300';
            resultEl.textContent = '⚡ Sending payment...';
            resultEl.classList.remove('hidden');

            try {
                const res = await fetch('/api/claim', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lightningAddress: address, amount: amount || undefined })
                });
                const data = await res.json();
                if (!res.ok) {
                    resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
                    resultEl.textContent = data.error + (data.hint ? '\n' + data.hint : '');
                } else {
                    resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-green-900/50 border border-green-700 text-green-300';
                    resultEl.textContent = data.message;
                    setTimeout(() => location.reload(), 2000);
                }
                resultEl.classList.remove('hidden');
            } catch (err) {
                resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
                resultEl.textContent = 'Connection error';
                resultEl.classList.remove('hidden');
            }
        }
    </script>
</body>
</html>
