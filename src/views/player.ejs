<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= player.name %> — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
        @keyframes pulseGold { 0%, 100% { box-shadow: 0 0 0 0 rgba(255,215,0,0.4); } 50% { box-shadow: 0 0 20px 5px rgba(255,215,0,0.2); } }
        .pulse-gold { animation: pulseGold 2s infinite; }
        /* Style html5-qrcode scanner to match dark theme */
        #qr-reader { border: none !important; background: transparent !important; }
        #qr-reader video { border-radius: 0.5rem; }
        #qr-reader__scan_region { background: transparent !important; }
        #qr-reader__dashboard { display: none !important; }
        #qr-reader__header_message { display: none !important; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker p-4 pb-24">
    <div class="max-w-lg mx-auto">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold">Hey, <%= player.name %> 👋</h1>
                <div class="text-xs text-gray-500 mt-1 flex items-center gap-1"><%- include('partials/icon', { name: 'lightning', size: 14, cls: 'text-throne-gold' }) %> Lightning login</div>
            </div>
            <div class="text-right">
                <div class="text-2xl font-mono text-throne-gold font-bold flex items-center gap-1 justify-end"><%- include('partials/icon', { name: 'lightning', size: 22, cls: 'text-throne-gold' }) %> <%= player.sat_balance.toLocaleString() %></div>
                <div class="text-xs text-gray-400">sat balance</div>
                <% if (player.total_sats_earned > player.sat_balance) { %>
                <div class="text-xs text-gray-600"><%= player.total_sats_earned.toLocaleString() %> earned</div>
                <% } %>
                <% if (player.total_sats_claimed > 0) { %>
                <div class="text-xs text-green-600"><%= player.total_sats_claimed.toLocaleString() %> paid out ✓</div>
                <% } %>
            </div>
        </div>

        <!-- ====== KING BANNER ====== -->
        <% if (state.king && state.king.id === player.id) { %>
        <div class="card border-throne-gold mb-4 text-center pulse-gold">
            <div class="mb-2"><%- include('partials/icon', { name: 'crown', size: 48, cls: 'text-throne-gold' }) %></div>
            <div class="text-xl font-bold text-throne-gold">You are the King!</div>
            <div class="text-sm text-gray-400 mt-1">Earning <span class="text-throne-gold font-bold"><%= state.config.satRate %></span> sats/sec right now</div>
            <div class="text-4xl font-mono text-throne-gold mt-3" id="live-sats"><%= state.liveSats.toLocaleString() %></div>
            <div class="text-xs text-gray-500">sats this reign</div>
            <div class="text-sm text-gray-400 mt-3">Defend your throne against all challengers!</div>
        </div>
        <% } %>

        <!-- ====== ACTIVE GAME BANNER ====== -->
        <% if (state.game && (state.game.king_id === player.id || state.game.challenger_id === player.id)) { %>
        <a href="/game" class="block card border-throne-gold mb-4 text-center pulse-gold">
            <div class="text-2xl font-bold text-throne-gold flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'crossed-swords', size: 28, cls: 'text-throne-gold' }) %> Game in Progress!</div>
            <div class="text-gray-300 mt-2">
                <%= state.game.king_name %> <span class="text-gray-500">vs</span> <%= state.game.challenger_name %>
            </div>
            <div class="text-sm text-gray-500 mt-1">Position #<%= state.game.chess960_position %></div>
            <div class="text-sm text-yellow-400 mt-1 flex items-center justify-center gap-1"><%- include('partials/icon', { name: 'stopwatch', size: 16, cls: 'text-yellow-400' }) %> Started <span id="player-game-elapsed">0:00</span> ago</div>
            <div class="btn-gold inline-block mt-3 text-sm">Report Result →</div>
        </a>
        <% } %>

        <!-- ====== IN QUEUE ====== -->
        <% if (queueEntry) { %>
        <div class="card mb-4">
            <div class="flex items-center justify-between">
                <div>
                    <div class="text-sm text-gray-400">Your position in line</div>
                    <div class="text-4xl font-bold text-throne-gold">#<%= queueEntry.position %></div>
                    <div class="text-xs text-gray-500 mt-1">
                        <% if (queueEntry.position === 1) { %>
                            You're next! Wait for the current game to finish.
                        <% } else if (queueEntry.position <= 3) { %>
                            Almost there — stay close to the board!
                        <% } else { %>
                            Hang tight, games move fast ⚡
                        <% } %>
                    </div>
                </div>
                <button onclick="leaveQueue()" class="text-sm text-red-400 hover:text-red-300 border border-red-800 px-3 py-2 rounded-lg">Leave Line</button>
            </div>
        </div>

        <!-- ====== NOT IN QUEUE — INLINE JOIN WITH SCAN ====== -->
        <% } else if (!state.king || state.king.id !== player.id) { %>
        <div class="card mb-4">
            <div class="text-lg font-bold mb-2 text-center">Ready to play?</div>
            <% if (state.king) { %>
            <div class="text-gray-400 mb-4 text-center">
                <span class="text-throne-gold font-bold"><%= state.king.name %></span> is on the throne.
                <% if (state.queue.length === 0) { %>
                    No one in line — you could be next!
                <% } else { %>
                    <%= state.queue.length %> challenger<%= state.queue.length === 1 ? '' : 's' %> in line.
                <% } %>
            </div>
            <% } else { %>
            <div class="text-gray-400 mb-4 text-center">No King yet — be the first to claim the throne!</div>
            <% } %>

            <div class="text-sm text-gray-400 mb-3 text-center">📍 If you're at the venue, scan the QR to join</div>

            <!-- QR Scanner -->
            <div id="scanner-section" class="mb-3">
                <button onclick="startScanner()" id="scan-btn" class="w-full py-3 px-4 rounded-lg bg-throne-dark border border-gray-700 text-gray-300 hover:border-throne-gold hover:text-throne-gold transition-colors flex items-center justify-center gap-2">
                    <span class="text-xl">📷</span> Scan Venue QR Code
                </button>
                <div id="scanner-container" class="hidden mt-3 relative">
                    <div id="qr-reader" style="width: 100%;"></div>
                    <button onclick="stopScanner()" class="absolute top-2 right-2 z-10 bg-black/70 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm">✕</button>
                </div>
            </div>

            <!-- Manual Code Entry (hidden — venue code submitted automatically via QR scan) -->
            <div class="hidden">
                <input type="text" id="venue-code-input">
                <button id="join-btn">Join</button>
            </div>

            <div id="join-result" class="hidden mt-3 p-3 rounded-lg text-sm text-center"></div>
        </div>
        <% } %>

        <!-- ====== THE LINE (full queue) ====== -->
        <% if (state.queue.length > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> The Line</h3>
            <% if (state.king) { %>
            <div class="flex items-center gap-3 p-2 mb-2 bg-throne-gold/10 border border-throne-gold/30 rounded-lg">
                <%- include('partials/icon', { name: 'crown', size: 22, cls: 'text-throne-gold' }) %>
                <span class="font-bold text-throne-gold"><%= state.king.name %></span>
                <span class="text-xs text-gray-500 ml-auto">defending</span>
            </div>
            <% } %>
            <div class="space-y-1">
                <% state.queue.forEach((entry, i) => { %>
                <div class="flex items-center gap-3 p-2 rounded-lg <%= entry.player_id === player.id ? 'bg-throne-gold/10 border border-throne-gold/30' : 'bg-throne-darker' %> <%= entry.status === 'on_deck' ? 'border border-throne-gold' : '' %>">
                    <span class="text-sm font-mono w-6 text-center <%= entry.status === 'on_deck' ? 'text-throne-gold' : 'text-gray-600' %>">
                        <% if (entry.status === 'on_deck') { %><%- include('partials/icon', { name: 'bell', size: 16, cls: 'text-throne-gold' }) %><% } else { %><%= entry.position %><% } %>
                    </span>
                    <span class="<%= entry.player_id === player.id ? 'text-throne-gold font-bold' : '' %>">
                        <%= entry.player_name %><%= entry.player_id === player.id ? ' (you)' : '' %>
                    </span>
                    <% if (entry.status === 'on_deck') { %>
                    <span class="text-xs text-throne-gold ml-auto">UP NEXT</span>
                    <% } %>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- ====== CLAIM SATS ====== -->
        <% if (player.sat_balance > 0) { %>
        <div class="card mb-4" id="claim-card">
            <h3 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 20, cls: 'text-throne-gold' }) %> Cash Out</h3>
            
            <% if (player.sat_balance >= 200000) { %>
            <!-- ===== ON-CHAIN BITCOIN CASHOUT (≥200k sats) — PRIMARY ===== -->
            <div id="onchain-section">
                <p class="text-sm text-gray-400 mb-3">Send <span class="text-throne-gold font-bold"><%= player.sat_balance.toLocaleString() %></span> sats to your Bitcoin wallet (on-chain)</p>
                <input type="text" id="btc-address" class="input mb-3" placeholder="Bitcoin address (bc1...)">
                <button onclick="sendOnChain()" id="onchain-btn" class="w-full py-4 text-lg flex items-center justify-center gap-2 rounded-lg font-bold bg-orange-600 hover:bg-orange-500 text-white transition-colors">
                    ⛓️ Send Bitcoin
                </button>
                <div class="text-xs text-gray-600 mt-2 text-center">On-chain transaction — may take ~10-60 min to confirm. Fees paid by us.</div>
            </div>
            <div id="onchain-success-section" class="hidden text-center py-4">
                <div class="text-4xl mb-2">⛓️</div>
                <div class="text-xl font-bold text-green-400" id="onchain-success-msg"></div>
                <div class="text-sm text-gray-500 mt-2" id="onchain-txid-link"></div>
            </div>
            <div id="onchain-error-section" class="hidden">
                <div class="bg-red-900/50 border border-red-700 rounded-lg p-3 text-sm text-red-300 text-center" id="onchain-error-msg"></div>
                <button onclick="resetOnChain()" class="text-sm text-gray-400 hover:text-gray-200 mt-3 w-full text-center">Try Again</button>
            </div>

            <!-- Lightning withdraw as secondary option for large balances -->
            <details class="mt-4 border-t border-gray-800 pt-3">
                <summary class="text-xs text-gray-600 cursor-pointer hover:text-gray-400 transition-colors">Use Lightning instead</summary>
                <div class="mt-3">
            <% } %>

            <!-- Primary (or secondary if ≥200k): One-tap LNURL-withdraw -->
            <div id="claim-tap-section">
                <% if (player.sat_balance < 200000) { %>
                <p class="text-sm text-gray-400 mb-3">Tap to send sats straight to your Lightning wallet</p>
                <% } %>
                <button onclick="startWithdraw()" id="claim-btn" class="btn-gold w-full py-4 text-lg flex items-center justify-center gap-2">
                    <%- include('partials/icon', { name: 'lightning', size: 24, cls: '' }) %> Claim <span id="claim-btn-amount"><%= player.sat_balance.toLocaleString() %></span> sats
                </button>
            </div>

            <!-- Withdraw QR / Deep Link (shown after tap) -->
            <div id="claim-withdraw-section" class="hidden">
                <div class="text-center">
                    <div class="text-sm text-gray-400 mb-3">Open in your wallet to receive <span class="text-throne-gold font-bold" id="withdraw-amount"></span> sats</div>
                    
                    <!-- QR Code (for scanning from another device) -->
                    <div id="claim-qr-container" class="mb-3">
                        <img id="claim-qr-img" src="" alt="Withdraw QR" class="mx-auto rounded-lg" style="max-width: 250px;">
                    </div>

                    <!-- Open in Wallet button (primary action on mobile) -->
                    <a id="claim-deep-link" href="#" class="btn-gold w-full py-4 text-lg flex items-center justify-center gap-2 mb-3">
                        <%- include('partials/icon', { name: 'lightning', size: 24, cls: '' }) %> Open in Wallet
                    </a>

                    <div id="claim-status" class="text-sm text-gray-500 flex items-center justify-center gap-2">
                        <%- include('partials/icon', { name: 'hourglass', size: 16, cls: 'text-gray-500' }) %> Waiting for wallet...
                    </div>
                    
                    <button onclick="cancelWithdraw()" class="text-xs text-gray-600 hover:text-gray-400 mt-3 transition-colors">Cancel</button>
                </div>
            </div>

            <!-- Success state -->
            <div id="claim-success-section" class="hidden text-center py-4">
                <div class="text-4xl mb-2">⚡</div>
                <div class="text-xl font-bold text-green-400" id="claim-success-msg"></div>
                <div class="text-sm text-gray-500 mt-2">Check your wallet — sats should arrive instantly</div>
            </div>

            <!-- Error state -->
            <div id="claim-error-section" class="hidden">
                <div class="bg-red-900/50 border border-red-700 rounded-lg p-3 text-sm text-red-300 text-center" id="claim-error-msg"></div>
                <button onclick="resetClaim()" class="text-sm text-gray-400 hover:text-gray-200 mt-3 w-full text-center">Try Again</button>
            </div>

            <!-- Fallback: Lightning address (collapsed) -->
            <details class="mt-4 border-t border-gray-800 pt-3">
                <summary class="text-xs text-gray-600 cursor-pointer hover:text-gray-400 transition-colors">Send to Lightning address instead</summary>
                <form id="claim-form" onsubmit="return handleClaim(event)" class="mt-3">
                    <input type="text" id="ln-address" class="input mb-2" placeholder="Lightning address (e.g. you@walletofsatoshi.com)">
                    <input type="number" id="claim-amount" class="input mb-3" placeholder="Amount (leave blank for all)" max="<%= player.sat_balance %>">
                    <button type="submit" class="btn-gold w-full flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 20, cls: '' }) %> Send sats</button>
                </form>
                <div id="claim-result" class="hidden mt-3 p-3 rounded-lg text-sm"></div>
            </details>

            <% if (player.sat_balance >= 200000) { %>
                </div><!-- close Lightning fallback inner div -->
            </details><!-- close "Use Lightning instead" details -->
            <% } %>
        </div>
        <% } %>

        <!-- ====== STATS ====== -->
        <% if (player.games_played > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'chart', size: 20, cls: '' }) %> Your Stats</h3>
            <div class="grid grid-cols-3 gap-2 text-center">
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= player.games_played %></div>
                    <div class="text-xs text-gray-400">Games</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-green-400"><%= player.games_won %></div>
                    <div class="text-xs text-gray-400">Wins</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-throne-gold"><%= player.times_as_king %></div>
                    <div class="text-xs text-gray-400 flex items-center justify-center gap-1"><%- include('partials/icon', { name: 'crown', size: 12, cls: 'text-throne-gold' }) %> Reigns</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold text-throne-gold"><%= player.total_sats_earned.toLocaleString() %></div>
                    <div class="text-xs text-gray-400">Total Sats</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= player.longest_win_streak %></div>
                    <div class="text-xs text-gray-400">Best Streak</div>
                </div>
                <div class="bg-throne-darker rounded-lg p-3">
                    <div class="text-2xl font-bold"><%= Math.floor(player.longest_reign_seconds / 60) %>m</div>
                    <div class="text-xs text-gray-400">Long Reign</div>
                </div>
            </div>
        </div>
        <% } %>

        <!-- ====== RECENT GAMES ====== -->
        <% if (games.length > 0) { %>
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3">Recent Games</h3>
            <div class="space-y-2">
                <% games.forEach(g => { %>
                <div class="bg-throne-darker rounded-lg p-3 flex items-center justify-between">
                    <div>
                        <span class="text-sm">
                            <% if (g.king_id === player.id) { %>
                                <%- include('partials/icon', { name: 'crown', size: 16, cls: 'text-throne-gold' }) %> vs <%= g.challenger_name %>
                            <% } else { %>
                                <%- include('partials/icon', { name: 'crossed-swords', size: 16, cls: '' }) %> vs <%= g.king_name %> (King)
                            <% } %>
                        </span>
                        <span class="text-xs text-gray-500 ml-2">#<%= g.chess960_position %></span>
                    </div>
                    <div>
                        <% if (g.result === 'king_won') { %>
                            <span class="text-sm font-bold <%= g.king_id === player.id ? 'text-green-400' : 'text-red-400' %>">
                                <%= g.king_id === player.id ? 'Won' : 'Lost' %>
                            </span>
                        <% } else if (g.result === 'challenger_won') { %>
                            <span class="text-sm font-bold <%= g.challenger_id === player.id ? 'text-green-400' : 'text-red-400' %>">
                                <%= g.challenger_id === player.id ? 'Won' : 'Lost' %>
                            </span>
                        <% } else { %>
                            <span class="text-sm font-bold text-gray-400">Draw</span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <!-- ====== TELEGRAM NOTIFICATIONS ====== -->
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'bell', size: 20, cls: '' }) %> Telegram Notifications</h3>
            <div id="telegram-section">
                <% if (player.telegram_chat_id) { %>
                <!-- Linked -->
                <div class="flex items-center justify-between">
                    <div>
                        <div class="text-green-400 text-sm font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'checkmark', size: 16, cls: 'text-green-400' }) %> Connected</div>
                        <div class="text-xs text-gray-500 mt-1">You'll get notified when it's your turn</div>
                    </div>
                    <button onclick="unlinkTelegram()" class="text-sm text-red-400 hover:text-red-300 border border-red-800 px-3 py-2 rounded-lg">Unlink</button>
                </div>
                <% } else { %>
                <!-- Not linked -->
                <p class="text-sm text-gray-400 mb-3">Get a Telegram message when you're up next, your game starts, or you become King.</p>
                <button onclick="linkTelegram()" id="tg-link-btn" class="btn-gold w-full flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'phone', size: 20, cls: '' }) %> Connect Telegram</button>
                <div id="tg-link-steps" class="hidden mt-3">
                    <div class="bg-throne-darker rounded-lg p-4 text-center">
                        <div class="text-sm text-gray-300 mb-3">Tap the button below to open the bot in Telegram:</div>
                        <a id="tg-deep-link" href="#" target="_blank" class="inline-block bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-lg transition-colors">
                            Open in Telegram →
                        </a>
                        <div class="text-xs text-gray-500 mt-3">The bot will confirm once you're linked.</div>
                        <div id="tg-link-polling" class="text-xs text-gray-600 mt-2">Waiting for confirmation...</div>
                    </div>
                </div>
                <% } %>
            </div>
        </div>

        <!-- ====== EMAIL / PROFILE ====== -->
        <div class="card mb-4">
            <h3 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'user', size: 20, cls: '' }) %> Profile</h3>
            <div class="mb-3">
                <label class="text-xs text-gray-400 block mb-1">Email (optional — for account recovery)</label>
                <div class="flex gap-2">
                    <input type="email" id="email-input" class="input flex-1" placeholder="you@example.com" value="<%= player.email || '' %>">
                    <button onclick="saveEmail()" id="save-email-btn" class="px-4 py-2 rounded-lg bg-throne-dark border border-gray-700 text-gray-300 hover:border-throne-gold hover:text-throne-gold transition-colors text-sm">Save</button>
                </div>
                <div id="email-result" class="hidden mt-2 text-xs"></div>
            </div>
        </div>

        <!-- Nav -->
        <div class="flex justify-center gap-6 text-sm text-gray-500 mb-4">
            <a href="/throne" class="hover:text-throne-gold transition-colors flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 16, cls: '' }) %> Throne</a>
            <a href="/leaderboard" class="hover:text-throne-gold transition-colors flex items-center gap-1"><%- include('partials/icon', { name: 'trophy', size: 16, cls: '' }) %> Leaderboard</a>
        </div>

        <div class="text-center mb-6">
            <button onclick="logout()" class="text-xs text-gray-700 hover:text-gray-500 transition-colors">sign out</button>
        </div>
    </div>

    <!-- html5-qrcode library — proper camera selection + native barcode detection -->
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
        const socket = io();
        const playerId = <%- player.id %>;

        // Live sat counter for king — derives from crowned_at (single source of truth)
        <% if (state.king && state.king.id === player.id && state.reign) { %>
        const reignStart = new Date('<%- state.reign.crowned_at %><%- state.reign.crowned_at.endsWith("Z") ? "" : "Z" %>').getTime();
        const satRate = <%- state.config.satRate %>;
        function updateKingSats() {
            const reignSec = Math.floor((Date.now() - reignStart) / 1000);
            const totalSats = reignSec * satRate;
            const el = document.getElementById('live-sats');
            if (el) el.textContent = totalSats.toLocaleString();
        }
        setInterval(updateKingSats, 1000);
        updateKingSats();
        <% } %>

        // On-deck countdown
        <% if (queueEntry && queueEntry.status === 'on_deck') { %>
        let timeLeft = <%- state.config.queueTimeout %>;
        <% if (queueEntry.on_deck_since) { %>
        timeLeft -= Math.floor((Date.now() - new Date('<%- queueEntry.on_deck_since %>Z').getTime()) / 1000);
        <% } %>
        const timerEl = document.getElementById('on-deck-timer');
        setInterval(() => {
            timeLeft--;
            if (timerEl) timerEl.textContent = Math.max(0, timeLeft);
        }, 1000);
        <% } %>

        // Game elapsed timer on player dashboard
        <% if (state.game && state.game.started_at && (state.game.king_id === player.id || state.game.challenger_id === player.id)) { %>
        (function() {
            const gameStart = new Date('<%- state.game.started_at %><%- state.game.started_at.endsWith("Z") ? "" : "Z" %>').getTime();
            const el = document.getElementById('player-game-elapsed');
            function tickGame() {
                const sec = Math.floor((Date.now() - gameStart) / 1000);
                const m = Math.floor(sec / 60);
                const s = sec % 60;
                if (el) el.textContent = m + ':' + String(s).padStart(2, '0');
            }
            tickGame();
            setInterval(tickGame, 1000);
        })();
        <% } %>

        // Socket events — reload on any state change
        socket.on('game_started', (data) => {
            if (data.king.id === playerId || data.challenger.id === playerId) {
                window.location.href = '/game';
            }
        });
        socket.on('on_deck', () => location.reload());
        socket.on('new_king', () => location.reload());
        socket.on('game_ended', () => location.reload());
        socket.on('queue_updated', () => location.reload());

        async function leaveQueue() {
            if (!confirm('Leave the line?')) return;
            await fetch('/api/queue/leave', { method: 'POST' });
            location.reload();
        }

        async function logout() {
            await fetch('/api/logout', { method: 'POST' });
            window.location.href = '/';
        }

        // ====== QR Scanner (html5-qrcode) ======
        let html5QrCode = null;

        async function applyOptimalZoom(videoElement) {
            // Apply real camera zoom (not digital) via MediaStreamTrack constraints
            // This works on Android Chrome and Safari iOS 17+
            try {
                if (!videoElement || !videoElement.srcObject) return;
                const videoTrack = videoElement.srcObject.getVideoTracks()[0];
                if (!videoTrack) return;

                const caps = videoTrack.getCapabilities ? videoTrack.getCapabilities() : {};
                const settings = videoTrack.getSettings ? videoTrack.getSettings() : {};

                console.log('[QR Camera] Track capabilities:', JSON.stringify(caps));
                console.log('[QR Camera] Track settings:', JSON.stringify(settings));

                if (caps.zoom) {
                    // Target 2x zoom — this switches to main lens on most phones
                    // On phones where min zoom is already 1.0, 2.0 gives a nice close-up
                    const target = Math.min(2.0, caps.zoom.max);
                    const zoomVal = Math.max(target, caps.zoom.min);
                    console.log('[QR Camera] Applying zoom:', zoomVal, '(range:', caps.zoom.min, '-', caps.zoom.max, ')');
                    await videoTrack.applyConstraints({ advanced: [{ zoom: zoomVal }] });
                    console.log('[QR Camera] Zoom applied successfully');
                } else {
                    console.log('[QR Camera] Zoom not supported on this track');
                }

                // Also ensure continuous autofocus
                if (caps.focusMode && caps.focusMode.includes('continuous')) {
                    await videoTrack.applyConstraints({ advanced: [{ focusMode: 'continuous' }] });
                }
            } catch (e) {
                console.warn('[QR Camera] Zoom/focus error:', e);
            }
        }

        async function startScanner() {
            const container = document.getElementById('scanner-container');
            const scanBtn = document.getElementById('scan-btn');

            container.classList.remove('hidden');
            scanBtn.style.display = 'none';

            try {
                html5QrCode = new Html5Qrcode('qr-reader');

                // Get available cameras and pick the best rear one
                const cameras = await Html5Qrcode.getCameras();
                console.log('[QR Camera] Available cameras:', JSON.stringify(cameras.map(c => ({id: c.id, label: c.label}))));
                let cameraId = null;

                if (cameras && cameras.length > 0) {
                    // Strategy: find rear cameras, then pick the MAIN one (not ultra-wide)
                    // Android labels: "camera2 0, facing back" (main), "camera2 2, facing back" (wide)
                    // iPhone labels: "Back Camera" (main), "Back Ultra Wide Camera" (wide)
                    const rearCameras = cameras.filter(c => {
                        const label = c.label.toLowerCase();
                        return label.includes('back') || label.includes('rear') || label.includes('environment');
                    });

                    // Filter out ultra-wide / wide-angle cameras
                    const mainCameras = rearCameras.filter(c => {
                        const label = c.label.toLowerCase();
                        return !label.includes('ultra') && !label.includes('wide');
                    });

                    // On Android, camera labels often don't say "wide" — pick camera2 0 (usually main)
                    // If we have multiple rear cameras and can't distinguish, pick the first non-wide
                    if (mainCameras.length > 0) {
                        cameraId = mainCameras[0].id;
                        console.log('[QR Camera] Selected main camera:', mainCameras[0].label);
                    } else if (rearCameras.length > 0) {
                        // If all rear cameras matched "wide", just use the first rear one
                        // and rely on zoom to compensate
                        cameraId = rearCameras[0].id;
                        console.log('[QR Camera] Selected rear camera (may be wide):', rearCameras[0].label);
                    }
                }

                const config = {
                    fps: 10,
                    qrbox: { width: 250, height: 250 },
                    aspectRatio: 1.0,
                    experimentalFeatures: {
                        useBarCodeDetectorIfSupported: true
                    }
                };

                const onScanSuccess = (decodedText) => {
                    let code = '';
                    try {
                        const url = new URL(decodedText);
                        code = url.searchParams.get('code') || '';
                    } catch {
                        code = decodedText.trim();
                    }
                    if (code) {
                        stopScanner();
                        document.getElementById('venue-code-input').value = code.toUpperCase();
                        joinWithCode();
                    }
                };

                if (cameraId) {
                    await html5QrCode.start(cameraId, config, onScanSuccess);
                } else {
                    await html5QrCode.start(
                        { facingMode: { exact: 'environment' } },
                        config,
                        onScanSuccess
                    );
                }

                // Wait a moment for video element to be ready, then apply zoom
                setTimeout(async () => {
                    const videoEl = document.querySelector('#qr-reader video');
                    await applyOptimalZoom(videoEl);
                }, 500);

            } catch (err) {
                console.error('Scanner error:', err);
                container.innerHTML = '<div class="p-4 text-center text-red-400 text-sm">Camera not available — type the code below instead</div>';
            }
        }

        async function stopScanner() {
            if (html5QrCode) {
                try {
                    await html5QrCode.stop();
                } catch (e) { /* already stopped */ }
                html5QrCode.clear();
                html5QrCode = null;
            }
            const container = document.getElementById('scanner-container');
            const scanBtn = document.getElementById('scan-btn');
            if (container) container.classList.add('hidden');
            if (scanBtn) scanBtn.style.display = '';
        }

        async function joinWithCode() {
            const input = document.getElementById('venue-code-input');
            const code = input ? input.value.trim().toUpperCase() : '';
            if (!code) { alert('Enter the venue code'); return; }

            const btn = document.getElementById('join-btn');
            const resultEl = document.getElementById('join-result');
            if (btn) { btn.disabled = true; btn.textContent = 'Joining...'; }

            try {
                const res = await fetch('/api/queue/join', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ venueCode: code })
                });
                const data = await res.json();
                if (resultEl) resultEl.classList.remove('hidden');
                if (!res.ok) {
                    if (resultEl) {
                        resultEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-900/50 border border-red-700 text-red-300';
                        resultEl.textContent = data.error;
                    }
                    if (btn) { btn.disabled = false; btn.textContent = '⚔️ Join'; }
                } else {
                    if (resultEl) {
                        resultEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-green-900/50 border border-green-700 text-green-300';
                        resultEl.textContent = "You're #" + data.position + ' in line! ⚔️';
                    }
                    setTimeout(() => location.reload(), 1500);
                }
            } catch (err) {
                if (resultEl) {
                    resultEl.classList.remove('hidden');
                    resultEl.className = 'mt-3 p-3 rounded-lg text-sm text-center bg-red-900/50 border border-red-700 text-red-300';
                    resultEl.textContent = 'Connection error';
                }
                if (btn) { btn.disabled = false; btn.textContent = '⚔️ Join'; }
            }
        }

        async function saveEmail() {
            const input = document.getElementById('email-input');
            const btn = document.getElementById('save-email-btn');
            const resultEl = document.getElementById('email-result');
            const email = input ? input.value.trim() : '';

            btn.disabled = true;
            btn.textContent = 'Saving...';

            try {
                const res = await fetch('/api/auth/set-email', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email || null })
                });
                const data = await res.json();
                resultEl.classList.remove('hidden');
                if (!res.ok) {
                    resultEl.className = 'mt-2 text-xs text-red-400';
                    resultEl.textContent = data.error;
                } else {
                    resultEl.className = 'mt-2 text-xs text-green-400';
                    resultEl.textContent = email ? '✓ Email saved' : '✓ Email removed';
                    setTimeout(() => resultEl.classList.add('hidden'), 3000);
                }
            } catch {
                resultEl.classList.remove('hidden');
                resultEl.className = 'mt-2 text-xs text-red-400';
                resultEl.textContent = 'Connection error';
            }
            btn.disabled = false;
            btn.textContent = 'Save';
        }

        // ====== Telegram Linking ======
        let tgPollInterval = null;

        async function linkTelegram() {
            const btn = document.getElementById('tg-link-btn');
            const steps = document.getElementById('tg-link-steps');
            if (btn) btn.style.display = 'none';

            try {
                const res = await fetch('/api/telegram/link', { method: 'POST' });
                const data = await res.json();
                if (!res.ok) {
                    alert(data.error || 'Failed to generate link');
                    if (btn) btn.style.display = '';
                    return;
                }

                // Show the deep link button
                const deepLinkEl = document.getElementById('tg-deep-link');
                if (deepLinkEl) deepLinkEl.href = data.deepLink;
                if (steps) steps.classList.remove('hidden');

                // Poll for link completion
                tgPollInterval = setInterval(async () => {
                    try {
                        const statusRes = await fetch('/api/telegram/status');
                        const statusData = await statusRes.json();
                        if (statusData.linked) {
                            clearInterval(tgPollInterval);
                            const pollingEl = document.getElementById('tg-link-polling');
                            if (pollingEl) {
                                pollingEl.textContent = '✅ Linked! Reloading...';
                                pollingEl.className = 'text-xs text-green-400 mt-2';
                            }
                            setTimeout(() => location.reload(), 1000);
                        }
                    } catch { /* ignore polling errors */ }
                }, 2000);

            } catch {
                alert('Connection error');
                if (btn) btn.style.display = '';
            }
        }

        async function unlinkTelegram() {
            if (!confirm('Unlink Telegram? You won\'t get notifications anymore.')) return;
            await fetch('/api/telegram/unlink', { method: 'POST' });
            location.reload();
        }

        // ====== On-chain Bitcoin cashout ======
        async function sendOnChain() {
            const addressInput = document.getElementById('btc-address');
            const btn = document.getElementById('onchain-btn');
            const address = addressInput ? addressInput.value.trim() : '';

            if (!address) { alert('Enter a Bitcoin address'); return; }

            btn.disabled = true;
            btn.textContent = '⛓️ Sending...';

            try {
                const res = await fetch('/api/claim/onchain', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bitcoinAddress: address })
                });
                const data = await res.json();

                if (!res.ok) {
                    document.getElementById('onchain-section').classList.add('hidden');
                    document.getElementById('onchain-error-section').classList.remove('hidden');
                    document.getElementById('onchain-error-msg').textContent = data.error;
                    return;
                }

                // Success
                document.getElementById('onchain-section').classList.add('hidden');
                document.getElementById('onchain-success-section').classList.remove('hidden');
                document.getElementById('onchain-success-msg').textContent = data.message;
                if (data.txid) {
                    document.getElementById('onchain-txid-link').innerHTML = 
                        '<a href="https://mempool.space/tx/' + data.txid + '" target="_blank" class="text-blue-400 hover:text-blue-300 underline">View on mempool.space →</a>';
                }
                setTimeout(() => location.reload(), 5000);
            } catch (err) {
                document.getElementById('onchain-section').classList.add('hidden');
                document.getElementById('onchain-error-section').classList.remove('hidden');
                document.getElementById('onchain-error-msg').textContent = 'Connection error';
            }
        }

        function resetOnChain() {
            const section = document.getElementById('onchain-section');
            const successSection = document.getElementById('onchain-success-section');
            const errorSection = document.getElementById('onchain-error-section');
            const btn = document.getElementById('onchain-btn');
            if (section) section.classList.remove('hidden');
            if (successSection) successSection.classList.add('hidden');
            if (errorSection) errorSection.classList.add('hidden');
            if (btn) { btn.disabled = false; btn.textContent = '⛓️ Send Bitcoin'; }
        }

        // ====== LNURL-withdraw (one-tap claim) ======
        let withdrawK1 = null;
        let withdrawPollInterval = null;

        async function startWithdraw() {
            const btn = document.getElementById('claim-btn');
            const tapSection = document.getElementById('claim-tap-section');
            const withdrawSection = document.getElementById('claim-withdraw-section');
            const successSection = document.getElementById('claim-success-section');
            const errorSection = document.getElementById('claim-error-section');

            btn.disabled = true;
            btn.textContent = 'Creating withdraw link...';

            try {
                const res = await fetch('/api/claim/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({})
                });
                const data = await res.json();

                if (!res.ok) {
                    btn.disabled = false;
                    btn.innerHTML = '⚡ Claim sats';
                    alert(data.error || 'Failed to create withdraw');
                    return;
                }

                withdrawK1 = data.k1;

                // Show the withdraw section
                tapSection.classList.add('hidden');
                successSection.classList.add('hidden');
                errorSection.classList.add('hidden');
                withdrawSection.classList.remove('hidden');

                // Set QR and deep link
                document.getElementById('claim-qr-img').src = data.qr;
                document.getElementById('claim-deep-link').href = data.deepLink;
                document.getElementById('withdraw-amount').textContent = data.amount.toLocaleString();

                // On mobile, auto-open the deep link
                if (/iPhone|iPad|Android/i.test(navigator.userAgent)) {
                    window.location.href = data.deepLink;
                }

                // Start polling for completion
                withdrawPollInterval = setInterval(async () => {
                    try {
                        const statusRes = await fetch('/api/claim/status/' + withdrawK1);
                        const statusData = await statusRes.json();

                        if (statusData.status === 'complete') {
                            clearInterval(withdrawPollInterval);
                            withdrawPollInterval = null;
                            // Show success
                            withdrawSection.classList.add('hidden');
                            successSection.classList.remove('hidden');
                            document.getElementById('claim-success-msg').textContent = statusData.message;
                            setTimeout(() => location.reload(), 3000);
                        } else if (statusData.status === 'failed') {
                            clearInterval(withdrawPollInterval);
                            withdrawPollInterval = null;
                            // Show error
                            withdrawSection.classList.add('hidden');
                            errorSection.classList.remove('hidden');
                            document.getElementById('claim-error-msg').textContent = statusData.error || 'Payment failed';
                        } else if (statusData.status === 'expired') {
                            clearInterval(withdrawPollInterval);
                            withdrawPollInterval = null;
                            resetClaim();
                        }
                    } catch { /* ignore polling errors */ }
                }, 1500);

            } catch (err) {
                btn.disabled = false;
                btn.innerHTML = '⚡ Claim sats';
                alert('Connection error');
            }
        }

        function cancelWithdraw() {
            if (withdrawPollInterval) {
                clearInterval(withdrawPollInterval);
                withdrawPollInterval = null;
            }
            withdrawK1 = null;
            resetClaim();
        }

        function resetClaim() {
            const tapSection = document.getElementById('claim-tap-section');
            const withdrawSection = document.getElementById('claim-withdraw-section');
            const successSection = document.getElementById('claim-success-section');
            const errorSection = document.getElementById('claim-error-section');
            const btn = document.getElementById('claim-btn');

            if (tapSection) tapSection.classList.remove('hidden');
            if (withdrawSection) withdrawSection.classList.add('hidden');
            if (successSection) successSection.classList.add('hidden');
            if (errorSection) errorSection.classList.add('hidden');
            if (btn) { btn.disabled = false; }
        }

        // ====== Lightning address claim (fallback) ======
        async function handleClaim(e) {
            e.preventDefault();
            const address = document.getElementById('ln-address').value.trim();
            const amount = document.getElementById('claim-amount').value;
            const resultEl = document.getElementById('claim-result');

            if (!address) { alert('Enter a Lightning address'); return; }

            resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-blue-900/50 border border-blue-700 text-blue-300';
            resultEl.textContent = '⚡ Sending payment...';
            resultEl.classList.remove('hidden');

            try {
                const res = await fetch('/api/claim', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ lightningAddress: address, amount: amount || undefined })
                });
                const data = await res.json();
                if (!res.ok) {
                    resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
                    resultEl.textContent = data.error + (data.hint ? '\n' + data.hint : '');
                } else {
                    resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-green-900/50 border border-green-700 text-green-300';
                    resultEl.textContent = data.message;
                    setTimeout(() => location.reload(), 2000);
                }
                resultEl.classList.remove('hidden');
            } catch (err) {
                resultEl.className = 'mt-3 p-3 rounded-lg text-sm bg-red-900/50 border border-red-700 text-red-300';
                resultEl.textContent = 'Connection error';
                resultEl.classList.remove('hidden');
            }
        }
    </script>
