<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        /* Inline fallback styles in case Tailwind CSS hasn't been built yet */
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
        .fallback-center { display: flex; justify-content: center; align-items: center; min-height: 100vh; }
    </style>
</head>
<body class="min-h-screen">
    <%- typeof body !== 'undefined' ? body : '' %>
    <% if (typeof content !== 'undefined') { %><%- content %><% } %>
    <script>
    // Secret zoom control: Ctrl+Shift+Minus/Plus to shrink/grow 1%, Ctrl+Shift+0 to reset
    (function() {
        var zoom = parseFloat(localStorage.getItem('_tz') || '100');
        document.documentElement.style.zoom = (zoom / 100);
        document.addEventListener('keydown', function(e) {
            if (!(e.ctrlKey && e.shiftKey)) return;
            if (e.key === '-' || e.key === '_') {
                e.preventDefault();
                zoom = Math.max(10, zoom - 1);
            } else if (e.key === '=' || e.key === '+') {
                e.preventDefault();
                zoom = Math.min(200, zoom + 1);
            } else if (e.key === '0' || e.key === ')') {
                e.preventDefault();
                zoom = 100;
            } else {
                return;
            }
            localStorage.setItem('_tz', String(zoom));
            document.documentElement.style.zoom = (zoom / 100);
        });
    })();
    </script>
</body>
</html>
