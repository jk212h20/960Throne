<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — King of the Hill Chess960</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        .pulse { animation: pulse 2s infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .spinner { animation: spin 1s linear infinite; display: inline-block; }
        #qr-container img { border-radius: 12px; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="text-6xl mb-4">♚</div>
            <h1 class="text-4xl font-bold text-throne-gold mb-2">960 Throne</h1>
            <p class="text-gray-400 text-lg">King of the Hill Chess960</p>
            <p class="text-gray-500 mt-1">Prospera, Roatán</p>
        </div>

        <!-- Current King ticker -->
        <% if (state.king) { %>
        <div class="card mb-6 text-center">
            <div class="text-sm text-gray-400 mb-1 flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: 'text-gray-400' }) %> Current King</div>
            <div class="text-2xl font-bold text-throne-gold"><%= state.king.name %></div>
            <div class="text-sm text-gray-400 mt-1">Earning <span class="text-throne-gold"><%= state.config.satRate %></span> sats/sec</div>
            <% if (state.queue.length > 0) { %>
            <div class="text-xs text-gray-500 mt-1"><%= state.queue.length %> challenger<%= state.queue.length === 1 ? '' : 's' %> in line</div>
            <% } %>
        </div>
        <% } %>

        <!-- How it works -->
        <div class="card mb-4">
            <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 20, cls: 'text-throne-gold' }) %> How it works</h2>
            <div class="space-y-2 text-sm text-gray-300">
                <div class="flex gap-2"><span class="text-throne-gold">1.</span> Login with your Lightning wallet below</div>
                <div class="flex gap-2"><span class="text-throne-gold">2.</span> Get in line to challenge the King</div>
                <div class="flex gap-2"><span class="text-throne-gold">3.</span> Beat the King → become the new King</div>
                <div class="flex gap-2"><span class="text-throne-gold">4.</span> The King earns <strong class="text-throne-gold">21 sats/second</strong> while on the throne</div>
                <div class="flex gap-2 items-center"><span class="text-throne-gold">5.</span> Cash out your sats via Lightning <%- include('partials/icon', { name: 'lightning', size: 14, cls: 'text-throne-gold' }) %></div>
            </div>
        </div>

        <!-- Error message -->
        <% if (error) { %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm"><%= error %></div>
        <% } %>

        <!-- Lightning Login -->
        <div class="card" id="login-card">
            <h2 class="text-xl font-bold mb-2 text-center flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 22, cls: 'text-throne-gold' }) %> Login with Lightning</h2>
            <p class="text-sm text-gray-400 mb-4 text-center">Scan with your Lightning wallet to login instantly</p>
            
            <!-- QR Code Area -->
            <div id="qr-container" class="flex flex-col items-center">
                <div id="qr-loading" class="text-center py-8">
                    <div class="mb-2"><%- include('partials/icon', { name: 'lightning', size: 28, cls: 'text-throne-gold' }) %></div>
                    <div class="text-sm text-gray-400">Generating login code...</div>
                </div>
                <div id="qr-code" class="hidden text-center">
                    <img id="qr-img" alt="Scan with Lightning wallet" class="mx-auto mb-3" style="width: 280px; height: 280px; background: #fff; padding: 8px; border-radius: 12px;">
                    <!-- Mobile deep link button -->
                    <a id="ln-deeplink" href="#" class="btn-gold inline-block text-lg px-8 mb-3 w-full text-center">
                        <%- include('partials/icon', { name: 'lightning', size: 20, cls: '' }) %> Open Wallet
                    </a>
                    <div class="text-xs text-gray-500 mt-1">Works with Phoenix, Zeus, Alby, Breez, and more</div>
                </div>
                <div id="qr-error" class="hidden text-center py-8">
                    <div class="text-red-400 mb-2">Failed to load login code</div>
                    <button onclick="loadChallenge()" class="btn-outline text-sm">Try Again</button>
                </div>
                <div id="qr-success" class="hidden text-center py-8">
                    <div class="mb-2"><%- include('partials/icon', { name: 'checkmark', size: 40, cls: 'text-green-400' }) %></div>
                    <div class="text-lg font-bold text-green-400">Authenticated!</div>
                    <div class="text-sm text-gray-400">Redirecting...</div>
                </div>
            </div>
        </div>

        <!-- Links -->
        <div class="flex justify-center gap-6 mt-6 text-sm text-gray-500">
            <a href="/throne" class="hover:text-throne-gold transition-colors flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 16, cls: '' }) %> Throne</a>
            <a href="/queue" class="hover:text-throne-gold transition-colors flex items-center gap-1"><%- include('partials/icon', { name: 'queue', size: 16, cls: '' }) %> Queue</a>
            <a href="/leaderboard" class="hover:text-throne-gold transition-colors flex items-center gap-1"><%- include('partials/icon', { name: 'trophy', size: 16, cls: '' }) %> Leaderboard</a>
        </div>
    </div>

    <script>
        let currentK1 = null;
        let pollInterval = null;
        const venueCode = '<%= venueCode %>';

        async function loadChallenge() {
            // Show loading state
            document.getElementById('qr-loading').classList.remove('hidden');
            document.getElementById('qr-code').classList.add('hidden');
            document.getElementById('qr-error').classList.add('hidden');
            document.getElementById('qr-success').classList.add('hidden');

            try {
                const res = await fetch('/api/auth/lightning');
                if (!res.ok) throw new Error('Failed to generate challenge');
                const data = await res.json();

                currentK1 = data.k1;

                // Show QR code
                document.getElementById('qr-img').src = data.qr;
                document.getElementById('ln-deeplink').href = data.deepLink;
                
                document.getElementById('qr-loading').classList.add('hidden');
                document.getElementById('qr-code').classList.remove('hidden');

                // Start polling for auth completion
                startPolling();
            } catch (err) {
                console.error('Failed to load challenge:', err);
                document.getElementById('qr-loading').classList.add('hidden');
                document.getElementById('qr-error').classList.remove('hidden');
            }
        }

        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);
            
            pollInterval = setInterval(async () => {
                if (!currentK1) return;

                try {
                    const res = await fetch(`/api/auth/status?k1=${currentK1}`);
                    const data = await res.json();

                    if (data.status === 'complete') {
                        clearInterval(pollInterval);
                        
                        // Show success
                        document.getElementById('qr-code').classList.add('hidden');
                        document.getElementById('qr-success').classList.remove('hidden');

                        // Redirect based on whether they need to set a name
                        setTimeout(() => {
                            if (data.needsName) {
                                window.location.href = '/set-name' + (venueCode ? '?code=' + venueCode : '');
                            } else {
                                window.location.href = '/player';
                            }
                        }, 800);
                    } else if (data.status === 'expired' || data.status === 'failed') {
                        clearInterval(pollInterval);
                        // Reload a new challenge
                        loadChallenge();
                    }
                } catch (err) {
                    // Network error — keep trying
                    console.error('Poll error:', err);
                }
            }, 1500); // Poll every 1.5 seconds
        }

        // Auto-refresh challenge every 4 minutes (before 5min expiry)
        setInterval(() => {
            loadChallenge();
        }, 4 * 60 * 1000);

        // Start on page load
        loadChallenge();
    </script>
<script src="/vscale.js"></script>
</body>
</html>
