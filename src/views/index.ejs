<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — King of the Hill Chess960</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="text-6xl mb-4">♚</div>
            <h1 class="text-4xl font-bold text-throne-gold mb-2">960 Throne</h1>
            <p class="text-gray-400 text-lg">King of the Hill Chess960</p>
            <p class="text-gray-500 mt-1">Prospera, Roatán</p>
        </div>

        <!-- Current King ticker -->
        <% if (state.king) { %>
        <div class="card mb-6 text-center">
            <div class="text-sm text-gray-400 mb-1">👑 Current King</div>
            <div class="text-2xl font-bold text-throne-gold"><%= state.king.name %></div>
            <div class="text-sm text-gray-400 mt-1">Earning <span class="text-throne-gold"><%= state.config.satRate %></span> sats/sec</div>
            <% if (state.queue.length > 0) { %>
            <div class="text-xs text-gray-500 mt-1"><%= state.queue.length %> challenger<%= state.queue.length === 1 ? '' : 's' %> in line</div>
            <% } %>
        </div>
        <% } %>

        <!-- How it works -->
        <div class="card mb-4">
            <h2 class="text-lg font-bold mb-3">⚡ How it works</h2>
            <div class="space-y-2 text-sm text-gray-300">
                <div class="flex gap-2"><span class="text-throne-gold">1.</span> Enter your name below to join</div>
                <div class="flex gap-2"><span class="text-throne-gold">2.</span> Get in line to challenge the King</div>
                <div class="flex gap-2"><span class="text-throne-gold">3.</span> Beat the King → become the new King</div>
                <div class="flex gap-2"><span class="text-throne-gold">4.</span> The King earns <strong class="text-throne-gold">21 sats/second</strong> while on the throne</div>
                <div class="flex gap-2"><span class="text-throne-gold">5.</span> Collect your sats via Lightning ⚡</div>
            </div>
        </div>

        <!-- Error message -->
        <% if (error) { %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm"><%= error %></div>
        <% } %>

        <!-- Register — simple form POST -->
        <div class="card">
            <% if (venueCode) { %>
            <h2 class="text-xl font-bold mb-2">⚔️ Get in Line</h2>
            <p class="text-sm text-gray-400 mb-4">Enter your name and you'll be added to the challenger queue</p>
            <% } else { %>
            <h2 class="text-xl font-bold mb-4">Enter the Arena</h2>
            <% } %>
            <form method="POST" action="/register">
                <input type="hidden" name="venueCode" value="<%= venueCode %>">
                <input type="text" name="name" class="input mb-3" placeholder="Your name" maxlength="30" required autofocus>
                <button type="submit" class="btn-gold w-full text-lg">
                    <% if (venueCode) { %>
                    ⚔️ Join the Line
                    <% } else { %>
                    ⚔️ Join
                    <% } %>
                </button>
            </form>

            <div class="border-t border-gray-700 mt-5 pt-4">
                <details class="text-sm">
                    <summary class="text-gray-500 cursor-pointer hover:text-gray-300">Already registered? Log in</summary>
                    <form method="POST" action="/login" class="mt-3">
                        <input type="hidden" name="venueCode" value="<%= venueCode %>">
                        <input type="text" name="name" class="input mb-2" placeholder="Your name">
                        <input type="text" name="pin" class="input mb-3" placeholder="4-digit PIN" maxlength="4" inputmode="numeric">
                        <button type="submit" class="btn-outline w-full">Log In</button>
                    </form>
                </details>
            </div>
        </div>

        <!-- Links -->
        <div class="flex justify-center gap-6 mt-6 text-sm text-gray-500">
            <a href="/throne" class="hover:text-throne-gold transition-colors">👑 Throne</a>
            <a href="/queue" class="hover:text-throne-gold transition-colors">📋 Queue</a>
            <a href="/leaderboard" class="hover:text-throne-gold transition-colors">🏆 Leaderboard</a>
        </div>
    </div>
</body>
</html>
