<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }</style>
</head>
<body class="min-h-screen bg-throne-darker p-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold">🔧 Admin Panel</h1>
            <div class="flex gap-3">
                <a href="/throne" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: '' }) %> Throne</a>
                <a href="/timeline" class="text-sm text-gray-400 hover:text-throne-gold">📜 Timeline</a>
                <a href="/leaderboard" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'trophy', size: 14, cls: '' }) %> Board</a>
            </div>
        </div>

        <!-- Notifications -->
        <% if (notifications.length > 0) { %>
        <div class="card border-red-700 mb-4">
            <h2 class="text-lg font-bold mb-3 text-red-400 flex items-center gap-2"><%- include('partials/icon', { name: 'warning', size: 20, cls: 'text-red-400' }) %> Notifications (<%= notifications.length %>)</h2>
            <div class="space-y-2">
                <% notifications.forEach(n => { %>
                <div class="bg-throne-darker rounded-lg p-3 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-gray-500"><%= n.type %></span>
                        <div class="text-sm"><%= n.message %></div>
                    </div>
                    <button onclick="resolveNotification(<%= n.id %>)" class="text-xs text-gray-500 hover:text-white">✓ Dismiss</button>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Game Control -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'gamepad', size: 20, cls: '' }) %> Game Control</h2>
                <% if (state.king) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg">
                    <div class="text-sm text-gray-400">Current King</div>
                    <div class="text-xl font-bold text-throne-gold flex items-center gap-2"><%- include('partials/icon', { name: 'crown', size: 22, cls: 'text-throne-gold' }) %> <%= state.king.name %></div>
                </div>
                <% } %>
                <% if (state.game) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg">
                    <div class="text-sm text-gray-400">Active Game #<%= state.game.id %></div>
                    <% const adminKc = state.game.king_color || 'white'; %>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span style="display:inline-block;background:<%= adminKc === 'white' ? '#fff' : '#1a1a1a' %>;color:<%= adminKc === 'white' ? '#1a1a1a' : '#fff' %>;padding:1px 6px;border-radius:3px;border:1px solid <%= adminKc === 'white' ? '#fff' : '#555' %>;">👑 <%= state.game.king_name %></span>
                        <span class="text-gray-500">vs</span>
                        <span style="display:inline-block;background:<%= adminKc === 'white' ? '#1a1a1a' : '#fff' %>;color:<%= adminKc === 'white' ? '#fff' : '#1a1a1a' %>;padding:1px 6px;border-radius:3px;border:1px solid <%= adminKc === 'white' ? '#555' : '#fff' %>;">⚔️ <%= state.game.challenger_name %></span>
                    </div>
                    <div class="text-xs text-gray-500">Position #<%= state.game.chess960_position %></div>
                    <div id="admin-pos-verify" class="text-xs mt-1 px-2 py-1 rounded" style="display:none;"></div>
                    <div class="text-sm text-yellow-400 mt-1">⏱️ Started <span id="admin-game-elapsed">0:00</span> ago</div>
                    <div id="admin-dgt-clock" class="flex items-center gap-3 mt-2 text-sm" style="display:none;">
                        <span class="text-gray-400">DGT Clock:</span>
                        <span class="font-mono font-bold text-white bg-gray-800 px-2 py-0.5 rounded" id="admin-clock-white">--:--</span>
                        <span class="text-gray-500">-</span>
                        <span class="font-mono font-bold text-white bg-gray-800 px-2 py-0.5 rounded" id="admin-clock-black">--:--</span>
                    </div>
                    <% if (state.game.king_reported || state.game.challenger_reported) { %>
                    <div class="text-xs text-gray-500 mt-1">
                        <% if (state.game.king_reported) { %>King reported: <span class="text-white"><%= state.game.king_reported %></span> <% } %>
                        <% if (state.game.challenger_reported) { %>Chal. reported: <span class="text-white"><%= state.game.challenger_reported %></span><% } %>
                    </div>
                    <% } %>
                    <div class="grid grid-cols-2 gap-2 mt-2">
                        <button onclick="overrideResult(<%= state.game.id %>, 'king_won')" class="text-xs bg-green-800 hover:bg-green-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: '' }) %> King Won</button>
                        <button onclick="overrideResult(<%= state.game.id %>, 'challenger_won')" class="text-xs bg-red-800 hover:bg-red-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'crossed-swords', size: 14, cls: '' }) %> Challenger Won</button>
                        <button onclick="overrideResult(<%= state.game.id %>, 'draw')" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'handshake', size: 14, cls: '' }) %> Draw (King Stays)</button>
                        <button onclick="removeChallenger()" class="text-xs bg-yellow-800 hover:bg-yellow-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'warning', size: 14, cls: '' }) %> No Show</button>
                    </div>
                </div>
                <% } else if (state.king) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg text-center">
                    <div class="text-sm text-gray-400">Waiting for next challenger...</div>
                    <% if (state.queue.length > 0) { %>
                    <div class="text-xs text-yellow-400 mt-1">Next game auto-starts when queue is processed</div>
                    <% } else { %>
                    <div class="text-xs text-gray-500 mt-1">Queue is empty — add someone to queue to start a game</div>
                    <% } %>
                </div>
                <% } else { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg text-center">
                    <div class="text-sm text-gray-500">No king — crown someone first</div>
                </div>
                <% } %>

                <!-- Undo Last Game -->
                <% if (recentGames.length > 0) { %>
                <div class="mt-3 pt-3 border-t border-gray-700">
                    <button onclick="undoGame(<%= recentGames[0].id %>)" class="w-full text-xs bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">
                        ↩️ Undo Last Game (#<%= recentGames[0].id %>: <%= recentGames[0].king_name %> vs <%= recentGames[0].challenger_name %> — <%= recentGames[0].result %>)
                    </button>
                </div>
                <% } %>

                <!-- Crown a King -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="text-sm text-gray-400 mb-2">Crown a King</div>
                    <select id="crown-select" class="input mb-2">
                        <option value="">Select player...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="crownKing()" class="btn-purple w-full text-sm flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'crown', size: 16, cls: '' }) %> Crown Selected Player</button>
                </div>

                <!-- Set Challenger -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="text-sm text-gray-400 mb-2">Set Challenger (bypass queue)</div>
                    <select id="challenger-select" class="input mb-2">
                        <option value="">Select player...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="setChallenger()" class="btn-purple w-full text-sm flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'crossed-swords', size: 16, cls: '' }) %> Set as Challenger</button>
                </div>
            </div>

            <!-- Venue Code -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'key', size: 20, cls: '' }) %> Venue Code</h2>
                <% if (venueCode) { %>
                <div class="text-center mb-4">
                    <div class="text-5xl font-mono font-bold text-throne-gold tracking-widest"><%= venueCode.code %></div>
                    <div class="text-xs text-gray-500 mt-2">
                        Expires: <%= venueCode.expires_at ? new Date(venueCode.expires_at).toLocaleTimeString() : 'never' %>
                    </div>
                    <!-- Venue QR Code -->
                    <div class="mt-3 mb-2">
                        <img id="venue-qr-img" src="/api/venue-qr.png" alt="Venue QR Code" 
                             class="mx-auto rounded-lg" style="width: 180px; height: 180px; background: #fff; padding: 8px;"
                             onerror="this.style.display='none'">
                    </div>
                    <div class="text-xs text-gray-500 mt-1">
                        <code class="text-gray-400"><%= process.env.BASE_URL || 'http://localhost:3000' %>/?code=<%= venueCode.code %></code>
                    </div>
                    <div class="flex items-center justify-center gap-2 mt-2">
                        <button onclick="enlargeQR()" class="text-xs bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded inline-flex items-center gap-1">
                            🔍 Enlarge
                        </button>
                        <button onclick="printVenueQR()" class="text-xs bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded inline-flex items-center gap-1">
                            🖨️ Print QR
                        </button>
                    </div>
                </div>
                <% } %>
                <button onclick="rotateCode()" class="btn-outline w-full text-sm">🔄 Generate New Code</button>

                <!-- Event Toggle -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="flex items-center justify-between">
                        <span>Event Active</span>
                        <button onclick="toggleEvent()" class="<%= state.eventActive ? 'btn-red' : 'btn-green' %> text-sm">
                            <%= state.eventActive ? 'Pause Event' : 'Start Event' %>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Queue Management -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> Queue (<%= state.queue.length %>)</h2>
                <% if (state.queue.length === 0) { %>
                <p class="text-gray-500 text-sm">Queue empty</p>
                <% } else { %>
                <div class="space-y-1 mb-3 max-h-48 overflow-y-auto">
                    <% state.queue.forEach(q => { %>
                    <div class="flex items-center justify-between bg-throne-darker rounded p-2">
                        <span class="text-sm <%= q.status === 'on_deck' ? 'text-throne-gold font-bold' : '' %>">
                            #<%= q.position %> <%= q.player_name %>
                            <% if (q.status === 'on_deck') { %> <%- include('partials/icon', { name: 'bell', size: 14, cls: 'text-throne-gold' }) %><% } %>
                            <% if (q.timeout_count > 0) { %> <span class="text-red-400">(⚠ timeout x<%= q.timeout_count %>)</span><% } %>
                        </span>
                        <button onclick="removeFromQueue(<%= q.player_id %>)" class="text-xs text-red-400 hover:text-red-300">Remove</button>
                    </div>
                    <% }) %>
                </div>
                <% } %>
                <div class="flex gap-2">
                    <select id="add-queue-select" class="input text-sm flex-1">
                        <option value="">Add to queue...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="addToQueue()" class="btn-purple text-sm">Add</button>
                </div>
            </div>

            <!-- Config -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'gear', size: 20, cls: '' }) %> Config</h2>
                <div class="space-y-2 text-sm">
                    <% const editableKeys = ['sat_rate_per_second','time_control_base','time_control_increment','queue_timeout_seconds','winner_only_confirm_delay','venue_code_rotation_minutes']; %>
                    <% editableKeys.forEach(key => { %>
                    <div class="flex items-center gap-2">
                        <label class="text-gray-400 flex-1 text-xs"><%= key %></label>
                        <input type="text" value="<%= config[key] || '' %>" class="input text-sm w-24 text-right py-1 px-2"
                            onchange="updateConfig('<%= key %>', this.value)">
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Accounting Audit -->
            <div class="card" id="accounting-card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'chart', size: 20, cls: '' }) %> Sat Accounting</h2>
                <p class="text-xs text-gray-500 mb-3">Verifies total sats credited = throne-occupied seconds × rate. Discrepancy should be ≤1 sat per reign transition (rounding).</p>
                <div id="accounting-data" class="text-sm space-y-1">
                    <button onclick="loadAccounting()" class="btn-outline w-full text-sm">🔍 Run Audit</button>
                </div>
            </div>

            <!-- Scheduled Reset -->
            <div class="card <%= scheduledReset ? 'border-red-700' : '' %>">
                <h2 class="text-lg font-bold mb-3">🧹 Scheduled Reset</h2>
                <p class="text-xs text-gray-500 mb-3">Schedule a full event reset — clears all stats, sats, games, and reigns. Player accounts are kept. A backup is created automatically before reset.</p>
                
                <% if (scheduledReset) { %>
                <div class="bg-red-900/30 border border-red-700 rounded-lg p-4 mb-3 text-center">
                    <div class="text-sm text-red-400 mb-1">⏰ Reset scheduled for</div>
                    <div class="text-xl font-mono text-red-300" id="reset-target-time"><%= new Date(scheduledReset.resetAt).toLocaleString() %></div>
                    <div class="text-4xl font-mono font-bold text-red-400 mt-2" id="reset-countdown">--:--:--</div>
                    <div class="text-xs text-red-500 mt-1">countdown to reset</div>
                    <button onclick="cancelReset()" class="mt-3 text-sm bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'cross', size: 14, cls: 'text-red-400' }) %> Cancel Reset</button>
                </div>
                <% } else { %>
                <div class="space-y-2">
                    <div>
                        <label class="text-xs text-gray-400">Reset date & time</label>
                        <input type="datetime-local" id="reset-datetime" class="input text-sm">
                    </div>
                    <div>
                        <label class="text-xs text-gray-400">Re-enter admin password to confirm</label>
                        <input type="password" id="reset-password" class="input text-sm" placeholder="Admin password">
                    </div>
                    <button onclick="scheduleReset()" class="w-full text-sm bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">🧹 Schedule Event Reset</button>
                </div>
                <% } %>
            </div>

            <!-- Merge Accounts -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3">🔀 Merge Accounts</h2>
                <p class="text-xs text-gray-500 mb-3">For players locked out of their wallet who created a new account. Merges source → target (source is deleted).</p>
                <div class="space-y-2">
                    <div>
                        <label class="text-xs text-gray-400">Keep this account (target)</label>
                        <select id="merge-target" class="input text-sm">
                            <option value="">Select player to KEEP...</option>
                            <% players.forEach(p => { %>
                            <option value="<%= p.id %>">#<%= p.id %> — <%= p.name || '(no name)' %> (<%= p.games_played %> games, <%= p.sat_balance %> sats)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs text-gray-400">Delete this account (source — stats merged into target)</label>
                        <select id="merge-source" class="input text-sm">
                            <option value="">Select player to DELETE...</option>
                            <% players.forEach(p => { %>
                            <option value="<%= p.id %>">#<%= p.id %> — <%= p.name || '(no name)' %> (<%= p.games_played %> games, <%= p.sat_balance %> sats)</option>
                            <% }) %>
                        </select>
                    </div>
                    <button onclick="mergeAccounts()" class="w-full text-sm bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">🔀 Merge Accounts</button>
                </div>
            </div>
        </div>

        <!-- Recent Games -->
        <div class="card mt-4">
            <h2 class="text-lg font-bold mb-3">📜 Recent Games</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="text-gray-500 border-b border-gray-700">
                        <th class="py-1 text-left">#</th><th class="py-1 text-left">King</th><th class="py-1 text-left">Challenger</th>
                        <th class="py-1 text-left">Result</th><th class="py-1 text-right">Sats</th><th class="py-1 text-right">Pos</th>
                    </tr></thead>
                    <tbody>
                    <% recentGames.forEach(g => { %>
                    <tr class="border-b border-gray-800">
                        <td class="py-1"><%= g.id %></td>
                        <td class="py-1 <%= g.result === 'king_won' ? 'text-green-400' : g.result === 'challenger_won' ? 'text-red-400' : '' %>"><%= g.king_name %></td>
                        <td class="py-1 <%= g.result === 'challenger_won' ? 'text-green-400' : g.result === 'king_won' ? 'text-red-400' : '' %>"><%= g.challenger_name %></td>
                        <td class="py-1"><%= g.result %></td>
                        <td class="py-1 text-right text-throne-gold"><%= g.sats_earned %></td>
                        <td class="py-1 text-right text-gray-500">#<%= g.chess960_position %></td>
                    </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="admin-status" class="hidden fixed bottom-4 right-4 p-3 rounded-lg text-sm max-w-xs"></div>
    </div>

    <script>
        const socket = io();
        function showStatus(msg, ok) {
            const el = document.getElementById('admin-status');
            el.textContent = msg;
            el.className = `fixed bottom-4 right-4 p-3 rounded-lg text-sm max-w-xs ${ok ? 'bg-green-900 text-green-300' : 'bg-red-900 text-red-300'}`;
            setTimeout(() => el.className = 'hidden', 3000);
        }
        async function api(url, body) {
            const res = await fetch(url, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
            const data = await res.json();
            if (!res.ok) { showStatus(data.error, false); return null; }
            showStatus('Done!', true);
            return data;
        }
        async function startGame() { if (await api('/api/admin/start-game', {})) setTimeout(() => location.reload(), 500); }
        async function crownKing() {
            const id = document.getElementById('crown-select').value;
            if (!id) return;
            if (await api('/api/admin/crown', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function overrideResult(gameId, result) {
            if (!confirm(`Override as ${result}?`)) return;
            if (await api('/api/admin/override-result', { gameId, result })) setTimeout(() => location.reload(), 500);
        }
        async function rotateCode() { if (await api('/api/admin/rotate-venue-code', {})) setTimeout(() => location.reload(), 500); }
        async function toggleEvent() {
            const active = '<%= state.eventActive %>' !== 'true';
            if (await api('/api/admin/event-active', { active })) setTimeout(() => location.reload(), 500);
        }
        async function removeFromQueue(playerId) { if (await api('/api/admin/queue/remove', { playerId })) setTimeout(() => location.reload(), 500); }
        async function addToQueue() {
            const id = document.getElementById('add-queue-select').value;
            if (!id) return;
            if (await api('/api/admin/queue/add', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function updateConfig(key, value) { await api('/api/admin/config', { key, value }); }
        async function mergeAccounts() {
            const targetId = document.getElementById('merge-target').value.trim();
            const sourceId = document.getElementById('merge-source').value.trim();
            if (!targetId || !sourceId) return alert('Both player IDs required');
            if (targetId === sourceId) return alert('Cannot merge a player with themselves');
            if (!confirm(`Merge player #${sourceId} INTO player #${targetId}? This will delete player #${sourceId} and transfer all their stats/sats to #${targetId}. This cannot be undone.`)) return;
            const result = await api('/api/admin/merge-accounts', { targetPlayerId: parseInt(targetId), sourcePlayerId: parseInt(sourceId) });
            if (result) { alert(result.message || 'Accounts merged'); setTimeout(() => location.reload(), 500); }
        }
        async function undoGame(gameId) {
            if (!confirm('Undo this game? This will reverse all stat changes and restore the previous king if needed.')) return;
            if (await api('/api/admin/undo-game', { gameId })) setTimeout(() => location.reload(), 500);
        }
        async function setChallenger() {
            const id = document.getElementById('challenger-select').value;
            if (!id) return;
            if (await api('/api/admin/set-challenger', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function removeChallenger() {
            if (!confirm('Remove challenger (no-show)? Same position will be used for the next challenger.')) return;
            if (await api('/api/admin/remove-challenger', {})) setTimeout(() => location.reload(), 500);
        }
        async function resolveNotification(id) { if (await api('/api/admin/notifications/resolve', { id })) setTimeout(() => location.reload(), 500); }

        // Enlarge QR — fullscreen overlay
        function enlargeQR() {
            const qrImg = document.getElementById('venue-qr-img');
            if (!qrImg) return;
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.9);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;cursor:pointer;';
            overlay.innerHTML = `
                <img src="${qrImg.src}" style="width:min(80vw,80vh);height:min(80vw,80vh);background:#fff;padding:16px;border-radius:12px;">
                <div style="color:#999;margin-top:16px;font-size:14px;">Tap anywhere to close</div>
            `;
            overlay.addEventListener('click', () => overlay.remove());
            document.body.appendChild(overlay);
        }

        // Print Venue QR — opens fullscreen printable view
        function printVenueQR() {
            const qrImg = document.getElementById('venue-qr-img');
            if (!qrImg) return;
            const win = window.open('', '_blank');
            win.document.write(`
                <!DOCTYPE html>
                <html>
                <head><title>960 Throne — Venue QR</title>
                <style>
                    * { margin: 0; padding: 0; box-sizing: border-box; }
                    body { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: #fff; font-family: system-ui, sans-serif; }
                    img { width: 400px; height: 400px; }
                    h1 { font-size: 3rem; margin-bottom: 20px; }
                    h2 { font-size: 1.5rem; color: #666; margin-top: 20px; }
                    p { font-size: 1.2rem; color: #999; margin-top: 10px; }
                    @media print { body { -webkit-print-color-adjust: exact; print-color-adjust: exact; } }
                </style>
                </head>
                <body>
                    <h1>♟️ 960 Throne</h1>
                    <img src="${qrImg.src}" alt="QR Code">
                    <h2>Scan to Play!</h2>
                    <p>King of the Hill Chess960</p>
                <script src="/vscale.js"></script>
</body>
                </html>
            `);
            win.document.close();
            setTimeout(() => win.print(), 500);
        }

        // Accounting Audit
        async function loadAccounting() {
            const res = await fetch('/api/admin/accounting');
            const d = await res.json();
            const el = document.getElementById('accounting-data');
            const statusColor = d.isClean ? 'text-green-400' : 'text-red-400';
            const statusIcon = d.isClean ? '✅' : '⚠️';
            el.innerHTML = `
                <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                    <span class="text-gray-400">Total player sats (credited)</span><span class="text-right font-mono">${d.totalPlayerSats.toLocaleString()}</span>
                    <span class="text-gray-400">Expected sats (time × rate)</span><span class="text-right font-mono">${d.expectedTotalSats.toLocaleString()}</span>
                    <span class="text-gray-400">Throne-occupied time</span><span class="text-right font-mono">${Math.floor(d.totalThroneSeconds / 60)}m ${d.totalThroneSeconds % 60}s</span>
                    <span class="text-gray-400">Completed reigns</span><span class="text-right font-mono">${d.completedReignCount}</span>
                    <span class="text-gray-400">Active reign sats (live)</span><span class="text-right font-mono">${d.activeReignSats.toLocaleString()}</span>
                    <span class="text-gray-400 font-bold">Discrepancy</span><span class="text-right font-mono font-bold ${statusColor}">${statusIcon} ${d.discrepancy > 0 ? '+' : ''}${d.discrepancy} sats</span>
                </div>
                <div class="text-xs text-gray-500 mt-2">${d.isClean ? 'Accounting is clean (within rounding tolerance).' : 'Discrepancy exceeds rounding tolerance — investigate!'}</div>
                <button onclick="loadAccounting()" class="btn-outline w-full text-sm mt-2">🔄 Refresh</button>
            `;
        }

        // Scheduled Reset
        async function scheduleReset() {
            const dt = document.getElementById('reset-datetime').value;
            const pw = document.getElementById('reset-password').value;
            if (!dt) return alert('Pick a date and time for the reset');
            if (!pw) return alert('Enter admin password to confirm');
            const resetAt = new Date(dt).toISOString();
            if (!confirm(`⚠️ SCHEDULE FULL RESET for ${new Date(dt).toLocaleString()}?\n\nThis will clear ALL stats, sats, games, and reigns.\nPlayer accounts will be kept.\nA backup is created automatically.`)) return;
            if (await api('/api/admin/schedule-reset', { resetAt, password: pw })) setTimeout(() => location.reload(), 500);
        }
        async function cancelReset() {
            if (!confirm('Cancel the scheduled reset?')) return;
            if (await api('/api/admin/cancel-reset', {})) setTimeout(() => location.reload(), 500);
        }

        // Countdown timer for scheduled reset
        <% if (scheduledReset) { %>
        (function() {
            const resetAt = new Date('<%= scheduledReset.resetAt %>').getTime();
            const el = document.getElementById('reset-countdown');
            function tick() {
                const diff = Math.max(0, resetAt - Date.now());
                if (diff <= 0) { el.textContent = 'RESETTING...'; location.reload(); return; }
                const h = Math.floor(diff / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                el.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
            }
            tick();
            setInterval(tick, 1000);
        })();
        <% } %>

        // Game elapsed timer
        <% if (state.game && state.game.started_at) { %>
        (function() {
            const gameStart = new Date('<%- state.game.started_at %><%- state.game.started_at.endsWith("Z") ? "" : "Z" %>').getTime();
            const el = document.getElementById('admin-game-elapsed');
            function tickGame() {
                const sec = Math.floor((Date.now() - gameStart) / 1000);
                const m = Math.floor(sec / 60);
                const s = sec % 60;
                if (el) el.textContent = m + ':' + String(s).padStart(2, '0');
            }
            tickGame();
            setInterval(tickGame, 1000);
        })();
        <% } %>

        // DGT clock + position verification
        function formatAdminClock(seconds) {
            if (seconds == null) return '--:--';
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return m + ':' + String(s).padStart(2, '0');
        }

        socket.on('dgt_board', (data) => {
            // Update clock display
            if (data.clock) {
                const clockContainer = document.getElementById('admin-dgt-clock');
                const whiteEl = document.getElementById('admin-clock-white');
                const blackEl = document.getElementById('admin-clock-black');
                if (clockContainer) clockContainer.style.display = 'flex';
                if (whiteEl) whiteEl.textContent = formatAdminClock(data.clock.white);
                if (blackEl) blackEl.textContent = formatAdminClock(data.clock.black);
            }

            // Position verification
            const el = document.getElementById('admin-pos-verify');
            if (!el) return;
            const pv = data.positionVerification;
            if (!pv) { el.style.display = 'none'; return; }
            el.style.display = 'block';
            if (pv.matches === true) {
                el.style.background = 'rgba(34,197,94,0.15)';
                el.style.color = '#22c55e';
                el.textContent = '🟢 Board matches Position #' + pv.positionNumber;
            } else if (pv.matches === false) {
                el.style.background = 'rgba(239,68,68,0.15)';
                el.style.color = '#ef4444';
                el.textContent = '🔴 Board mismatch — set up: ' + (pv.pieces ? pv.pieces.join(' ') : '');
            } else {
                el.style.background = 'rgba(234,179,8,0.15)';
                el.style.color = '#eab308';
                el.textContent = '🟡 Waiting for DGT board';
            }
        });

        socket.on('game_started', () => setTimeout(() => location.reload(), 500));
        socket.on('game_ended', () => setTimeout(() => location.reload(), 1000));
        socket.on('new_king', () => setTimeout(() => location.reload(), 1000));
        socket.on('queue_updated', () => setTimeout(() => location.reload(), 1000));
        socket.on('event_reset', () => setTimeout(() => location.reload(), 1000));
        socket.on('reset_scheduled', () => setTimeout(() => location.reload(), 1000));
        socket.on('reset_cancelled', () => setTimeout(() => location.reload(), 1000));
    </script>
<script src="/vscale.js"></script>
</body>
</html>
