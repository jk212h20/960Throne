<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }</style>
</head>
<body class="min-h-screen bg-throne-darker p-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold">🔧 Admin Panel</h1>
            <div class="flex gap-3">
                <a href="/throne" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: '' }) %> Throne</a>
                <a href="/admin/users" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'user', size: 14, cls: '' }) %> Users</a>
                <a href="/timeline" class="text-sm text-gray-400 hover:text-throne-gold">📜 Timeline</a>
                <a href="/leaderboard" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'trophy', size: 14, cls: '' }) %> Board</a>
            </div>
        </div>

        <!-- Notifications -->
        <% if (notifications.length > 0) { %>
        <div class="card border-red-700 mb-4">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-bold text-red-400 flex items-center gap-2"><%- include('partials/icon', { name: 'warning', size: 20, cls: 'text-red-400' }) %> Notifications (<%= notifications.length %>)</h2>
                <button onclick="resolveAllNotifications()" class="text-xs bg-gray-700 hover:bg-gray-600 text-gray-300 px-3 py-1 rounded">✓ Dismiss All</button>
            </div>
            <div class="space-y-2">
                <% notifications.forEach(n => { %>
                <div class="bg-throne-darker rounded-lg p-3 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-gray-500"><%= n.type %></span>
                        <div class="text-sm"><%= n.message %></div>
                    </div>
                    <button onclick="resolveNotification(<%= n.id %>)" class="text-xs text-gray-500 hover:text-white">✓ Dismiss</button>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Game Control -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'gamepad', size: 20, cls: '' }) %> Game Control</h2>
                <% if (state.king) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg">
                    <div class="text-sm text-gray-400">Current King</div>
                    <div class="text-xl font-bold text-throne-gold flex items-center gap-2"><%- include('partials/icon', { name: 'crown', size: 22, cls: 'text-throne-gold' }) %> <%= state.king.name %></div>
                </div>
                <% } %>
                <% if (state.game) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg">
                    <div class="text-sm text-gray-400">Active Game #<%= state.game.id %></div>
                    <% const adminKc = state.game.king_color || 'white'; %>
                    <div class="flex items-center gap-2 flex-wrap">
                        <span style="display:inline-block;background:<%= adminKc === 'white' ? '#fff' : '#1a1a1a' %>;color:<%= adminKc === 'white' ? '#1a1a1a' : '#fff' %>;padding:1px 6px;border-radius:3px;border:1px solid <%= adminKc === 'white' ? '#fff' : '#555' %>;">👑 <%= state.game.king_name %></span>
                        <span class="text-gray-500">vs</span>
                        <span style="display:inline-block;background:<%= adminKc === 'white' ? '#1a1a1a' : '#fff' %>;color:<%= adminKc === 'white' ? '#fff' : '#1a1a1a' %>;padding:1px 6px;border-radius:3px;border:1px solid <%= adminKc === 'white' ? '#555' : '#fff' %>;">⚔️ <%= state.game.challenger_name %></span>
                    </div>
                    <div class="text-xs text-gray-500">Position #<%= state.game.chess960_position %></div>
                    <div id="admin-pos-verify" class="text-xs mt-1 px-2 py-1 rounded" style="display:none;"></div>
                    <button id="skip-setup-btn" onclick="skipBoardSetup()" class="w-full text-xs bg-yellow-700 hover:bg-yellow-600 text-white px-3 py-2 rounded mt-1 flex items-center justify-center gap-1" style="display:none;">
                        <%- include('partials/icon', { name: 'skip', size: 14, cls: '' }) %> Skip Board Setup
                    </button>
                    <div class="text-sm text-yellow-400 mt-1">⏱️ Started <span id="admin-game-elapsed">0:00</span> ago</div>
                    <div id="admin-dgt-clock" class="flex items-center gap-3 mt-2 text-sm" style="display:none;">
                        <span class="text-gray-400">DGT Clock:</span>
                        <span class="font-mono font-bold text-white bg-gray-800 px-2 py-0.5 rounded" id="admin-clock-white">--:--</span>
                        <span class="text-gray-500">-</span>
                        <span class="font-mono font-bold text-white bg-gray-800 px-2 py-0.5 rounded" id="admin-clock-black">--:--</span>
                    </div>
                    <% if (state.game.king_reported || state.game.challenger_reported) { %>
                    <div class="text-xs text-gray-500 mt-1">
                        <% if (state.game.king_reported) { %>King reported: <span class="text-white"><%= state.game.king_reported %></span> <% } %>
                        <% if (state.game.challenger_reported) { %>Chal. reported: <span class="text-white"><%= state.game.challenger_reported %></span><% } %>
                    </div>
                    <% } %>
                    <div class="grid grid-cols-2 gap-2 mt-2">
                        <button onclick="overrideResult(<%= state.game.id %>, 'king_won')" class="text-xs bg-green-800 hover:bg-green-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: '' }) %> King Won</button>
                        <button onclick="overrideResult(<%= state.game.id %>, 'challenger_won')" class="text-xs bg-red-800 hover:bg-red-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'crossed-swords', size: 14, cls: '' }) %> Challenger Won</button>
                        <button onclick="overrideResult(<%= state.game.id %>, 'draw')" class="text-xs bg-gray-700 hover:bg-gray-600 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'handshake', size: 14, cls: '' }) %> Draw (King Stays)</button>
                        <button onclick="removeChallenger()" class="text-xs bg-yellow-800 hover:bg-yellow-700 px-2 py-2 rounded flex items-center gap-1"><%- include('partials/icon', { name: 'warning', size: 14, cls: '' }) %> No Show</button>
                    </div>
                </div>
                <% } else if (state.king) { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg text-center">
                    <div class="text-sm text-gray-400">Waiting for next challenger...</div>
                    <% if (state.queue.length > 0) { %>
                    <div class="text-xs text-yellow-400 mt-1">Next game auto-starts when queue is processed</div>
                    <% } else { %>
                    <div class="text-xs text-gray-500 mt-1">Queue is empty — add someone to queue to start a game</div>
                    <% } %>
                </div>
                <% } else { %>
                <div class="mb-3 p-3 bg-throne-darker rounded-lg text-center">
                    <div class="text-sm text-gray-500">No king — crown someone first</div>
                </div>
                <% } %>

                <!-- Undo Last Game -->
                <% if (recentGames.length > 0) { %>
                <div class="mt-3 pt-3 border-t border-gray-700">
                    <button onclick="undoGame(<%= recentGames[0].id %>)" class="w-full text-xs bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">
                        ↩️ Undo Last Game (#<%= recentGames[0].id %>: <%= recentGames[0].king_name %> vs <%= recentGames[0].challenger_name %> — <%= recentGames[0].result %>)
                    </button>
                </div>
                <% } %>

                <!-- Crown a King -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="text-sm text-gray-400 mb-2">Crown a King</div>
                    <select id="crown-select" class="input mb-2">
                        <option value="">Select player...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="crownKing()" class="btn-purple w-full text-sm flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'crown', size: 16, cls: '' }) %> Crown Selected Player</button>
                </div>

                <!-- Set Challenger -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="text-sm text-gray-400 mb-2">Set Challenger (bypass queue)</div>
                    <select id="challenger-select" class="input mb-2">
                        <option value="">Select player...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="setChallenger()" class="btn-purple w-full text-sm flex items-center justify-center gap-2"><%- include('partials/icon', { name: 'crossed-swords', size: 16, cls: '' }) %> Set as Challenger</button>
                </div>
            </div>

            <!-- Venue Code -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'key', size: 20, cls: '' }) %> Venue Code</h2>
                <% if (venueCode) { %>
                <div class="text-center mb-4">
                    <div class="text-5xl font-mono font-bold text-throne-gold tracking-widest"><%= venueCode.code %></div>
                    <div class="text-xs text-gray-500 mt-2">
                        Expires: <%= venueCode.expires_at ? new Date(venueCode.expires_at).toLocaleTimeString() : 'never' %>
                    </div>
                    <!-- Venue QR Code -->
                    <div class="mt-3 mb-2">
                        <img id="venue-qr-img" src="/api/venue-qr.png" alt="Venue QR Code" 
                             class="mx-auto rounded-lg" style="width: 180px; height: 180px; background: #fff; padding: 8px;"
                             onerror="this.style.display='none'">
                    </div>
                    <div class="text-xs text-gray-500 mt-1">
                        <code class="text-gray-400"><%= process.env.BASE_URL || 'http://localhost:3000' %>/?code=<%= venueCode.code %></code>
                    </div>
                    <div class="flex items-center justify-center gap-2 mt-2">
                        <button onclick="enlargeQR()" class="text-xs bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded inline-flex items-center gap-1">
                            🔍 Enlarge
                        </button>
                        <button onclick="printVenueQR()" class="text-xs bg-gray-700 hover:bg-gray-600 text-white px-4 py-2 rounded inline-flex items-center gap-1">
                            🖨️ Print QR
                        </button>
                    </div>
                </div>
                <% } %>
                <button onclick="rotateCode()" class="btn-outline w-full text-sm">🔄 Generate New Code</button>

                <!-- Show Venue Code Toggle (shows code text on throne + code entry on player page) -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="flex items-center justify-between">
                        <div>
                            <span>Show Code on Screen</span>
                            <div class="text-xs text-gray-500 mt-0.5">Shows venue code text on throne &amp; enables manual code entry for players</div>
                        </div>
                        <button onclick="toggleVenueCode()" id="venue-code-toggle" class="<%= showVenueCode ? 'btn-red' : 'btn-green' %> text-sm">
                            <%= showVenueCode ? 'Hide Code' : 'Show Code' %>
                        </button>
                    </div>
                </div>

                <!-- Event Toggle -->
                <div class="mt-4 pt-4 border-t border-gray-700">
                    <div class="flex items-center justify-between">
                        <span>Event Active</span>
                        <button onclick="toggleEvent()" class="<%= state.eventActive ? 'btn-red' : 'btn-green' %> text-sm">
                            <%= state.eventActive ? 'Pause Event' : 'Start Event' %>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Queue Management -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> Queue (<%= state.queue.length %>)</h2>
                <% if (state.queue.length === 0) { %>
                <p class="text-gray-500 text-sm">Queue empty</p>
                <% } else { %>
                <div class="space-y-1 mb-3 max-h-48 overflow-y-auto">
                    <% state.queue.forEach(q => { %>
                    <div class="flex items-center justify-between bg-throne-darker rounded p-2">
                        <span class="text-sm <%= q.status === 'on_deck' ? 'text-throne-gold font-bold' : '' %>">
                            #<%= q.position %> <%= q.player_name %>
                            <% if (q.status === 'on_deck') { %> <%- include('partials/icon', { name: 'bell', size: 14, cls: 'text-throne-gold' }) %><% } %>
                            <% if (q.timeout_count > 0) { %> <span class="text-red-400">(⚠ timeout x<%= q.timeout_count %>)</span><% } %>
                        </span>
                        <button onclick="removeFromQueue(<%= q.player_id %>)" class="text-xs text-red-400 hover:text-red-300">Remove</button>
                    </div>
                    <% }) %>
                </div>
                <% } %>
                <div class="flex gap-2">
                    <select id="add-queue-select" class="input text-sm flex-1">
                        <option value="">Add to queue...</option>
                        <% players.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                        <% }) %>
                    </select>
                    <button onclick="addToQueue()" class="btn-purple text-sm">Add (end)</button>
                </div>
                <div class="flex gap-2 mt-2">
                    <input type="number" id="insert-queue-pos" class="input text-sm w-16 text-center" placeholder="#" min="1" value="1">
                    <button onclick="insertIntoQueue()" class="btn-purple text-sm flex-1">Insert at Position</button>
                </div>

                <!-- Reorder Button -->
                <% if (state.king || state.queue.length > 0) { %>
                <div class="mt-3 pt-3 border-t border-gray-700">
                    <button onclick="openReorderModal()" class="btn-outline w-full text-sm flex items-center justify-center gap-2">
                        ↕️ Reorder King + Queue
                    </button>
                </div>
                <% } %>
            </div>

            <!-- Config -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'gear', size: 20, cls: '' }) %> Config</h2>
                <div class="space-y-2 text-sm">
                    <% const editableKeys = ['sat_rate_per_second','time_control_base','time_control_increment','queue_timeout_seconds','winner_only_confirm_delay','venue_code_rotation_minutes']; %>
                    <% editableKeys.forEach(key => { %>
                    <div class="flex items-center gap-2">
                        <label class="text-gray-400 flex-1 text-xs"><%= key %></label>
                        <input type="text" value="<%= config[key] || '' %>" class="input text-sm w-24 text-right py-1 px-2"
                            onchange="updateConfig('<%= key %>', this.value)">
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Lightning Node -->
            <div class="card" id="lightning-card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 20, cls: 'text-throne-gold' }) %> Lightning Node</h2>
                <div id="ln-status" class="text-sm space-y-1">
                    <button onclick="loadLightningStatus()" class="btn-outline w-full text-sm">⚡ Load Node Status</button>
                </div>
                <div id="ln-topup" class="mt-3 pt-3 border-t border-gray-700" style="display:none;">
                    <div class="text-sm text-gray-400 mb-2">Top Up Node</div>
                    <div class="flex gap-2 mb-2">
                        <button onclick="showInvoiceForm()" class="flex-1 text-xs bg-purple-800 hover:bg-purple-700 px-2 py-2 rounded">⚡ Receive via Lightning</button>
                        <button onclick="getDepositAddress()" class="flex-1 text-xs bg-orange-800 hover:bg-orange-700 px-2 py-2 rounded">₿ On-chain Address</button>
                    </div>
                    <div class="text-xs text-gray-500 mb-1">⚡ Lightning goes to channel balance (for payouts). ₿ On-chain goes to wallet (for opening channels).</div>
                    <div id="ln-deposit" class="hidden mt-2 p-3 bg-throne-darker rounded-lg text-center">
                        <div class="text-xs text-gray-400 mb-1" id="ln-deposit-label"></div>
                        <div class="font-mono text-xs text-throne-gold break-all select-all" id="ln-deposit-value"></div>
                        <img id="ln-deposit-qr" class="mx-auto mt-2 rounded" style="max-width:200px;display:none;" />
                    </div>
                    <div id="ln-invoice-form" class="hidden mt-2">
                        <div class="flex gap-2">
                            <input type="number" id="ln-invoice-amount" class="input text-sm flex-1" placeholder="Amount (sats)">
                            <button onclick="createLnInvoice()" class="btn-purple text-sm">Create</button>
                        </div>
                    </div>
                </div>
                <!-- Channel Management -->
                <div id="ln-channels" class="mt-3 pt-3 border-t border-gray-700" style="display:none;">
                    <div class="flex items-center justify-between mb-2">
                        <div class="text-sm text-gray-400">Channels</div>
                        <button onclick="loadChannels()" class="text-xs text-gray-500 hover:text-white">🔄</button>
                    </div>
                    <div id="ln-channel-list" class="space-y-1 text-xs max-h-32 overflow-y-auto"></div>
                    <div class="mt-2 pt-2 border-t border-gray-800">
                        <div class="text-xs text-gray-500 mb-1">Open Channel (on-chain → Lightning)</div>
                        <input type="text" id="ln-channel-peer" class="input text-xs mb-1" placeholder="pubkey@host:port">
                        <div class="flex gap-2">
                            <input type="number" id="ln-channel-amount" class="input text-xs flex-1" placeholder="Amount (sats)">
                            <button onclick="openChannel()" class="text-xs bg-green-800 hover:bg-green-700 px-3 py-1 rounded">Open</button>
                        </div>
                        <div class="text-xs text-gray-600 mt-1">Uses on-chain balance. Min 20k sats. ~30 min to confirm.</div>
                    </div>
                </div>
            </div>

            <!-- Accounting Audit -->
            <div class="card" id="accounting-card">
                <h2 class="text-lg font-bold mb-3 flex items-center gap-2"><%- include('partials/icon', { name: 'chart', size: 20, cls: '' }) %> Sat Accounting</h2>
                <p class="text-xs text-gray-500 mb-3">Verifies total sats credited to players matches sum of per-reign sats. Discrepancy should be 0.</p>
                <div id="accounting-data" class="text-sm space-y-1">
                    <button onclick="loadAccounting()" class="btn-outline w-full text-sm">🔍 Run Audit</button>
                </div>
            </div>

            <!-- Immediate Reset -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3">⚡ Reset Event Now</h2>
                <p class="text-xs text-gray-500 mb-3">Immediately reset all event data — stats, sats, games, and reigns. Player accounts are kept. A backup is created automatically.</p>
                <div class="space-y-2">
                    <div>
                        <label class="text-xs text-gray-400">Enter admin password to confirm</label>
                        <input type="password" id="immediate-reset-password" class="input text-sm" placeholder="Admin password">
                    </div>
                    <button onclick="immediateReset()" class="w-full text-sm bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">⚡ Reset Event Now</button>
                </div>
            </div>

            <!-- Merge Accounts -->
            <div class="card">
                <h2 class="text-lg font-bold mb-3">🔀 Merge Accounts</h2>
                <p class="text-xs text-gray-500 mb-3">For players locked out of their wallet who created a new account. Merges source → target (source is deleted).</p>
                <div class="space-y-2">
                    <div>
                        <label class="text-xs text-gray-400">Keep this account (target)</label>
                        <select id="merge-target" class="input text-sm">
                            <option value="">Select player to KEEP...</option>
                            <% players.forEach(p => { %>
                            <option value="<%= p.id %>">#<%= p.id %> — <%= p.name || '(no name)' %> (<%= p.games_played %> games, <%= p.sat_balance %> sats)</option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="text-xs text-gray-400">Delete this account (source — stats merged into target)</label>
                        <select id="merge-source" class="input text-sm">
                            <option value="">Select player to DELETE...</option>
                            <% players.forEach(p => { %>
                            <option value="<%= p.id %>">#<%= p.id %> — <%= p.name || '(no name)' %> (<%= p.games_played %> games, <%= p.sat_balance %> sats)</option>
                            <% }) %>
                        </select>
                    </div>
                    <button onclick="mergeAccounts()" class="w-full text-sm bg-red-900 hover:bg-red-800 text-red-300 px-3 py-2 rounded">🔀 Merge Accounts</button>
                </div>
            </div>
        </div>

        <!-- Recent Games -->
        <div class="card mt-4">
            <h2 class="text-lg font-bold mb-3">📜 Recent Games</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="text-gray-500 border-b border-gray-700">
                        <th class="py-1 text-left">#</th><th class="py-1 text-left">King</th><th class="py-1 text-left">Challenger</th>
                        <th class="py-1 text-left">Result</th><th class="py-1 text-right">Sats</th><th class="py-1 text-right">Pos</th>
                    </tr></thead>
                    <tbody>
                    <% recentGames.forEach(g => { %>
                    <tr class="border-b border-gray-800">
                        <td class="py-1"><%= g.id %></td>
                        <td class="py-1 <%= g.result === 'king_won' ? 'text-green-400' : g.result === 'challenger_won' ? 'text-red-400' : '' %>"><%= g.king_name %></td>
                        <td class="py-1 <%= g.result === 'challenger_won' ? 'text-green-400' : g.result === 'king_won' ? 'text-red-400' : '' %>"><%= g.challenger_name %></td>
                        <td class="py-1"><%= g.result %></td>
                        <td class="py-1 text-right text-throne-gold"><%= g.sats_earned %></td>
                        <td class="py-1 text-right text-gray-500">#<%= g.chess960_position %></td>
                    </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Payout History -->
        <div class="card mt-4">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-bold flex items-center gap-2"><%- include('partials/icon', { name: 'lightning', size: 20, cls: 'text-throne-gold' }) %> Payout History (<%= payouts.length %>)</h2>
                <button onclick="reconcilePayouts()" class="bg-yellow-600 hover:bg-yellow-500 text-black text-xs font-bold px-3 py-1 rounded">🔧 Reconcile All Payouts</button>
            </div>
            <% if (payouts.length === 0) { %>
            <p class="text-gray-500 text-sm">No payouts yet</p>
            <% } else { %>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead><tr class="text-gray-500 border-b border-gray-700">
                        <th class="py-1 text-left">Player</th>
                        <th class="py-1 text-right">Sats</th>
                        <th class="py-1 text-left">Status</th>
                        <th class="py-1 text-left">Address</th>
                        <th class="py-1 text-right">When</th>
                    </tr></thead>
                    <tbody>
                    <% payouts.forEach(p => { %>
                    <tr class="border-b border-gray-800">
                        <td class="py-1"><%= p.player_name %></td>
                        <td class="py-1 text-right text-throne-gold font-mono"><%= p.amount_sats.toLocaleString() %></td>
                        <td class="py-1">
                            <% if (p.status === 'completed') { %>
                            <span class="text-green-400">✓ paid</span>
                            <% } else if (p.status === 'reversed') { %>
                            <span class="text-orange-400" title="<%= p.error_message || '' %>">🔄 reversed</span>
                            <% } else if (p.status === 'failed') { %>
                            <span class="text-red-400">✗ failed</span>
                            <% } else { %>
                            <span class="text-yellow-400">⏳ <%= p.status %></span>
                            <% } %>
                        </td>
                        <td class="py-1 text-xs text-gray-500 max-w-[120px] truncate" title="<%= p.lightning_address || '' %>"><%= p.lightning_address || 'LNURL-withdraw' %></td>
                        <td class="py-1 text-right text-xs text-gray-500"><%= p.created_at ? new Date(p.created_at + 'Z').toLocaleString() : '' %></td>
                    </tr>
                    <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>

        <div id="admin-status" class="hidden fixed bottom-4 right-4 p-3 rounded-lg text-sm max-w-xs"></div>
    </div>

    <script>
        const socket = io();
        function showStatus(msg, ok) {
            const el = document.getElementById('admin-status');
            el.textContent = msg;
            el.className = `fixed bottom-4 right-4 p-3 rounded-lg text-sm max-w-xs ${ok ? 'bg-green-900 text-green-300' : 'bg-red-900 text-red-300'}`;
            setTimeout(() => el.className = 'hidden', 3000);
        }
        async function api(url, body) {
            const res = await fetch(url, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
            const data = await res.json();
            if (!res.ok) { showStatus(data.error, false); return null; }
            showStatus('Done!', true);
            return data;
        }
        async function startGame() { if (await api('/api/admin/start-game', {})) setTimeout(() => location.reload(), 500); }
        async function crownKing() {
            const id = document.getElementById('crown-select').value;
            if (!id) return;
            if (await api('/api/admin/crown', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function overrideResult(gameId, result) {
            if (!confirm(`Override as ${result}?`)) return;
            if (await api('/api/admin/override-result', { gameId, result })) setTimeout(() => location.reload(), 500);
        }
        async function rotateCode() { if (await api('/api/admin/rotate-venue-code', {})) setTimeout(() => location.reload(), 500); }
        async function toggleVenueCode() {
            const result = await api('/api/admin/toggle-venue-code', {});
            if (result) {
                const btn = document.getElementById('venue-code-toggle');
                if (btn) {
                    btn.textContent = result.showCode ? 'Hide Code' : 'Show Code';
                    btn.className = (result.showCode ? 'btn-red' : 'btn-green') + ' text-sm';
                }
            }
        }
        async function toggleEvent() {
            const active = '<%= state.eventActive %>' !== 'true';
            if (await api('/api/admin/event-active', { active })) setTimeout(() => location.reload(), 500);
        }
        async function removeFromQueue(playerId) { if (await api('/api/admin/queue/remove', { playerId })) setTimeout(() => location.reload(), 500); }
        async function addToQueue() {
            const id = document.getElementById('add-queue-select').value;
            if (!id) return;
            if (await api('/api/admin/queue/add', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function insertIntoQueue() {
            const id = document.getElementById('add-queue-select').value;
            const pos = parseInt(document.getElementById('insert-queue-pos').value);
            if (!id) return alert('Select a player first');
            if (!pos || pos < 1) return alert('Enter a valid position (1+)');
            if (await api('/api/admin/queue/insert', { playerId: parseInt(id), position: pos })) setTimeout(() => location.reload(), 500);
        }
        async function updateConfig(key, value) { await api('/api/admin/config', { key, value }); }
        async function mergeAccounts() {
            const targetId = document.getElementById('merge-target').value.trim();
            const sourceId = document.getElementById('merge-source').value.trim();
            if (!targetId || !sourceId) return alert('Both player IDs required');
            if (targetId === sourceId) return alert('Cannot merge a player with themselves');
            if (!confirm(`Merge player #${sourceId} INTO player #${targetId}? This will delete player #${sourceId} and transfer all their stats/sats to #${targetId}. This cannot be undone.`)) return;
            const result = await api('/api/admin/merge-accounts', { targetPlayerId: parseInt(targetId), sourcePlayerId: parseInt(sourceId) });
            if (result) { alert(result.message || 'Accounts merged'); setTimeout(() => location.reload(), 500); }
        }
        async function undoGame(gameId) {
            if (!confirm('Undo this game? This will reverse all stat changes and restore the previous king if needed.')) return;
            if (await api('/api/admin/undo-game', { gameId })) setTimeout(() => location.reload(), 500);
        }
        async function setChallenger() {
            const id = document.getElementById('challenger-select').value;
            if (!id) return;
            if (await api('/api/admin/set-challenger', { playerId: parseInt(id) })) setTimeout(() => location.reload(), 500);
        }
        async function removeChallenger() {
            if (!confirm('Remove challenger (no-show)? Same position will be used for the next challenger.')) return;
            if (await api('/api/admin/remove-challenger', {})) setTimeout(() => location.reload(), 500);
        }
        async function skipBoardSetup() {
            if (await api('/api/admin/skip-setup', {})) {
                const btn = document.getElementById('skip-setup-btn');
                if (btn) btn.style.display = 'none';
            }
        }
        async function resolveNotification(id) { if (await api('/api/admin/notifications/resolve', { id })) setTimeout(() => location.reload(), 500); }
        async function resolveAllNotifications() { if (await api('/api/admin/notifications/resolve-all', {})) setTimeout(() => location.reload(), 500); }

        async function reconcilePayouts() {
            if (!confirm('Reconcile ALL payouts against LND?\n\nThis will:\n• Check pending payouts for LND matches\n• Deep-verify ALL "completed" payouts against LND\n• REVERSE any that LND says actually FAILED\n• Restore balances for affected players')) return;
            const result = await api('/api/admin/reconcile-payouts', {});
            if (result) {
                let msg = result.message + '\n\n';
                if (result.details && result.details.length > 0) {
                    msg += 'Details:\n' + result.details.join('\n');
                }
                alert(msg);
                setTimeout(() => location.reload(), 500);
            }
        }

        // Lightning Node Status
        async function loadLightningStatus() {
            const el = document.getElementById('ln-status');
            el.innerHTML = '<div class="text-gray-400">Loading...</div>';
            try {
                const res = await fetch('/api/admin/lightning-status');
                const d = await res.json();
                if (!d.configured) {
                    el.innerHTML = `<div class="text-red-400">❌ Not configured: ${d.reason}</div>`;
                    return;
                }
                const chanLocal = parseInt(d.channelBalance?.local_balance?.sat || d.channelBalance?.balance || '0');
                const chanRemote = parseInt(d.channelBalance?.remote_balance?.sat || '0');
                const onchain = parseInt(d.walletBalance?.confirmed_balance || d.walletBalance?.total_balance || '0');
                el.innerHTML = `
                    <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                        <span class="text-gray-400">Node</span><span class="text-right">${d.alias || '—'}</span>
                        <span class="text-gray-400">Synced</span><span class="text-right">${d.synced ? '✅ Yes' : '❌ No'}</span>
                        <span class="text-gray-400">⚡ Channel (send)</span><span class="text-right font-mono text-throne-gold">${chanLocal.toLocaleString()} sats</span>
                        <span class="text-gray-400">⚡ Channel (receive)</span><span class="text-right font-mono">${chanRemote.toLocaleString()} sats</span>
                        <span class="text-gray-400">₿ On-chain</span><span class="text-right font-mono">${onchain.toLocaleString()} sats</span>
                    </div>
                    <button onclick="loadLightningStatus()" class="btn-outline w-full text-sm mt-2">🔄 Refresh</button>
                `;
                document.getElementById('ln-topup').style.display = 'block';
                document.getElementById('ln-channels').style.display = 'block';
                loadChannels();
            } catch (err) {
                el.innerHTML = `<div class="text-red-400">Error: ${err.message}</div>`;
            }
        }

        async function getDepositAddress() {
            const depositEl = document.getElementById('ln-deposit');
            const invoiceFormEl = document.getElementById('ln-invoice-form');
            invoiceFormEl.classList.add('hidden');
            depositEl.classList.remove('hidden');
            document.getElementById('ln-deposit-label').textContent = 'Loading...';
            document.getElementById('ln-deposit-value').textContent = '';
            document.getElementById('ln-deposit-qr').style.display = 'none';
            try {
                const res = await fetch('/api/admin/lightning-address');
                const d = await res.json();
                if (d.error) throw new Error(d.error);
                document.getElementById('ln-deposit-label').textContent = 'Bitcoin deposit address (on-chain):';
                document.getElementById('ln-deposit-value').textContent = d.address;
                if (d.qr) { const qrImg = document.getElementById('ln-deposit-qr'); qrImg.src = d.qr; qrImg.style.display = 'block'; }
            } catch (err) {
                document.getElementById('ln-deposit-label').textContent = 'Error: ' + err.message;
            }
        }

        function showInvoiceForm() {
            document.getElementById('ln-deposit').classList.add('hidden');
            document.getElementById('ln-invoice-form').classList.remove('hidden');
        }

        async function createLnInvoice() {
            const amount = document.getElementById('ln-invoice-amount').value;
            if (!amount || parseInt(amount) <= 0) return alert('Enter amount in sats');
            const depositEl = document.getElementById('ln-deposit');
            const invoiceFormEl = document.getElementById('ln-invoice-form');
            invoiceFormEl.classList.add('hidden');
            depositEl.classList.remove('hidden');
            document.getElementById('ln-deposit-label').textContent = 'Creating invoice...';
            document.getElementById('ln-deposit-value').textContent = '';
            document.getElementById('ln-deposit-qr').style.display = 'none';
            try {
                const res = await fetch('/api/admin/lightning-invoice', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({ amount: parseInt(amount) })
                });
                const d = await res.json();
                if (d.error) throw new Error(d.error);
                document.getElementById('ln-deposit-label').textContent = `Lightning invoice for ${parseInt(amount).toLocaleString()} sats:`;
                document.getElementById('ln-deposit-value').textContent = d.paymentRequest;
                if (d.qr) { const qrImg = document.getElementById('ln-deposit-qr'); qrImg.src = d.qr; qrImg.style.display = 'block'; }
            } catch (err) {
                document.getElementById('ln-deposit-label').textContent = 'Error: ' + err.message;
            }
        }

        // Channel Management
        async function loadChannels() {
            const el = document.getElementById('ln-channel-list');
            el.innerHTML = '<div class="text-gray-500">Loading...</div>';
            try {
                const res = await fetch('/api/admin/channels');
                const d = await res.json();
                if (d.error) throw new Error(d.error);
                const channels = d.channels || [];
                const pendingOpen = d.pending?.pending_open_channels || [];
                if (channels.length === 0 && pendingOpen.length === 0) {
                    el.innerHTML = '<div class="text-gray-500">No channels. Open one to move on-chain sats to Lightning.</div>';
                } else {
                    let html = '';
                    channels.forEach(ch => {
                        const local = parseInt(ch.local_balance || '0');
                        const remote = parseInt(ch.remote_balance || '0');
                        const cap = parseInt(ch.capacity || '0');
                        const alias = ch.peer_alias || ch.remote_pubkey?.substring(0, 12) + '...';
                        const active = ch.active ? '🟢' : '🔴';
                        html += `<div class="bg-throne-darker rounded p-1.5">${active} <span class="text-gray-300">${alias}</span> — <span class="text-throne-gold">${local.toLocaleString()}</span>/<span class="text-gray-500">${cap.toLocaleString()}</span> sats</div>`;
                    });
                    pendingOpen.forEach(ch => {
                        const cap = parseInt(ch.channel?.capacity || '0');
                        html += `<div class="bg-throne-darker rounded p-1.5">⏳ Opening... ${cap.toLocaleString()} sats (waiting for confirmations)</div>`;
                    });
                    el.innerHTML = html;
                }
            } catch (err) {
                el.innerHTML = `<div class="text-red-400">${err.message}</div>`;
            }
        }

        async function openChannel() {
            const peer = document.getElementById('ln-channel-peer').value.trim();
            const amount = document.getElementById('ln-channel-amount').value;
            if (!peer) return alert('Enter peer address (pubkey@host:port)');
            if (!amount || parseInt(amount) < 20000) return alert('Minimum channel size is 20,000 sats');
            if (!confirm(`Open a ${parseInt(amount).toLocaleString()} sat channel to ${peer.substring(0, 20)}...?\nThis uses your on-chain balance and takes ~30 min to confirm.`)) return;
            const result = await api('/api/admin/open-channel', { peer, amount: parseInt(amount) });
            if (result) {
                alert(result.message);
                loadChannels();
                loadLightningStatus();
            }
        }

        // Enlarge QR — fullscreen overlay
        function enlargeQR() {
            const qrImg = document.getElementById('venue-qr-img');
            if (!qrImg) return;
            const overlay = document.createElement('div');
            overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.9);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;cursor:pointer;';
            overlay.innerHTML = `
                <img src="${qrImg.src}" style="width:min(80vw,80vh);height:min(80vw,80vh);background:#fff;padding:16px;border-radius:12px;">
                <div style="color:#999;margin-top:16px;font-size:14px;">Tap anywhere to close</div>
            `;
            overlay.addEventListener('click', () => overlay.remove());
            document.body.appendChild(overlay);
        }

        // Print Venue QR — opens fullscreen printable view
        function printVenueQR() {
            const qrImg = document.getElementById('venue-qr-img');
            if (!qrImg) return;
            const win = window.open('', '_blank');
            win.document.write(`
                <!DOCTYPE html>
                <html>
                <head><title>960 Throne — Venue QR</title>
                <style>
                    * { margin: 0; padding: 0; box-sizing: border-box; }
                    body { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; background: #fff; font-family: system-ui, sans-serif; }
                    img { width: 400px; height: 400px; }
                    h1 { font-size: 3rem; margin-bottom: 20px; }
                    h2 { font-size: 1.5rem; color: #666; margin-top: 20px; }
                    p { font-size: 1.2rem; color: #999; margin-top: 10px; }
                    @media print { body { -webkit-print-color-adjust: exact; print-color-adjust: exact; } }
                </style>
                </head>
                <body>
                    <h1>♟️ 960 Throne</h1>
                    <img src="${qrImg.src}" alt="QR Code">
                    <h2>Scan to Play!</h2>
                    <p>King of the Hill Chess960</p>
                <scr` + `ipt src="/vscale.js"></scr` + `ipt>
</body>
                </html>
            `);
            win.document.close();
            setTimeout(() => win.print(), 500);
        }

        // Accounting Audit
        async function loadAccounting() {
            const res = await fetch('/api/admin/accounting');
            const d = await res.json();
            const el = document.getElementById('accounting-data');
            const statusColor = d.isClean ? 'text-green-400' : 'text-red-400';
            const statusIcon = d.isClean ? '✅' : '⚠️';
            el.innerHTML = `
                <div class="grid grid-cols-2 gap-x-4 gap-y-1">
                    <span class="text-gray-400">Total player sats (credited)</span><span class="text-right font-mono">${d.totalPlayerSats.toLocaleString()}</span>
                    <span class="text-gray-400">Total sats paid out</span><span class="text-right font-mono text-green-400">${d.totalSatsClaimed.toLocaleString()} ✓</span>
                    <span class="text-gray-400">Expected sats (reign totals)</span><span class="text-right font-mono">${d.expectedTotalSats.toLocaleString()}</span>
                    <span class="text-gray-400">Throne-occupied time</span><span class="text-right font-mono">${Math.floor(d.totalThroneSeconds / 60)}m ${d.totalThroneSeconds % 60}s</span>
                    <span class="text-gray-400">Completed reigns</span><span class="text-right font-mono">${d.completedReignCount}</span>
                    <span class="text-gray-400">Active reign sats (live)</span><span class="text-right font-mono">${d.activeReignSats.toLocaleString()}</span>
                    <span class="text-gray-400 font-bold">Discrepancy</span><span class="text-right font-mono font-bold ${statusColor}">${statusIcon} ${d.discrepancy > 0 ? '+' : ''}${d.discrepancy} sats</span>
                </div>
                <div class="text-xs text-gray-500 mt-2">${d.isClean ? 'Accounting is clean (within rounding tolerance).' : 'Discrepancy exceeds rounding tolerance — investigate!'}</div>
                <button onclick="loadAccounting()" class="btn-outline w-full text-sm mt-2">🔄 Refresh</button>
            `;
        }

        // Immediate Reset
        async function immediateReset() {
            const pw = document.getElementById('immediate-reset-password').value;
            if (!pw) return alert('Enter admin password to confirm');
            if (!confirm('⚠️ RESET ALL EVENT DATA NOW?\n\nThis will immediately clear ALL stats, sats, games, and reigns.\nPlayer accounts will be kept.\nA backup is created automatically.')) return;
            if (await api('/api/admin/immediate-reset', { password: pw })) {
                alert('Event data has been reset!');
                setTimeout(() => location.reload(), 500);
            }
        }

        // Change Admin Password
        async function changePassword() {
            const current = document.getElementById('current-password').value;
            const newPw = document.getElementById('new-password').value;
            const confirm = document.getElementById('confirm-password').value;
            if (!current || !newPw || !confirm) return alert('All fields are required');
            if (newPw !== confirm) return alert('New passwords do not match');
            if (newPw.length < 4) return alert('New password must be at least 4 characters');
            const result = await api('/api/admin/change-password', { currentPassword: current, newPassword: newPw });
            if (result) {
                alert('Password changed successfully!');
                document.getElementById('current-password').value = '';
                document.getElementById('new-password').value = '';
                document.getElementById('confirm-password').value = '';
            }
        }

        // Scheduled Reset
        async function scheduleReset() {
            const dt = document.getElementById('reset-datetime').value;
            const pw = document.getElementById('reset-password').value;
            if (!dt) return alert('Pick a date and time for the reset');
            if (!pw) return alert('Enter admin password to confirm');
            const resetAt = new Date(dt).toISOString();
            if (!confirm(`⚠️ SCHEDULE FULL RESET for ${new Date(dt).toLocaleString()}?\n\nThis will clear ALL stats, sats, games, and reigns.\nPlayer accounts will be kept.\nA backup is created automatically.`)) return;
            if (await api('/api/admin/schedule-reset', { resetAt, password: pw })) setTimeout(() => location.reload(), 500);
        }
        async function cancelReset() {
            if (!confirm('Cancel the scheduled reset?')) return;
            if (await api('/api/admin/cancel-reset', {})) setTimeout(() => location.reload(), 500);
        }

        // Countdown timer for scheduled reset
        <% if (scheduledReset) { %>
        (function() {
            const resetAt = new Date('<%= scheduledReset.resetAt %>').getTime();
            const el = document.getElementById('reset-countdown');
            function tick() {
                const diff = Math.max(0, resetAt - Date.now());
                if (diff <= 0) { el.textContent = 'RESETTING...'; location.reload(); return; }
                const h = Math.floor(diff / 3600000);
                const m = Math.floor((diff % 3600000) / 60000);
                const s = Math.floor((diff % 60000) / 1000);
                el.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
            }
            tick();
            setInterval(tick, 1000);
        })();
        <% } %>

        // Game elapsed timer
        <% if (state.game && state.game.started_at) { %>
        (function() {
            const gameStart = new Date('<%- state.game.started_at %><%- state.game.started_at.endsWith("Z") ? "" : "Z" %>').getTime();
            const el = document.getElementById('admin-game-elapsed');
            function tickGame() {
                const sec = Math.floor((Date.now() - gameStart) / 1000);
                const m = Math.floor(sec / 60);
                const s = sec % 60;
                if (el) el.textContent = m + ':' + String(s).padStart(2, '0');
            }
            tickGame();
            setInterval(tickGame, 1000);
        })();
        <% } %>

        // DGT clock + position verification
        function formatAdminClock(seconds) {
            if (seconds == null) return '--:--';
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return m + ':' + String(s).padStart(2, '0');
        }

        socket.on('dgt_board', (data) => {
            // Update clock display
            if (data.clock) {
                const clockContainer = document.getElementById('admin-dgt-clock');
                const whiteEl = document.getElementById('admin-clock-white');
                const blackEl = document.getElementById('admin-clock-black');
                if (clockContainer) clockContainer.style.display = 'flex';
                if (whiteEl) whiteEl.textContent = formatAdminClock(data.clock.white);
                if (blackEl) blackEl.textContent = formatAdminClock(data.clock.black);
            }

            // Position verification + skip setup button
            const el = document.getElementById('admin-pos-verify');
            const skipBtn = document.getElementById('skip-setup-btn');
            if (!el) return;
            const pv = data.positionVerification;
            if (!pv) {
                el.style.display = 'none';
                if (skipBtn) skipBtn.style.display = 'none';
                return;
            }
            el.style.display = 'block';
            // Show skip button when position verification is active (setup mode)
            if (skipBtn) skipBtn.style.display = 'flex';
            if (pv.matches === true) {
                el.style.background = 'rgba(34,197,94,0.15)';
                el.style.color = '#22c55e';
                el.textContent = '🟢 Board matches Position #' + pv.positionNumber;
            } else if (pv.matches === false) {
                el.style.background = 'rgba(239,68,68,0.15)';
                el.style.color = '#ef4444';
                el.textContent = '🔴 Board mismatch — set up: ' + (pv.pieces ? pv.pieces.join(' ') : '');
            } else {
                el.style.background = 'rgba(234,179,8,0.15)';
                el.style.color = '#eab308';
                el.textContent = '🟡 Waiting for DGT board';
            }
        });

        // Live QR update on admin page too
        socket.on('venue_code_updated', (data) => {
            const qrImg = document.getElementById('venue-qr-img');
            if (qrImg) qrImg.src = '/api/venue-qr.png?t=' + Date.now();
            // Reload to update code text / expiry
            setTimeout(() => location.reload(), 1000);
        });

        socket.on('game_started', () => setTimeout(() => location.reload(), 500));
        socket.on('game_ended', () => setTimeout(() => location.reload(), 1000));
        socket.on('new_king', () => setTimeout(() => location.reload(), 1000));
        socket.on('queue_updated', () => setTimeout(() => location.reload(), 1000));
        socket.on('event_reset', () => setTimeout(() => location.reload(), 1000));
        socket.on('reset_scheduled', () => setTimeout(() => location.reload(), 1000));
        socket.on('reset_cancelled', () => setTimeout(() => location.reload(), 1000));

        // ============================================================
        // Reorder Modal — drag-and-drop king + queue ordering
        // ============================================================
        let reorderList = []; // [{id, name}]

        function openReorderModal() {
            // Build the combined list: king first, then queue
            reorderList = [];
            <% if (state.king) { %>
            reorderList.push({ id: <%= state.king.id %>, name: '<%= (state.king.name || "").replace(/'/g, "\\'") %>', role: 'king' });
            <% } %>
            <% if (state.game && !state.game.result) { %>
            reorderList.push({ id: <%= state.game.challenger_id %>, name: '<%= (state.game.challenger_name || "").replace(/'/g, "\\'") %>', role: 'challenger' });
            <% } %>
            <% state.queue.forEach(q => { %>
            reorderList.push({ id: <%= q.player_id %>, name: '<%= (q.player_name || "").replace(/'/g, "\\'") %>', role: 'queue' });
            <% }) %>

            if (reorderList.length === 0) return alert('No players to reorder');

            document.getElementById('reorder-overlay').style.display = 'flex';
            renderReorderList();
        }

        function closeReorderModal() {
            document.getElementById('reorder-overlay').style.display = 'none';
        }

        function renderReorderList() {
            const container = document.getElementById('reorder-items');
            container.innerHTML = '';
            reorderList.forEach((player, idx) => {
                const div = document.createElement('div');
                div.className = 'reorder-item';
                div.dataset.index = idx;
                div.draggable = true;
                const isKing = idx === 0;
                const isChallenger = idx === 1 && player.role === 'challenger';
                const posLabel = isKing ? '👑' : isChallenger ? '⚔️' : '#' + (isChallenger ? idx : idx);
                const roleLabel = isKing ? 'KING' : isChallenger ? 'PLAYING' : '';
                const roleColor = isChallenger ? 'color:#f87171;' : '';
                div.innerHTML = `
                    <span class="reorder-handle">☰</span>
                    <span class="reorder-pos">${posLabel}</span>
                    <span class="reorder-name">${player.name}</span>
                    <span class="reorder-role" style="${roleColor}">${roleLabel}</span>
                    <span class="reorder-arrows">
                        <button onclick="reorderMove(${idx}, -1)" ${idx === 0 ? 'disabled' : ''}>▲</button>
                        <button onclick="reorderMove(${idx}, 1)" ${idx === reorderList.length - 1 ? 'disabled' : ''}>▼</button>
                    </span>
                `;
                // Drag events
                div.addEventListener('dragstart', onDragStart);
                div.addEventListener('dragover', onDragOver);
                div.addEventListener('dragenter', onDragEnter);
                div.addEventListener('dragleave', onDragLeave);
                div.addEventListener('drop', onDrop);
                div.addEventListener('dragend', onDragEnd);
                // Touch events for mobile
                div.addEventListener('touchstart', onTouchStart, { passive: false });
                div.addEventListener('touchmove', onTouchMove, { passive: false });
                div.addEventListener('touchend', onTouchEnd);
                container.appendChild(div);
            });
        }

        // Arrow button reorder
        function reorderMove(fromIdx, direction) {
            const toIdx = fromIdx + direction;
            if (toIdx < 0 || toIdx >= reorderList.length) return;
            const item = reorderList.splice(fromIdx, 1)[0];
            reorderList.splice(toIdx, 0, item);
            renderReorderList();
        }

        // Drag & drop
        let dragIdx = null;
        function onDragStart(e) {
            dragIdx = parseInt(e.currentTarget.dataset.index);
            e.currentTarget.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        }
        function onDragOver(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
        function onDragEnter(e) {
            e.preventDefault();
            const target = e.currentTarget;
            if (target.classList.contains('reorder-item')) target.classList.add('drag-over');
        }
        function onDragLeave(e) { e.currentTarget.classList.remove('drag-over'); }
        function onDrop(e) {
            e.preventDefault();
            const targetIdx = parseInt(e.currentTarget.dataset.index);
            e.currentTarget.classList.remove('drag-over');
            if (dragIdx !== null && dragIdx !== targetIdx) {
                const item = reorderList.splice(dragIdx, 1)[0];
                reorderList.splice(targetIdx, 0, item);
                renderReorderList();
            }
        }
        function onDragEnd(e) {
            e.currentTarget.classList.remove('dragging');
            dragIdx = null;
        }

        // Touch drag for mobile
        let touchDragIdx = null;
        let touchClone = null;
        let touchStartY = 0;

        function onTouchStart(e) {
            const target = e.currentTarget;
            touchDragIdx = parseInt(target.dataset.index);
            touchStartY = e.touches[0].clientY;
            target.classList.add('dragging');

            // Create floating clone
            touchClone = target.cloneNode(true);
            touchClone.className = 'reorder-item dragging';
            touchClone.style.position = 'fixed';
            touchClone.style.left = target.getBoundingClientRect().left + 'px';
            touchClone.style.top = e.touches[0].clientY - 20 + 'px';
            touchClone.style.width = target.offsetWidth + 'px';
            touchClone.style.zIndex = '10000';
            touchClone.style.pointerEvents = 'none';
            document.body.appendChild(touchClone);
        }

        function onTouchMove(e) {
            e.preventDefault();
            if (touchClone) {
                touchClone.style.top = e.touches[0].clientY - 20 + 'px';
            }
            // Highlight the item we're over
            const items = document.querySelectorAll('.reorder-item');
            items.forEach(item => item.classList.remove('drag-over'));
            const touch = e.touches[0];
            const overEl = document.elementFromPoint(touch.clientX, touch.clientY);
            if (overEl) {
                const reorderItem = overEl.closest('.reorder-item');
                if (reorderItem && parseInt(reorderItem.dataset.index) !== touchDragIdx) {
                    reorderItem.classList.add('drag-over');
                }
            }
        }

        function onTouchEnd(e) {
            if (touchClone) { touchClone.remove(); touchClone = null; }
            const items = document.querySelectorAll('.reorder-item');
            items.forEach(item => { item.classList.remove('dragging'); item.classList.remove('drag-over'); });

            // Find target
            const touch = e.changedTouches[0];
            const overEl = document.elementFromPoint(touch.clientX, touch.clientY);
            if (overEl) {
                const reorderItem = overEl.closest('.reorder-item');
                if (reorderItem && touchDragIdx !== null) {
                    const targetIdx = parseInt(reorderItem.dataset.index);
                    if (targetIdx !== touchDragIdx) {
                        const item = reorderList.splice(touchDragIdx, 1)[0];
                        reorderList.splice(targetIdx, 0, item);
                        renderReorderList();
                    }
                }
            }
            touchDragIdx = null;
        }

        async function confirmReorder() {
            const order = reorderList.map(p => p.id);
            const kingName = reorderList[0]?.name || '?';
            // Check if king and challenger stayed in place (game will be preserved)
            const originalKingId = reorderList.find(p => p.role === 'king')?.id;
            const originalChallengerId = reorderList.find(p => p.role === 'challenger')?.id;
            const kingStays = order[0] === originalKingId;
            const challengerStays = originalChallengerId && order[1] === originalChallengerId;
            const gamePreserved = kingStays && challengerStays;
            const gameWarning = gamePreserved
                ? '✅ Active game will continue (only queue reordered).'
                : originalChallengerId
                    ? '⚠️ Active game will be CANCELLED (king or challenger moved).'
                    : '';
            if (!confirm(`Apply new order?\n\n👑 King: ${kingName}\n${reorderList.slice(1).map((p,i) => '#' + (i+1) + ' ' + p.name + (p.role === 'challenger' ? ' ⚔️' : '')).join('\n') || '(empty queue)'}\n\n${gameWarning}`)) return;
            const result = await api('/api/admin/reorder', { order });
            if (result) {
                closeReorderModal();
                setTimeout(() => location.reload(), 500);
            }
        }
    </script>

    <!-- Reorder Modal Overlay -->
    <div id="reorder-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9998;align-items:center;justify-content:center;">
        <div style="background:#1a1a2e;border-radius:12px;padding:20px;width:min(400px,90vw);max-height:80vh;display:flex;flex-direction:column;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <h2 style="font-size:18px;font-weight:bold;margin:0;">↕️ Reorder King + Queue</h2>
                <button onclick="closeReorderModal()" style="background:none;border:none;color:#999;font-size:20px;cursor:pointer;">✕</button>
            </div>
            <p style="font-size:12px;color:#888;margin:0 0 12px;">Drag players or use arrows. First player becomes King.</p>
            <div id="reorder-items" style="flex:1;overflow-y:auto;min-height:60px;"></div>
            <div style="display:flex;gap:8px;margin-top:16px;">
                <button onclick="closeReorderModal()" style="flex:1;padding:10px;border-radius:8px;background:#333;color:#ccc;border:none;font-size:14px;cursor:pointer;">Cancel</button>
                <button onclick="confirmReorder()" style="flex:1;padding:10px;border-radius:8px;background:#7c3aed;color:#fff;border:none;font-size:14px;font-weight:bold;cursor:pointer;">✓ Apply Order</button>
            </div>
        </div>
    </div>

    <style>
        .reorder-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            margin-bottom: 4px;
            background: #0f0f1a;
            border: 1px solid #333;
            border-radius: 8px;
            cursor: grab;
            user-select: none;
            transition: background 0.15s, border-color 0.15s;
        }
        .reorder-item:first-child {
            border-color: #b8860b;
            background: rgba(184, 134, 11, 0.1);
        }
        .reorder-item.dragging { opacity: 0.4; }
        .reorder-item.drag-over { border-color: #7c3aed; background: rgba(124, 58, 237, 0.15); }
        .reorder-handle { color: #555; font-size: 14px; cursor: grab; }
        .reorder-pos { font-size: 13px; font-weight: bold; min-width: 28px; text-align: center; color: #aaa; }
        .reorder-item:first-child .reorder-pos { color: #fbbf24; }
        .reorder-name { flex: 1; font-size: 14px; color: #eee; }
        .reorder-role { font-size: 10px; font-weight: bold; color: #fbbf24; min-width: 36px; text-align: right; }
        .reorder-arrows { display: flex; flex-direction: column; gap: 0; }
        .reorder-arrows button {
            background: none; border: none; color: #666; font-size: 10px; cursor: pointer;
            padding: 0 4px; line-height: 1.2;
        }
        .reorder-arrows button:hover:not(:disabled) { color: #fff; }
        .reorder-arrows button:disabled { opacity: 0.2; cursor: default; }
    </style>
<script src="/vscale.js"></script>
</body>
</html>
