<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Board <%= boardNum %></title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body {
            background: #0f0f1a;
            color: #fff;
            font-family: system-ui, -apple-system, sans-serif;
            height: 100%;
            overflow: hidden;
        }
        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            padding: 8px;
        }

        /* Player bars — top and bottom */
        .player-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: var(--board-size);
            padding: 8px 14px;
            border-radius: 8px;
            min-height: 48px;
        }
        .player-bar.top {
            margin-bottom: 4px;
            background: #1a1a2e;
            border: 1px solid #333;
        }
        .player-bar.bottom {
            margin-top: 4px;
            background: #1a1a2e;
            border: 1px solid #333;
        }
        .player-info {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .player-piece {
            font-size: 1.4rem;
            line-height: 1;
        }
        .player-name {
            font-size: 1.1rem;
            font-weight: 600;
            color: #eee;
        }
        .player-bar.top .player-name { color: #ccc; }
        .player-bar.bottom .player-name { color: #f0d9b5; }
        .player-clock {
            font-family: 'Courier New', monospace;
            font-weight: bold;
            font-size: 1.6rem;
            padding: 4px 14px;
            border-radius: 6px;
            min-width: 90px;
            text-align: center;
        }
        .clock-white { background: #f0d9b5; color: #1a1a1a; }
        .clock-black { background: #333; color: #f0d9b5; }
        .clock-active { box-shadow: 0 0 8px rgba(255,215,0,0.5); }

        /* Chess board */
        .chess-board {
            display: inline-block;
            border-radius: 4px;
            overflow: hidden;
            width: var(--board-size);
            height: var(--board-size);
        }
        .board-row { display: flex; }
        .sq {
            width: var(--sq-size);
            height: var(--sq-size);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .sq-light { background: #f0d9b5; }
        .sq-dark { background: #b58863; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }

        /* Waiting state */
        .status-msg {
            text-align: center;
            padding: 60px;
            color: #555;
            font-size: 1.2rem;
        }
        .status-msg .icon { font-size: 3rem; margin-bottom: 12px; }

        /* Board label (small, top-left) */
        .board-label {
            position: fixed;
            top: 6px;
            left: 10px;
            font-size: 0.7rem;
            color: #444;
            z-index: 10;
        }
    </style>
</head>
<body>

<div class="board-label">Board <%= boardNum %></div>

<div class="container" id="main-container">
    <div class="status-msg" id="waiting-msg">
        <div class="icon">📡</div>
        <div>Waiting for board data...</div>
        <div style="margin-top:6px;font-size:0.8rem">Board <%= boardNum %></div>
    </div>
</div>

<script>
const BOARD_NUM = <%= boardNum %>;
const socket = io();

// Server-resolved board ID (null if no boards connected when page was loaded)
let myBoardId = <%- boardId ? JSON.stringify(boardId) : 'null' %>;

const FEN_PIECES = {
    'K':'wK','Q':'wQ','R':'wR','B':'wB','N':'wN','P':'wP',
    'k':'bK','q':'bQ','r':'bR','b':'bB','n':'bN','p':'bP',
};

// State
let currentFen = <%- initialFen ? JSON.stringify(initialFen) : 'null' %>;
let currentClock = <%- initialClock ? JSON.stringify(initialClock) : 'null' %>;
let whiteName = '<%= whiteName || "" %>';
let blackName = '<%= blackName || "" %>';
let boardRendered = false;

// For auto-discovery when server didn't have boards at page load time
let discoveredBoardIds = [];

// ─── Sizing ──────────────────────────────────────────────────
function calcSizes() {
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const barSpace = 120;
    const maxBoard = Math.min(vw - 16, vh - barSpace);
    const boardSize = Math.max(200, maxBoard);
    const sqSize = boardSize / 8;
    document.documentElement.style.setProperty('--board-size', boardSize + 'px');
    document.documentElement.style.setProperty('--sq-size', sqSize + 'px');
}
calcSizes();
window.addEventListener('resize', () => { calcSizes(); if (currentFen) renderFull(); });

// ─── Render initial state if server provided it ──────────────
if (currentFen) {
    renderFull();
}

// ─── Socket.io — real-time updates from server ───────────────
socket.on('dgt_multi_board', (data) => {
    // Case 1: We already know our board ID — just filter for it
    if (myBoardId) {
        if (data.boardId !== myBoardId) return;
        handleBoardUpdate(data);
        return;
    }

    // Case 2: No board ID yet (server had no boards when page loaded)
    // Auto-discover: collect board IDs as they appear, pick the Nth one
    if (!discoveredBoardIds.includes(data.boardId)) {
        discoveredBoardIds.push(data.boardId);
        discoveredBoardIds.sort(); // Simple alphabetical sort as fallback
        console.log('Discovered boards:', discoveredBoardIds);
    }

    if (BOARD_NUM <= discoveredBoardIds.length) {
        myBoardId = discoveredBoardIds[BOARD_NUM - 1];
        console.log('Board', BOARD_NUM, '=> boardId:', myBoardId, '(auto-discovered)');
    }

    if (data.boardId === myBoardId) {
        handleBoardUpdate(data);
    }
});

function handleBoardUpdate(data) {
    let changed = false;
    if (data.fen && data.fen !== currentFen) {
        currentFen = data.fen;
        changed = true;
    }
    if (data.clock) {
        currentClock = data.clock;
        changed = true;
    }
    if (changed && currentFen) {
        renderFull();
    }
}

// ─── Poll player names from server ──────────────────────────
function pollNames() {
    fetch('/api/board-names/' + BOARD_NUM)
        .then(r => r.json())
        .then(data => {
            const w = data.white_name || '';
            const b = data.black_name || '';
            if (w !== whiteName || b !== blackName) {
                whiteName = w;
                blackName = b;
                if (boardRendered) renderFull();
            }
        }).catch(() => {});
}
setInterval(pollNames, 5000);

// ─── Rendering ───────────────────────────────────────────────
function formatClock(sec) {
    if (sec == null) return '--:--';
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return m + ':' + String(s).padStart(2, '0');
}

function renderFull() {
    if (!currentFen) return;
    boardRendered = true;

    const container = document.getElementById('main-container');
    const wActive = currentClock && currentClock.activeSide === 'white' && currentClock.running;
    const bActive = currentClock && currentClock.activeSide === 'black' && currentClock.running;

    let html = '';

    // Top bar — Black player
    html += '<div class="player-bar top">';
    html += '  <div class="player-info">';
    html += '    <span class="player-piece">♚</span>';
    html += '    <span class="player-name">' + escHtml(blackName || 'Black') + '</span>';
    html += '  </div>';
    html += '  <div class="player-clock clock-black' + (bActive ? ' clock-active' : '') + '">' + formatClock(currentClock ? currentClock.black : null) + '</div>';
    html += '</div>';

    // Board
    html += renderBoard(currentFen);

    // Bottom bar — White player
    html += '<div class="player-bar bottom">';
    html += '  <div class="player-info">';
    html += '    <span class="player-piece">♔</span>';
    html += '    <span class="player-name">' + escHtml(whiteName || 'White') + '</span>';
    html += '  </div>';
    html += '  <div class="player-clock clock-white' + (wActive ? ' clock-active' : '') + '">' + formatClock(currentClock ? currentClock.white : null) + '</div>';
    html += '</div>';

    container.innerHTML = html;
}

function renderBoard(fen) {
    const placement = fen.split(' ')[0];
    const rows = placement.split('/');
    let html = '<div class="chess-board">';
    for (let r = 0; r < rows.length; r++) {
        html += '<div class="board-row">';
        let col = 0;
        for (const ch of rows[r]) {
            if (ch >= '1' && ch <= '8') {
                for (let i = 0; i < parseInt(ch); i++) {
                    html += '<div class="sq ' + ((r + col) % 2 === 0 ? 'sq-light' : 'sq-dark') + '"></div>';
                    col++;
                }
            } else {
                const piece = FEN_PIECES[ch];
                html += '<div class="sq ' + ((r + col) % 2 === 0 ? 'sq-light' : 'sq-dark') + '">';
                if (piece) html += '<img src="/pieces/' + piece + '.svg" class="piece-img">';
                html += '</div>';
                col++;
            }
        }
        html += '</div>';
    }
    html += '</div>';
    return html;
}

function escHtml(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
}
</script>
<script src="/vscale.js"></script>
</body>
</html>
