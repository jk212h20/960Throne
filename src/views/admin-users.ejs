<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users — Admin — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <style>body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }</style>
</head>
<body class="min-h-screen bg-throne-darker p-4">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold flex items-center gap-2"><%- include('partials/icon', { name: 'user', size: 24, cls: '' }) %> Users (<%= players.length %>)</h1>
            <div class="flex gap-3">
                <a href="/admin" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'gear', size: 14, cls: '' }) %> Admin</a>
                <a href="/throne" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 14, cls: '' }) %> Throne</a>
                <a href="/leaderboard" class="text-sm text-gray-400 hover:text-throne-gold flex items-center gap-1"><%- include('partials/icon', { name: 'trophy', size: 14, cls: '' }) %> Board</a>
            </div>
        </div>

        <!-- Summary -->
        <div class="grid grid-cols-3 gap-3 mb-4">
            <div class="card text-center py-3">
                <div class="text-2xl font-bold text-throne-gold font-mono"><%= players.reduce((s, p) => s + p.total_sats_earned, 0).toLocaleString() %></div>
                <div class="text-xs text-gray-400">Total Earned</div>
            </div>
            <div class="card text-center py-3">
                <div class="text-2xl font-bold text-green-400 font-mono"><%= players.reduce((s, p) => s + p.total_sats_claimed, 0).toLocaleString() %></div>
                <div class="text-xs text-gray-400">Total Cashed Out</div>
            </div>
            <div class="card text-center py-3">
                <div class="text-2xl font-bold text-yellow-400 font-mono"><%= players.reduce((s, p) => s + p.sat_balance, 0).toLocaleString() %></div>
                <div class="text-xs text-gray-400">Total Remaining</div>
            </div>
        </div>

        <!-- Users Table -->
        <div class="card">
            <div class="overflow-x-auto">
                <table class="w-full text-sm" id="users-table">
                    <thead>
                        <tr class="text-gray-500 border-b border-gray-700">
                            <th class="py-2 text-left cursor-pointer hover:text-white" onclick="sortTable('name')">
                                Name <span id="sort-name" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('games_played')">
                                Games <span id="sort-games_played" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('total_sats_earned')">
                                Earned <span id="sort-total_sats_earned" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('total_sats_claimed')">
                                Cashed Out <span id="sort-total_sats_claimed" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('sat_balance')">
                                Remaining <span id="sort-sat_balance" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('games_won')">
                                W <span id="sort-games_won" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-right cursor-pointer hover:text-white" onclick="sortTable('games_lost')">
                                L <span id="sort-games_lost" class="text-xs"></span>
                            </th>
                            <th class="py-2 text-center">Payout</th>
                        </tr>
                    </thead>
                    <tbody id="users-tbody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const players = <%- JSON.stringify(players) %>;
        let currentSort = 'total_sats_earned';
        let sortAsc = false;

        function sortTable(key) {
            if (currentSort === key) {
                sortAsc = !sortAsc;
            } else {
                currentSort = key;
                sortAsc = key === 'name';
            }
            renderTable();
        }

        function renderTable() {
            const sorted = [...players].sort((a, b) => {
                let va = a[currentSort];
                let vb = b[currentSort];
                if (typeof va === 'string') va = (va || '').toLowerCase();
                if (typeof vb === 'string') vb = (vb || '').toLowerCase();
                if (va < vb) return sortAsc ? -1 : 1;
                if (va > vb) return sortAsc ? 1 : -1;
                return 0;
            });

            // Update sort indicators
            document.querySelectorAll('[id^="sort-"]').forEach(el => el.textContent = '');
            const indicator = document.getElementById('sort-' + currentSort);
            if (indicator) indicator.textContent = sortAsc ? '▲' : '▼';

            const tbody = document.getElementById('users-tbody');
            tbody.innerHTML = sorted.map(p => `
                <tr class="border-b border-gray-800 hover:bg-gray-800/50">
                    <td class="py-2 font-medium">
                        <span id="name-display-${p.id}" class="cursor-pointer hover:text-throne-gold" onclick="startRename(${p.id})" title="Click to rename">
                            ${p.name || '<span class="text-gray-600">(no name)</span>'}
                        </span>
                        <span id="name-edit-${p.id}" style="display:none" class="flex items-center gap-1">
                            <input type="text" id="name-input-${p.id}" value="${(p.name || '').replace(/"/g, '&quot;')}"
                                class="bg-gray-800 border border-gray-600 rounded px-2 py-1 text-sm text-white w-32"
                                onkeydown="if(event.key==='Enter')saveRename(${p.id});if(event.key==='Escape')cancelRename(${p.id})">
                            <button onclick="saveRename(${p.id})" class="text-green-400 hover:text-green-300 text-xs px-1">✓</button>
                            <button onclick="cancelRename(${p.id})" class="text-red-400 hover:text-red-300 text-xs px-1">✗</button>
                        </span>
                    </td>
                    <td class="py-2 text-right text-gray-400">${p.games_played}</td>
                    <td class="py-2 text-right text-throne-gold font-mono">${p.total_sats_earned.toLocaleString()}</td>
                    <td class="py-2 text-right text-green-400 font-mono">${p.total_sats_claimed.toLocaleString()}</td>
                    <td class="py-2 text-right text-yellow-400 font-mono">${p.sat_balance.toLocaleString()}</td>
                    <td class="py-2 text-right text-green-400">${p.games_won}</td>
                    <td class="py-2 text-right text-red-400">${p.games_lost}</td>
                    <td class="py-2 text-center">
                        ${p.sat_balance > 0
                            ? `<button onclick="zeroPayout(${p.id}, '${(p.name || '').replace(/'/g, "\\'")}', ${p.sat_balance})" 
                                class="text-xs px-2 py-1 rounded bg-yellow-600 hover:bg-yellow-500 text-black font-bold" 
                                id="payout-btn-${p.id}">Zero (${p.sat_balance.toLocaleString()})</button>`
                            : '<span class="text-gray-600 text-xs">—</span>'}
                    </td>
                </tr>
            `).join('');
        }

        renderTable();

        function startRename(playerId) {
            document.getElementById('name-display-' + playerId).style.display = 'none';
            document.getElementById('name-edit-' + playerId).style.display = 'flex';
            const input = document.getElementById('name-input-' + playerId);
            input.focus();
            input.select();
        }

        function cancelRename(playerId) {
            document.getElementById('name-display-' + playerId).style.display = '';
            document.getElementById('name-edit-' + playerId).style.display = 'none';
        }

        async function saveRename(playerId) {
            const input = document.getElementById('name-input-' + playerId);
            const newName = input.value.trim();
            if (!newName) { cancelRename(playerId); return; }

            input.disabled = true;
            try {
                const res = await fetch('/api/admin/rename-player', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playerId, name: newName })
                });
                const data = await res.json();
                if (!res.ok) {
                    alert(data.error || 'Rename failed');
                    input.disabled = false;
                    return;
                }
                // Update local data and re-render
                const p = players.find(p => p.id === playerId);
                if (p) p.name = data.name;
                renderTable();
            } catch (err) {
                alert('Connection error');
                input.disabled = false;
            }
        }

        async function zeroPayout(playerId, playerName, amount) {
            if (!confirm(`Zero balance for ${playerName}?\n\nThis will mark ${amount.toLocaleString()} sats as paid out manually.`)) return;
            const btn = document.getElementById('payout-btn-' + playerId);
            if (btn) { btn.disabled = true; btn.textContent = '...'; }
            try {
                const res = await fetch('/api/admin/manual-payout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playerId })
                });
                const data = await res.json();
                if (!res.ok) {
                    alert(data.error || 'Payout failed');
                    if (btn) { btn.disabled = false; btn.textContent = `Zero (${amount.toLocaleString()})`; }
                    return;
                }
                // Update local data
                const p = players.find(p => p.id === playerId);
                if (p) {
                    p.total_sats_claimed += p.sat_balance;
                    p.sat_balance = 0;
                }
                renderTable();
            } catch (err) {
                alert('Connection error');
                if (btn) { btn.disabled = false; btn.textContent = `Zero (${amount.toLocaleString()})`; }
            }
        }
    </script>
<script src="/vscale.js"></script>
</body>
</html>
