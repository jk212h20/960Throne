<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stream Settings — 960 Throne Admin</title>
    <link rel="stylesheet" href="/styles.css">
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker p-4">
    <div class="max-w-2xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold flex items-center gap-2">📺 Stream Settings</h1>
            <a href="/admin" class="text-gray-500 hover:text-throne-gold text-sm">← Back to Admin</a>
        </div>

        <!-- Current Stream Preview -->
        <div class="card mb-6">
            <h2 class="text-lg font-bold mb-3 text-throne-gold">Current Stream</h2>
            <div style="position:relative;width:100%;padding-bottom:56.25%;background:#000;border-radius:8px;overflow:hidden;margin-bottom:1rem;">
                <iframe
                    id="stream-preview"
                    src="https://www.youtube.com/embed/<%= currentStreamId %>?rel=0&modestbranding=1"
                    style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen>
                </iframe>
            </div>
            <div class="text-sm text-gray-400">
                Video ID: <code class="text-throne-gold" id="current-id"><%= currentStreamId %></code>
            </div>
        </div>

        <!-- Update Stream -->
        <div class="card mb-6">
            <h2 class="text-lg font-bold mb-3 text-throne-gold">Update Stream Link</h2>
            <p class="text-sm text-gray-400 mb-4">
                Paste any YouTube URL or video ID. Supports full URLs, embed URLs, short URLs, and bare video IDs.
            </p>

            <div class="mb-4">
                <label class="block text-sm text-gray-400 mb-1">YouTube URL or Video ID</label>
                <input
                    type="text"
                    id="stream-input"
                    class="input"
                    placeholder="https://www.youtube.com/watch?v=... or video ID"
                    value=""
                >
            </div>

            <div id="preview-box" class="mb-4" style="display:none;">
                <label class="block text-sm text-gray-400 mb-1">Extracted Video ID</label>
                <div class="flex items-center gap-2">
                    <code class="text-lg text-throne-gold font-mono" id="extracted-id"></code>
                    <span class="text-green-400 text-sm" id="valid-badge" style="display:none;">✓ Valid</span>
                    <span class="text-red-400 text-sm" id="invalid-badge" style="display:none;">✗ Invalid</span>
                </div>
            </div>

            <button
                id="update-btn"
                class="btn-gold w-full"
                disabled
                onclick="updateStream()"
            >
                Update Stream
            </button>

            <div id="status-msg" class="mt-3 text-center text-sm" style="display:none;"></div>
        </div>

        <!-- History -->
        <div class="card">
            <h2 class="text-lg font-bold mb-3 text-gray-400">Quick Tips</h2>
            <ul class="text-sm text-gray-500 space-y-2">
                <li>• The /watch page auto-embeds this YouTube stream</li>
                <li>• Changes take effect immediately — anyone viewing /watch will see the new stream on next page load</li>
                <li>• You can paste any of these formats:
                    <ul class="ml-4 mt-1 space-y-1 text-gray-600">
                        <li><code>https://www.youtube.com/watch?v=VIDEO_ID</code></li>
                        <li><code>https://youtu.be/VIDEO_ID</code></li>
                        <li><code>https://www.youtube.com/embed/VIDEO_ID</code></li>
                        <li><code>https://www.youtube.com/live/VIDEO_ID</code></li>
                        <li><code>VIDEO_ID</code> (bare ID)</li>
                    </ul>
                </li>
            </ul>
        </div>

        <div class="flex justify-center gap-6 mt-6 text-sm text-gray-500">
            <a href="/admin" class="hover:text-throne-gold transition-colors">← Admin</a>
            <a href="/watch" class="hover:text-throne-gold transition-colors" target="_blank">📺 Watch Page</a>
        </div>
    </div>

<script>
const input = document.getElementById('stream-input');
const previewBox = document.getElementById('preview-box');
const extractedId = document.getElementById('extracted-id');
const validBadge = document.getElementById('valid-badge');
const invalidBadge = document.getElementById('invalid-badge');
const updateBtn = document.getElementById('update-btn');
const statusMsg = document.getElementById('status-msg');

function extractYouTubeId(url) {
    if (!url || !url.trim()) return null;
    url = url.trim();

    // Bare video ID (11 chars, alphanumeric + - + _)
    if (/^[a-zA-Z0-9_-]{11}$/.test(url)) return url;

    // Standard watch URL: youtube.com/watch?v=ID
    let m = url.match(/[?&]v=([a-zA-Z0-9_-]{11})/);
    if (m) return m[1];

    // Short URL: youtu.be/ID
    m = url.match(/youtu\.be\/([a-zA-Z0-9_-]{11})/);
    if (m) return m[1];

    // Embed URL: youtube.com/embed/ID
    m = url.match(/youtube\.com\/embed\/([a-zA-Z0-9_-]{11})/);
    if (m) return m[1];

    // Live URL: youtube.com/live/ID
    m = url.match(/youtube\.com\/live\/([a-zA-Z0-9_-]{11})/);
    if (m) return m[1];

    // Shorts: youtube.com/shorts/ID
    m = url.match(/youtube\.com\/shorts\/([a-zA-Z0-9_-]{11})/);
    if (m) return m[1];

    return null;
}

input.addEventListener('input', () => {
    const val = input.value;
    const id = extractYouTubeId(val);

    if (!val.trim()) {
        previewBox.style.display = 'none';
        updateBtn.disabled = true;
        return;
    }

    previewBox.style.display = 'block';

    if (id) {
        extractedId.textContent = id;
        validBadge.style.display = 'inline';
        invalidBadge.style.display = 'none';
        updateBtn.disabled = false;
    } else {
        extractedId.textContent = '???';
        validBadge.style.display = 'none';
        invalidBadge.style.display = 'inline';
        updateBtn.disabled = true;
    }
});

async function updateStream() {
    const id = extractYouTubeId(input.value);
    if (!id) return;

    updateBtn.disabled = true;
    updateBtn.textContent = 'Updating...';

    try {
        const res = await fetch('/api/admin/config', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'youtube_stream_id', value: id }),
        });

        if (res.ok) {
            // Update preview iframe
            document.getElementById('stream-preview').src = 'https://www.youtube.com/embed/' + id + '?rel=0&modestbranding=1';
            document.getElementById('current-id').textContent = id;

            statusMsg.style.display = 'block';
            statusMsg.className = 'mt-3 text-center text-sm text-green-400';
            statusMsg.textContent = '✓ Stream updated to ' + id;

            input.value = '';
            previewBox.style.display = 'none';
        } else {
            const data = await res.json().catch(() => ({}));
            statusMsg.style.display = 'block';
            statusMsg.className = 'mt-3 text-center text-sm text-red-400';
            statusMsg.textContent = '✗ Failed: ' + (data.error || res.statusText);
        }
    } catch (e) {
        statusMsg.style.display = 'block';
        statusMsg.className = 'mt-3 text-center text-sm text-red-400';
        statusMsg.textContent = '✗ Network error';
    }

    updateBtn.disabled = false;
    updateBtn.textContent = 'Update Stream';

    setTimeout(() => { statusMsg.style.display = 'none'; }, 5000);
}
</script>
</body>
</html>
