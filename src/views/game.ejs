<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game — 960 Throne</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }
        .color-box-white { display: inline-block; background: #fff; color: #1a1a1a; padding: 2px 8px; border-radius: 4px; border: 2px solid #fff; }
        .color-box-black { display: inline-block; background: #1a1a1a; color: #fff; padding: 2px 8px; border-radius: 4px; border: 2px solid #555; }
    </style>
</head>
<body class="min-h-screen bg-throne-darker flex items-center justify-center p-4">
    <div class="max-w-md w-full">
        <% if (state.game) { %>
        <% const isKing = player.id === state.game.king_id; %>
        <% const isChallenger = player.id === state.game.challenger_id; %>
        <% const inGame = isKing || isChallenger; %>

        <% if (inGame) { %>
        <!-- Game Header -->
        <div class="text-center mb-6">
            <div class="text-sm text-gray-400 mb-2">Position #<%= state.game.chess960_position %></div>
            <%
              const kingColor = state.game.king_color || 'white';
              const isKingWhiteG = kingColor === 'white';
              const gamePieces = state.game.position.pieces;
              const orderedPiecesG = isKingWhiteG ? gamePieces : [...gamePieces].reverse();
              const fileLabelsG = isKingWhiteG ? ['a','b','c','d','e','f','g','h'] : ['h','g','f','e','d','c','b','a'];
              const pieceColorPrefixG = isKingWhiteG ? 'w' : 'b';
            %>
            <div class="text-xs text-gray-500 mb-2"><%= kingColor.charAt(0).toUpperCase() + kingColor.slice(1) %>'s pieces — challenger mirrors</div>
            <div class="flex justify-center gap-1 mb-1">
                <% orderedPiecesG.forEach((p, i) => { %>
                <div class="w-10 h-10 flex items-center justify-center rounded <%= i % 2 === 0 ? 'bg-amber-700' : 'bg-amber-100' %>">
                    <img src="/pieces/<%= pieceColorPrefixG %><%= p %>.svg" class="piece-img" alt="<%= p %>">
                </div>
                <% }) %>
            </div>
            <div class="flex justify-center gap-1 mb-4">
                <% fileLabelsG.forEach((f) => { %>
                <div class="w-10 text-center text-xs text-gray-600"><%= f %></div>
                <% }) %>
            </div>

            <div class="flex items-center justify-center gap-2 text-lg mb-2">
                <span class="<%= kingColor === 'white' ? 'color-box-white' : 'color-box-black' %> font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 18, cls: '' }) %> <%= state.game.king_name %></span>
                <span class="text-gray-500">vs</span>
                <span class="<%= kingColor === 'white' ? 'color-box-black' : 'color-box-white' %> font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crossed-swords', size: 18, cls: '' }) %> <%= state.game.challenger_name %></span>
            </div>

            <% const myColor = isKing ? kingColor : (kingColor === 'white' ? 'black' : 'white'); %>
            <div class="text-sm text-gray-400">
                You are the <span class="text-throne-gold font-bold"><%= isKing ? 'King' : 'Challenger' %></span>
                — playing <span class="font-bold <%= myColor === 'white' ? 'color-box-white' : 'color-box-black' %>" style="font-size: 0.875rem;"><%= myColor === 'white' ? 'White' : 'Black' %></span>
            </div>
            <div class="text-sm text-yellow-400 mt-2 flex items-center justify-center gap-1"><%- include('partials/icon', { name: 'stopwatch', size: 16, cls: 'text-yellow-400' }) %> Started <span id="game-elapsed">0:00</span> ago</div>

            <!-- Chess Clocks -->
            <%
              const tcBaseG = state.config.timeControl.base;
              const fmtClockG = (s) => Math.floor(s/60) + ':' + String(s%60).padStart(2,'0');
            %>
            <div id="game-clock-container" style="display:flex;align-items:center;justify-content:center;gap:16px;margin-top:12px;">
                <div style="text-align:center">
                    <div style="font-size:11px;color:#9ca3af;margin-bottom:2px;">♔ White</div>
                    <div id="game-clock-white" style="font-family:'Courier New',monospace;font-size:1.5rem;font-weight:bold;padding:6px 14px;border-radius:8px;min-width:80px;text-align:center;background:rgba(34,197,94,0.15);border:2px solid rgba(34,197,94,0.4);color:#22c55e;"><%= fmtClockG(tcBaseG) %></div>
                </div>
                <div style="text-align:center">
                    <div style="font-size:11px;color:#9ca3af;margin-bottom:2px;">♚ Black</div>
                    <div id="game-clock-black" style="font-family:'Courier New',monospace;font-size:1.5rem;font-weight:bold;padding:6px 14px;border-radius:8px;min-width:80px;text-align:center;background:rgba(255,255,255,0.05);border:2px solid rgba(255,255,255,0.1);color:#6b7280;"><%= fmtClockG(tcBaseG) %></div>
                </div>
            </div>
        </div>

        <!-- Report Result -->
        <div class="card">
            <h2 class="text-xl font-bold mb-4 text-center">Report Result</h2>

            <div class="space-y-3" id="report-buttons">
                <button onclick="report('king_won')" class="w-full p-4 rounded-lg text-lg font-bold transition-all
                    <%= isKing ? 'bg-green-800 hover:bg-green-700 text-white' : 'bg-red-900 hover:bg-red-800 text-white' %>">
                    <% if (isKing) { %>
                        <%- include('partials/icon', { name: 'checkmark', size: 20, cls: 'text-green-300' }) %> I Won (King Wins)
                    <% } else { %>
                        <%- include('partials/icon', { name: 'cross', size: 20, cls: 'text-red-300' }) %> I Lost (King Wins)
                    <% } %>
                </button>

                <button onclick="report('challenger_won')" class="w-full p-4 rounded-lg text-lg font-bold transition-all
                    <%= isChallenger ? 'bg-green-800 hover:bg-green-700 text-white' : 'bg-red-900 hover:bg-red-800 text-white' %>">
                    <% if (isChallenger) { %>
                        <%- include('partials/icon', { name: 'checkmark', size: 20, cls: 'text-green-300' }) %> I Won (Challenger Wins)
                    <% } else { %>
                        <%- include('partials/icon', { name: 'cross', size: 20, cls: 'text-red-300' }) %> I Lost (Challenger Wins)
                    <% } %>
                </button>

                <button onclick="report('draw')" class="w-full p-4 rounded-lg text-lg font-bold bg-gray-700 hover:bg-gray-600 text-white">
                    <%- include('partials/icon', { name: 'handshake', size: 20, cls: '' }) %> Draw (King Stays)
                </button>

                <button onclick="report('no_show')" class="w-full p-3 rounded-lg text-sm font-bold bg-yellow-900 hover:bg-yellow-800 text-yellow-300 transition-all">
                    <% if (isChallenger) { %>
                        <%- include('partials/icon', { name: 'skip', size: 18, cls: 'text-yellow-300' }) %> Skip Me
                    <% } else { %>
                        <%- include('partials/icon', { name: 'warning', size: 18, cls: 'text-yellow-300' }) %> No Show
                    <% } %>
                </button>
            </div>

            <div id="report-status" class="hidden mt-4 p-3 rounded-lg text-center"></div>
        </div>
        <% } else { %>
        <!-- Not in this game -->
        <div class="card text-center">
            <div class="text-2xl mb-2"><%- include('partials/icon', { name: 'gamepad', size: 28, cls: 'text-gray-400' }) %></div>
            <div class="text-lg">Game in progress</div>
            <div class="text-gray-400 mt-2"><%= state.game.king_name %> vs <%= state.game.challenger_name %></div>
            <a href="/player" class="btn-outline inline-block mt-4">← Back to Dashboard</a>
        </div>
        <% } %>

        <% } else { %>
        <!-- No active game -->
        <div class="card text-center">
            <div class="mb-2"><%- include('partials/icon', { name: 'hourglass', size: 28, cls: 'text-gray-400' }) %></div>
            <div class="text-lg">No active game</div>
            <a href="/player" class="btn-outline inline-block mt-4">← Back to Dashboard</a>
        </div>
        <% } %>
    </div>

    <script>
        const socket = io();

        async function report(result) {
            const buttons = document.getElementById('report-buttons');
            const status = document.getElementById('report-status');

            buttons.style.opacity = '0.5';
            buttons.style.pointerEvents = 'none';

            try {
                const res = await fetch('/api/game/report', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ result })
                });
                const data = await res.json();

                status.classList.remove('hidden');
                if (data.error) {
                    status.className = 'mt-4 p-3 rounded-lg text-center bg-red-900/50 border border-red-700 text-red-300';
                    status.textContent = data.error;
                    buttons.style.opacity = '1';
                    buttons.style.pointerEvents = 'auto';
                } else if (data.status === 'conflict') {
                    showConflict(data);
                } else if (data.status === 'pending') {
                    status.className = 'mt-4 p-3 rounded-lg text-center bg-blue-900/50 border border-blue-700 text-blue-300';
                    status.textContent = data.message;
                } else {
                    status.className = 'mt-4 p-3 rounded-lg text-center bg-green-900/50 border border-green-700 text-green-300';
                    status.textContent = 'Result recorded! Redirecting...';
                    setTimeout(() => window.location.href = '/player', 2000);
                }
            } catch (err) {
                status.classList.remove('hidden');
                status.className = 'mt-4 p-3 rounded-lg text-center bg-red-900/50 border border-red-700 text-red-300';
                status.textContent = 'Connection error. Try again.';
                buttons.style.opacity = '1';
                buttons.style.pointerEvents = 'auto';
            }
        }

        // Game elapsed timer + chess clock countdown
        <% if (state.game && state.game.started_at) { %>
        (function() {
            const gameStart = new Date('<%- state.game.started_at %><%- state.game.started_at.endsWith("Z") ? "" : "Z" %>').getTime();
            const el = document.getElementById('game-elapsed');
            const tcBase = <%- state.config.timeControl.base %>;
            const elapsedSec = (Date.now() - gameStart) / 1000;
            // Approximate: split elapsed equally between both clocks
            let cW = Math.max(0, tcBase - elapsedSec / 2);
            let cB = Math.max(0, tcBase - elapsedSec / 2);
            let turn = 'white';
            let lastTick = Date.now();
            let dgtOverride = false;

            function fmtCl(s) { if (s < 0) s = 0; return Math.floor(s/60) + ':' + String(Math.floor(s)%60).padStart(2,'0'); }

            function renderGameClocks() {
                const wEl = document.getElementById('game-clock-white');
                const bEl = document.getElementById('game-clock-black');
                if (wEl) {
                    wEl.textContent = fmtCl(cW);
                    wEl.style.background = turn === 'white' ? 'rgba(34,197,94,0.15)' : 'rgba(255,255,255,0.05)';
                    wEl.style.border = turn === 'white' ? '2px solid rgba(34,197,94,0.4)' : '2px solid rgba(255,255,255,0.1)';
                    wEl.style.color = turn === 'white' ? '#22c55e' : '#6b7280';
                }
                if (bEl) {
                    bEl.textContent = fmtCl(cB);
                    bEl.style.background = turn === 'black' ? 'rgba(34,197,94,0.15)' : 'rgba(255,255,255,0.05)';
                    bEl.style.border = turn === 'black' ? '2px solid rgba(34,197,94,0.4)' : '2px solid rgba(255,255,255,0.1)';
                    bEl.style.color = turn === 'black' ? '#22c55e' : '#6b7280';
                }
            }

            renderGameClocks();

            setInterval(() => {
                // Elapsed timer
                const sec = Math.floor((Date.now() - gameStart) / 1000);
                const m = Math.floor(sec / 60);
                const s = sec % 60;
                if (el) el.textContent = m + ':' + String(s).padStart(2, '0');

                // Clock countdown (unless DGT override)
                if (!dgtOverride) {
                    const now = Date.now();
                    const dt = (now - lastTick) / 1000;
                    lastTick = now;
                    if (turn === 'white') cW = Math.max(0, cW - dt);
                    else cB = Math.max(0, cB - dt);
                    renderGameClocks();
                }
            }, 200);

            // Listen for DGT clock updates
            socket.on('dgt_board', (data) => {
                if (data.clock) {
                    dgtOverride = true;
                    cW = data.clock.white;
                    cB = data.clock.black;
                    renderGameClocks();
                }
            });
        })();
        <% } %>

        // Show conflict warning and re-enable buttons
        function showConflict(data) {
            const buttons = document.getElementById('report-buttons');
            const status = document.getElementById('report-status');

            const resultLabels = {
                king_won: 'King Won',
                challenger_won: 'Challenger Won',
                draw: 'Draw'
            };

            const kingSaid = resultLabels[data.kingReported] || data.kingReported;
            const chalSaid = resultLabels[data.challengerReported] || data.challengerReported;

            status.classList.remove('hidden');
            status.className = 'mt-4 p-4 rounded-lg text-center bg-orange-900/60 border-2 border-orange-500 text-orange-200';
            status.innerHTML = '<div class="text-lg font-bold mb-2">⚠️ Results Don\'t Match</div>' +
                '<div class="text-sm mb-1">👑 ' + data.kingName + ' said: <strong>' + kingSaid + '</strong></div>' +
                '<div class="text-sm mb-3">⚔️ ' + data.challengerName + ' said: <strong>' + chalSaid + '</strong></div>' +
                '<div class="text-xs text-orange-300">Was that a mistake? Please verify and re-submit the correct result.</div>';

            // Re-enable buttons so players can correct
            buttons.style.opacity = '1';
            buttons.style.pointerEvents = 'auto';
        }

        // Listen for conflict broadcast (reaches the first reporter who's still on pending)
        socket.on('result_conflict', (data) => {
            showConflict(data);
        });

        // Redirect when game ends
        socket.on('game_ended', () => {
            setTimeout(() => window.location.href = '/player', 1500);
        });
        socket.on('new_king', () => {
            setTimeout(() => window.location.href = '/player', 1500);
        });
    </script>
<script src="/vscale.js"></script>
</body>
</html>
