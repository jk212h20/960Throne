<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — Live</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; overflow: hidden; }
        .board-square { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }
        .sq-light { background: #f0d9b5; }
        .sq-dark { background: #b58863; }
        .sq-highlight { background: #cdd26a !important; }
        .color-box-white { display: inline-block; background: #fff; color: #1a1a1a; padding: 4px 14px; border-radius: 4px; border: 2px solid #fff; }
        .color-box-black { display: inline-block; background: #1a1a1a; color: #fff; padding: 4px 14px; border-radius: 4px; border: 2px solid #555; }
        .player-side { position: relative; }
        .player-side .crown-badge { position: absolute; top: -18px; left: 50%; transform: translateX(-50%); color: #FFD700; filter: drop-shadow(0 0 4px rgba(255,215,0,0.6)); }
        .dgt-clock { font-family: 'Courier New', monospace; font-size: 2.5rem; font-weight: bold; padding: 12px 20px; border-radius: 12px; min-width: 120px; text-align: center; }
        .dgt-clock-active { background: rgba(34,197,94,0.15); border: 2px solid rgba(34,197,94,0.4); color: #22c55e; }
        .dgt-clock-inactive { background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1); color: #6b7280; }
        @keyframes satsGlow { 0%,100% { text-shadow: 0 0 10px #FFD700; } 50% { text-shadow: 0 0 30px #FFD700, 0 0 60px #FFD700; } }
        .sats-glow { animation: satsGlow 2s ease-in-out infinite; }

        /* Setup mode: board overlay */
        .board-container { position: relative; display: inline-block; }
        .board-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; align-items: center; justify-content: center; z-index: 10; pointer-events: none; border-radius: 12px; }
        .board-overlay-text { padding: 14px 32px; border-radius: 12px; font-size: 1.5rem; font-weight: 800; letter-spacing: 0.03em; text-transform: uppercase; text-align: center; line-height: 1.3; }
        .overlay-setup { background: rgba(0,0,0,0.7); color: #fff; border: 2px solid rgba(255,255,255,0.2); }
        .overlay-ready { background: rgba(34,197,94,0.85); color: #fff; border: 2px solid rgba(34,197,94,0.6); }
        @keyframes readyPulse { 0%,100% { box-shadow: 0 0 20px rgba(34,197,94,0.3); } 50% { box-shadow: 0 0 40px rgba(34,197,94,0.6); } }
        .overlay-ready { animation: readyPulse 2s ease-in-out infinite; }

        /* Per-square checkmark badge */
        .board-square { position: relative; }
        .sq-check { position: absolute; bottom: 1px; right: 1px; width: 18px; height: 18px; border-radius: 50%; background: rgba(34,197,94,0.9); display: flex; align-items: center; justify-content: center; z-index: 5; }
        .sq-check svg { width: 12px; height: 12px; color: #fff; }
    </style>
</head>
<body class="h-screen bg-throne-darker flex flex-col">
    <!-- Top Bar -->
    <div class="bg-throne-dark border-b border-gray-800 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="text-3xl">♚</span>
            <span class="text-xl font-bold text-throne-gold">960 Throne</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="text-right">
                <div class="text-sm text-gray-400 flex items-center gap-1"><%- include('partials/icon', { name: 'lightning', size: 14, cls: 'text-gray-400' }) %> Sats Earned</div>
                <div class="text-lg font-mono font-bold text-throne-gold sats-glow" id="total-sats-earned"><%= state.stats.totalSatsDistributed.toLocaleString() %></div>
            </div>
            <div class="text-right">
                <div class="text-sm text-gray-400">Time Control</div>
                <div class="text-lg font-mono" id="time-control"><%= state.config.timeControl.base / 60 %>+<%= state.config.timeControl.increment %></div>
            </div>
        </div>
    </div>

    <div class="flex-1 flex">
        <!-- Left: Queue & QR (30%) -->
        <div class="flex-[3] bg-throne-dark border-r border-gray-800 flex flex-col">
            <div class="p-4 border-b border-gray-800">
                <h2 class="text-lg font-bold text-gray-300 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> Challengers</h2>
            </div>
            <div class="flex-1 overflow-y-auto p-4" id="queue-list">
                <% if (state.queue.length === 0) { %>
                <div class="text-center text-gray-600 mt-8">
                    <div class="mb-2"><%- include('partials/icon', { name: 'castle', size: 36, cls: 'text-gray-600' }) %></div>
                    <div>No challengers in line</div>
                    <div class="text-sm mt-1">Scan QR to join!</div>
                </div>
                <% } else { %>
                <% state.queue.forEach((entry, i) => { %>
                <div class="mb-2 p-3 rounded-lg <%= entry.status === 'on_deck' ? 'bg-throne-gold/20 border border-throne-gold on-deck-pulse' : 'bg-throne-darker' %>">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-2xl font-bold <%= entry.status === 'on_deck' ? 'text-throne-gold' : 'text-gray-600' %>">
                                <% if (entry.status === 'on_deck') { %><%- include('partials/icon', { name: 'bell', size: 24, cls: 'text-throne-gold' }) %><% } else { %>#<%= entry.position %><% } %>
                            </span>
                            <span class="<%= i === 0 ? 'text-2xl font-bold text-throne-gold' : 'text-lg' %>">
                                <%= entry.player_name %>
                            </span>
                        </div>
                        <% if (entry.status === 'on_deck') { %>
                        <span class="text-sm font-mono text-throne-gold" id="deck-timer">ON DECK</span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
                <% } %>
            </div>

            <!-- Venue Code & QR / Watch Live URL -->
            <div class="p-4 border-t border-gray-800 text-center">
                <% if (showVenueCode && state.venueCode) { %>
                <div class="text-xs text-gray-500 mb-2">Scan to join the line</div>
                <img src="/api/venue-qr.png" alt="QR" class="mx-auto rounded-lg" style="background: #fff; padding: 8px; width: 90%; max-width: 340px; height: auto;">
                <% } else if (!showVenueCode) { %>
                <div class="text-sm text-gray-500 mb-2">🌐 Watch live at</div>
                <div class="text-lg font-mono text-throne-gold"><%= state.baseUrl ? state.baseUrl.replace(/^https?:\/\//, '') : '960throne.com' %>/live</div>
                <% } %>
            </div>
        </div>

        <!-- Right: King & Game (70%) -->
        <div class="flex-[7] flex flex-col">
            <!-- Compact King Info Bar -->
            <div class="px-6 py-3 border-b border-gray-800 flex items-center justify-between" id="king-section">
                <% if (state.king) { %>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2">
                        <%- include('partials/icon', { name: 'crown', size: 28, cls: 'text-throne-gold' }) %>
                        <span class="text-2xl font-bold text-throne-gold" id="king-name"><%= state.king.name %></span>
                    </div>
                    <div class="text-lg text-gray-400 flex items-center gap-2">
                        <span class="font-mono text-2xl" id="reign-time"><%= Math.floor(state.reignSeconds / 3600) %>:<%= String(Math.floor((state.reignSeconds % 3600) / 60)).padStart(2, '0') %>:<%= String(state.reignSeconds % 60).padStart(2, '0') %></span>
                        <span>reign ·</span> <span class="font-mono text-2xl" id="win-streak"><%= state.reign ? state.reign.consecutive_wins : 0 %></span> <span>streak</span>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-3xl font-mono font-bold text-throne-gold sats-glow" id="sat-counter"><%= state.liveSats.toLocaleString() %></div>
                    <div class="text-xs text-gray-500">sats this reign (<%= state.config.satRate %>/s)</div>
                </div>
                <% } else { %>
                <div class="text-lg text-gray-500">No King on the Throne</div>
                <div class="text-sm text-gray-600">Waiting for the first player...</div>
                <% } %>
            </div>

            <!-- Active Game / Chess960 Board -->
            <div class="flex-1 flex items-center justify-center p-4" id="game-section">
                <% if (state.game) { %>
                <div class="flex items-center justify-center gap-6">
                    <% const kc = state.game.king_color || 'white'; %>
                    <%
                      // Determine which player is white and which is black
                      const whiteName = kc === 'white' ? state.game.king_name : state.game.challenger_name;
                      const blackName = kc === 'white' ? state.game.challenger_name : state.game.king_name;
                      const whiteIsKing = kc === 'white';
                      const blackIsKing = kc === 'black';
                    %>
                    <!-- Left side: White player + clock -->
                    <div class="flex flex-col items-center gap-3" id="white-side">
                        <div class="player-side">
                            <% if (whiteIsKing) { %><div class="crown-badge"><%- include('partials/icon', { name: 'crown', size: 24, cls: '' }) %></div><% } %>
                            <div class="color-box-white text-2xl font-bold flex items-center gap-1">
                                <% if (!whiteIsKing) { %><%- include('partials/icon', { name: 'crossed-swords', size: 20, cls: '' }) %><% } %>
                                <%= whiteName %>
                            </div>
                        </div>
                        <%
                          const tcBase = state.config.timeControl.base;
                          const clockWhite = (dgt && dgt.clock) ? dgt.clock.white : tcBase;
                          const fmtClock = (s) => Math.floor(s/60) + ':' + String(s%60).padStart(2,'0');
                        %>
                        <div id="dgt-clock-white" class="dgt-clock dgt-clock-active"><%= fmtClock(clockWhite) %></div>
                    </div>

                    <!-- Center: Board + game info -->
                    <div class="text-center">
                        <div class="text-sm text-gray-500 mb-2">Game #<%= state.stats.totalGames + 1 %> · Pos #<%= state.game.chess960_position %></div>
                    <!-- Chess960 Full Board -->
                    <div class="inline-block bg-throne-dark rounded-xl p-3 border border-gray-700" id="live-board" data-live-board="true" data-position="<%= state.game.chess960_position %>">
                        <%
                          const pieces = state.game.position.pieces;
                          const isKingWhite = kc === 'white';
                          const fileLabels = isKingWhite ? ['a','b','c','d','e','f','g','h'] : ['h','g','f','e','d','c','b','a'];
                          const rankLabels = isKingWhite ? [8,7,6,5,4,3,2,1] : [1,2,3,4,5,6,7,8];
                          const backRank = isKingWhite ? pieces : [...pieces].reverse();
                          const board = [];
                          if (isKingWhite) {
                            board.push(backRank.map(p => ({img: 'b' + p})));
                            board.push(Array(8).fill({img: 'bP'}));
                            for (let r = 0; r < 4; r++) board.push(Array(8).fill(null));
                            board.push(Array(8).fill({img: 'wP'}));
                            board.push(backRank.map(p => ({img: 'w' + p})));
                          } else {
                            board.push([...pieces].reverse().map(p => ({img: 'w' + p})));
                            board.push(Array(8).fill({img: 'wP'}));
                            for (let r = 0; r < 4; r++) board.push(Array(8).fill(null));
                            board.push(Array(8).fill({img: 'bP'}));
                            board.push([...pieces].reverse().map(p => ({img: 'b' + p})));
                          }
                        %>
                        <div class="inline-block">
                            <% board.forEach((row, r) => { %>
                            <div class="flex">
                                <div class="w-5 flex items-center justify-center text-xs text-gray-500 font-mono"><%= rankLabels[r] %></div>
                                <% row.forEach((sq, c) => { %>
                                <div class="board-square <%= (r + c) % 2 === 0 ? 'sq-light' : 'sq-dark' %>" data-square="<%= fileLabels[c] %><%= rankLabels[r] %>">
                                    <% if (sq) { %>
                                    <img src="/pieces/<%= sq.img %>.svg" class="piece-img" alt="<%= sq.img %>">
                                    <% } %>
                                </div>
                                <% }) %>
                            </div>
                            <% }) %>
                            <div class="flex">
                                <div class="w-5"></div>
                                <% fileLabels.forEach(f => { %>
                                <div class="board-square" style="height:auto;"><span class="text-xs text-gray-500 font-mono"><%= f %></span></div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                    </div><!-- end center board column -->

                    <!-- Right side: Black player + clock -->
                    <div class="flex flex-col items-center gap-3" id="black-side">
                        <div class="player-side">
                            <% if (blackIsKing) { %><div class="crown-badge"><%- include('partials/icon', { name: 'crown', size: 24, cls: '' }) %></div><% } %>
                            <div class="color-box-black text-2xl font-bold flex items-center gap-1">
                                <% if (!blackIsKing) { %><%- include('partials/icon', { name: 'crossed-swords', size: 20, cls: '' }) %><% } %>
                                <%= blackName %>
                            </div>
                        </div>
                        <%
                          const clockBlack = (dgt && dgt.clock) ? dgt.clock.black : tcBase;
                        %>
                        <div id="dgt-clock-black" class="dgt-clock dgt-clock-active"><%= fmtClock(clockBlack) %></div>
                    </div>
                </div><!-- end flex row: white | board | black -->
                <% } else if (state.king) { %>
                <div class="text-center text-gray-500">
                    <div class="mb-3"><%- include('partials/icon', { name: 'hourglass', size: 48, cls: 'text-gray-500' }) %></div>
                    <div class="text-xl">Waiting for challenger...</div>
                </div>
                <% } %>
            </div>
        </div>

    </div>

    <!-- Recent Games Ticker (bottom bar) — hidden on throne display -->

    <script>
        const socket = io();
        let reignStart = <%- state.reign ? `new Date('${state.reign.crowned_at}${state.reign.crowned_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        let gameStart = <%- state.game ? `new Date('${state.game.started_at}${state.game.started_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        const satRate = <%- state.config.satRate %>;
        // Base sats = total distributed minus current reign's live portion (which we recalculate)
        const baseSatsFromDb = <%- state.stats.totalSatsDistributed %>;
        const reignSatsAlreadyCounted = <%- state.reign ? state.liveSats : 0 %>;
        const baseSats = baseSatsFromDb - reignSatsAlreadyCounted; // sats from all previous reigns

        // Live counters — sats accumulate continuously from crowning, not just during games
        function updateCounters() {
            const now = Date.now();

            // Reign time + sat counter (continuous from crowning)
            let currentReignSats = 0;
            if (reignStart) {
                const reignSec = Math.floor((now - reignStart) / 1000);
                const el = document.getElementById('reign-time');
                const h = Math.floor(reignSec / 3600);
                const m = Math.floor((reignSec % 3600) / 60);
                const s = reignSec % 60;
                if (el) el.textContent = `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;

                // Sats = total reign time * rate
                currentReignSats = reignSec * satRate;
                const satEl = document.getElementById('sat-counter');
                if (satEl) satEl.textContent = currentReignSats.toLocaleString();
            }

            // Update total sats earned in top bar (base + current reign live)
            const totalEl = document.getElementById('total-sats-earned');
            if (totalEl) totalEl.textContent = (baseSats + currentReignSats).toLocaleString();

        }

        setInterval(updateCounters, 1000);
        updateCounters();

        // Socket events — refresh on state changes
        // dgtActive only suppresses minor updates (on_deck). Structural changes always reload.
        let dgtActive = false;
        function forceReload() { location.reload(); }
        function safeReload() {
            if (!dgtActive) location.reload();
        }
        socket.on('new_king', forceReload);
        socket.on('queue_updated', forceReload);
        socket.on('on_deck', safeReload);           // minor — skip during DGT
        socket.on('player_removed_timeout', forceReload);

        // DGT Board live updates
        function createDgtBoard() {
            const gameSection = document.getElementById('game-section');
            if (!gameSection) return null;
            // Clear the section and create a fresh board
            gameSection.innerHTML = '';
            const wrapper = document.createElement('div');
            wrapper.className = 'text-center';
            const container = document.createElement('div');
            container.id = 'live-board';
            container.className = 'inline-block bg-throne-dark rounded-xl p-3 border border-gray-700';
            const inner = document.createElement('div');
            inner.className = 'inline-block';
            const files = ['a','b','c','d','e','f','g','h'];
            for (let r = 0; r < 8; r++) {
                const row = document.createElement('div');
                row.className = 'flex';
                const label = document.createElement('div');
                label.className = 'w-5 flex items-center justify-center text-xs text-gray-500 font-mono';
                label.textContent = 8 - r;
                row.appendChild(label);
                for (let f = 0; f < 8; f++) {
                    const sq = document.createElement('div');
                    sq.className = 'board-square ' + ((r + f) % 2 === 0 ? 'sq-light' : 'sq-dark');
                    sq.setAttribute('data-square', files[f] + (8 - r));
                    row.appendChild(sq);
                }
                inner.appendChild(row);
            }
            // File labels
            const labelRow = document.createElement('div');
            labelRow.className = 'flex';
            const spacer = document.createElement('div');
            spacer.className = 'w-5';
            labelRow.appendChild(spacer);
            files.forEach(f => {
                const d = document.createElement('div');
                d.className = 'board-square';
                d.style.height = 'auto';
                d.innerHTML = '<span class="text-xs text-gray-500 font-mono">' + f + '</span>';
                labelRow.appendChild(d);
            });
            inner.appendChild(labelRow);
            container.appendChild(inner);
            wrapper.appendChild(container);
            gameSection.appendChild(wrapper);
            return container;
        }

        // ─── Setup Mode: Board Overlay + Checkmarks ──────
        // Checkmark SVG for per-square badges (inline, no file load needed)
        const checkSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 12 10 18 20 6"/></svg>';

        // Track whether we're in setup mode (positionVerification present and not yet started)
        let inSetupMode = false;

        /**
         * Render the expected (target) position on the board, with optional per-square checkmarks.
         * Used during setup mode to show players what to set up.
         */
        function renderExpectedBoard(boardEl, expectedBoard, squareMatches) {
            if (!boardEl || !expectedBoard) return;
            const squares = boardEl.querySelectorAll('.board-square');
            if (squares.length < 64) return;

            let idx = 0;
            expectedBoard.forEach((row, ri) => {
                row.forEach((sq, fi) => {
                    const el = squares[idx];
                    if (!el) { idx++; return; }
                    el.classList.remove('sq-highlight');

                    // Remove any existing checkmark
                    const existingCheck = el.querySelector('.sq-check');
                    if (existingCheck) existingCheck.remove();

                    // Render the expected piece
                    const img = el.querySelector('img');
                    if (sq.piece) {
                        const src = '/pieces/' + sq.color + sq.piece + '.svg';
                        if (img) {
                            img.src = src;
                            img.alt = sq.color + sq.piece;
                        } else {
                            const imgEl = document.createElement('img');
                            imgEl.src = src;
                            imgEl.className = 'piece-img';
                            imgEl.alt = sq.color + sq.piece;
                            el.appendChild(imgEl);
                        }
                    } else {
                        if (img) img.remove();
                    }

                    // Add green checkmark if this square matches
                    if (squareMatches && squareMatches[idx]) {
                        const badge = document.createElement('div');
                        badge.className = 'sq-check';
                        badge.innerHTML = checkSvg;
                        el.appendChild(badge);
                    }

                    idx++;
                });
            });
        }

        /**
         * Show/hide the board overlay ("Set Up This Position" or "Start White's Clock")
         */
        function updateBoardOverlay(pv) {
            let boardEl = document.getElementById('live-board');
            if (!boardEl) return;

            // Ensure the board is wrapped in a .board-container for overlay positioning
            let container = boardEl.closest('.board-container');
            if (!container) {
                container = document.createElement('div');
                container.className = 'board-container';
                boardEl.parentNode.insertBefore(container, boardEl);
                container.appendChild(boardEl);
            }

            let overlay = container.querySelector('.board-overlay');

            if (!pv) {
                // No verification needed — remove overlay
                if (overlay) overlay.remove();
                return;
            }

            if (!overlay) {
                overlay = document.createElement('div');
                overlay.className = 'board-overlay';
                container.appendChild(overlay);
            }

            if (pv.matches === true) {
                // All pieces correct — show "Start White's Clock"
                overlay.innerHTML = '<div class="board-overlay-text overlay-ready">Start White\'s Clock</div>';
            } else if (pv.matches === false || pv.matches === null) {
                // Pieces not matched or no DGT data yet — show "Set Up This Position"
                overlay.innerHTML = '<div class="board-overlay-text overlay-setup">Set Up This Position</div>';
            }
        }

        // ─── DGT Clock Display ───────────────────────────
        // Display clock values from DGT hardware.
        // When activeSide is provided (from serial relay), show active/inactive styling.

        function formatClockTime(seconds) {
            if (seconds == null || seconds < 0) return '--:--';
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return m + ':' + String(s).padStart(2, '0');
        }

        function updateClockDisplay(clock) {
            if (!clock) return;
            const whiteEl = document.getElementById('dgt-clock-white');
            const blackEl = document.getElementById('dgt-clock-black');

            if (whiteEl) whiteEl.textContent = formatClockTime(clock.white);
            if (blackEl) blackEl.textContent = formatClockTime(clock.black);

            // If serial relay provides activeSide, show which clock is running
            if (clock.activeSide) {
                if (whiteEl) whiteEl.className = 'dgt-clock ' + (clock.activeSide === 'white' ? 'dgt-clock-active' : 'dgt-clock-inactive');
                if (blackEl) blackEl.className = 'dgt-clock ' + (clock.activeSide === 'black' ? 'dgt-clock-active' : 'dgt-clock-inactive');
            } else if (clock.running === false) {
                // Both stopped
                if (whiteEl) whiteEl.className = 'dgt-clock dgt-clock-inactive';
                if (blackEl) blackEl.className = 'dgt-clock dgt-clock-inactive';
            }
        }

        /**
         * Render the live DGT board (actual piece positions from the physical board).
         * Used after setup mode ends (clock started, game in progress).
         */
        function renderLiveBoard(boardEl, data) {
            if (!boardEl || !data.board) return;
            const squares = boardEl.querySelectorAll('.board-square');
            if (squares.length < 64) return;

            let idx = 0;
            data.board.forEach((row, ri) => {
                row.forEach((sq, fi) => {
                    const el = squares[idx];
                    if (!el) { idx++; return; }
                    el.classList.remove('sq-highlight');

                    // Remove any checkmark badges from setup mode
                    const check = el.querySelector('.sq-check');
                    if (check) check.remove();

                    if (data.lastMove && (sq.square === data.lastMove.from || sq.square === data.lastMove.to)) {
                        el.classList.add('sq-highlight');
                    }
                    const img = el.querySelector('img');
                    if (sq.piece) {
                        const src = '/pieces/' + sq.color + sq.piece + '.svg';
                        if (img) {
                            img.src = src;
                            img.alt = sq.piece;
                        } else {
                            el.innerHTML = '<img src="' + src + '" class="piece-img" alt="' + sq.piece + '">';
                        }
                    } else {
                        if (img) img.remove();
                    }
                    idx++;
                });
            });
        }

        socket.on('dgt_board', (data) => {
            if (!data.board && !data.clock) return;
            dgtActive = true; // Stop page reloads — DGT board is live

            const pv = data.positionVerification;
            const wasSetupMode = inSetupMode;

            // Determine if we're in setup mode
            // pv exists = game created but clock hasn't started yet
            // pv === null = no expected position (game already started or no game)
            inSetupMode = !!pv;

            let boardEl = document.getElementById('live-board');
            // Create board dynamically if it doesn't exist yet
            if (!boardEl) {
                boardEl = createDgtBoard();
                if (!boardEl) return;
            }

            if (inSetupMode) {
                // ─── SETUP MODE ──────────────────────────
                // Show the expected (target) position on the board
                // with per-square green checkmarks for correct pieces
                if (pv.expectedBoard) {
                    renderExpectedBoard(boardEl, pv.expectedBoard, pv.squareMatches);
                }
                // Show overlay text
                updateBoardOverlay(pv);
            } else {
                // ─── LIVE MODE ───────────────────────────
                // Show actual DGT board position
                if (wasSetupMode) {
                    // Transitioning out of setup mode — remove overlay
                    updateBoardOverlay(null);
                }
                if (data.board) {
                    renderLiveBoard(boardEl, data);
                }
            }

            // Update clock display AFTER board rendering
            if (data.clock) {
                updateClockDisplay(data.clock);
            }
        });

        // Handle game lifecycle events — always reload to get fresh player names, positions, etc.
        socket.on('game_started', forceReload);
        socket.on('game_ended', forceReload);

        // Live QR code update — when admin rotates the venue code, update QR + code text immediately
        socket.on('venue_code_updated', (data) => {
            // Update the QR image by adding a cache-busting parameter
            const qrImg = document.querySelector('img[src*="venue-qr.png"]');
            if (qrImg) {
                qrImg.src = '/api/venue-qr.png?t=' + Date.now();
            }
            // Update the venue code text
            if (data.code) {
                const codeEls = document.querySelectorAll('.tracking-\\[0\\.3em\\]');
                codeEls.forEach(el => { el.textContent = data.code; });
            }
        });

        // Also reload on event reset
        socket.on('event_reset', () => { location.reload(); });

        // ─── Initial page load: show setup overlay if position verification is active ──
        // The server passes `dgt` state which may include positionVerification
        (function initSetupMode() {
            const dgtState = <%- JSON.stringify(dgt || {}) %>;
            if (dgtState.positionVerification) {
                const pv = dgtState.positionVerification;
                inSetupMode = true;
                // The EJS-rendered board already shows the expected position
                // We just need to add the overlay and checkmarks
                const boardEl = document.getElementById('live-board');
                if (boardEl) {
                    // Add checkmarks to squares that are already correct
                    if (pv.squareMatches) {
                        const squares = boardEl.querySelectorAll('.board-square');
                        let idx = 0;
                        for (let i = 0; i < squares.length && idx < 64; i++) {
                            const el = squares[i];
                            // Skip file label squares (they have height:auto style)
                            if (el.style.height === 'auto') continue;
                            if (pv.squareMatches[idx]) {
                                const badge = document.createElement('div');
                                badge.className = 'sq-check';
                                badge.innerHTML = checkSvg;
                                el.appendChild(badge);
                            }
                            idx++;
                        }
                    }
                    // Show overlay
                    updateBoardOverlay(pv);
                }
            }
        })();
    </script>
<script src="/vscale.js"></script>
</body>
</html>
