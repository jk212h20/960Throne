<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — Live</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; overflow: hidden; }
        .board-square { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }
        .sq-light { background: #f0d9b5; }
        .sq-dark { background: #b58863; }
        .sq-highlight { background: #cdd26a !important; }
        .color-box-white { display: inline-block; background: #fff; color: #1a1a1a; padding: 2px 10px; border-radius: 4px; border: 2px solid #fff; }
        .color-box-black { display: inline-block; background: #1a1a1a; color: #fff; padding: 2px 10px; border-radius: 4px; border: 2px solid #555; }
        .dgt-clock { font-family: 'Courier New', monospace; font-size: 2.5rem; font-weight: bold; padding: 12px 20px; border-radius: 12px; min-width: 120px; text-align: center; }
        .dgt-clock-active { background: rgba(34,197,94,0.15); border: 2px solid rgba(34,197,94,0.4); color: #22c55e; }
        .dgt-clock-inactive { background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1); color: #6b7280; }
        @keyframes satsGlow { 0%,100% { text-shadow: 0 0 10px #FFD700; } 50% { text-shadow: 0 0 30px #FFD700, 0 0 60px #FFD700; } }
        .sats-glow { animation: satsGlow 2s ease-in-out infinite; }
    </style>
</head>
<body class="h-screen bg-throne-darker flex flex-col">
    <!-- Top Bar -->
    <div class="bg-throne-dark border-b border-gray-800 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="text-3xl">♚</span>
            <span class="text-xl font-bold text-throne-gold">960 Throne</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="text-right">
                <div class="text-sm text-gray-400 flex items-center gap-1"><%- include('partials/icon', { name: 'lightning', size: 14, cls: 'text-gray-400' }) %> Sats Earned</div>
                <div class="text-lg font-mono font-bold text-throne-gold sats-glow" id="total-sats-earned"><%= state.stats.totalSatsDistributed.toLocaleString() %></div>
            </div>
            <div class="text-right">
                <div class="text-sm text-gray-400">Time Control</div>
                <div class="text-lg font-mono" id="time-control"><%= state.config.timeControl.base / 60 %>+<%= state.config.timeControl.increment %></div>
            </div>
        </div>
    </div>

    <div class="flex-1 flex">
        <!-- Left: King & Game (70%) -->
        <div class="flex-[7] flex flex-col">
            <!-- Compact King Info Bar -->
            <div class="px-6 py-3 border-b border-gray-800 flex items-center justify-between" id="king-section">
                <% if (state.king) { %>
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2">
                        <%- include('partials/icon', { name: 'crown', size: 28, cls: 'text-throne-gold' }) %>
                        <span class="text-2xl font-bold text-throne-gold" id="king-name"><%= state.king.name %></span>
                    </div>
                    <div class="text-sm text-gray-400">
                        <span class="font-mono" id="reign-time"><%= Math.floor(state.reignSeconds / 3600) %>:<%= String(Math.floor((state.reignSeconds % 3600) / 60)).padStart(2, '0') %>:<%= String(state.reignSeconds % 60).padStart(2, '0') %></span>
                        reign · <span class="font-mono" id="win-streak"><%= state.reign ? state.reign.consecutive_wins : 0 %></span> streak
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-3xl font-mono font-bold text-throne-gold sats-glow" id="sat-counter"><%= state.liveSats.toLocaleString() %></div>
                    <div class="text-xs text-gray-500">sats this reign (<%= state.config.satRate %>/s)</div>
                </div>
                <% } else { %>
                <div class="text-lg text-gray-500">No King on the Throne</div>
                <div class="text-sm text-gray-600">Waiting for the first player...</div>
                <% } %>
            </div>

            <!-- Active Game / Chess960 Board -->
            <div class="flex-1 flex items-center justify-center p-4" id="game-section">
                <% if (state.game) { %>
                <div class="text-center">
                    <% const kc = state.game.king_color || 'white'; %>
                    <!-- Player matchup + game info -->
                    <div class="flex items-center justify-center gap-3 mb-3">
                        <span class="<%= kc === 'white' ? 'color-box-white' : 'color-box-black' %> text-lg font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 16, cls: '' }) %> <%= state.game.king_name %></span>
                        <span class="text-gray-500 text-sm">vs</span>
                        <span class="<%= kc === 'white' ? 'color-box-black' : 'color-box-white' %> text-lg font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crossed-swords', size: 16, cls: '' }) %> <%= state.game.challenger_name %></span>
                        <span class="text-sm text-gray-500 ml-2">Game #<%= state.stats.totalGames + 1 %> · Pos #<%= state.game.chess960_position %> · <span id="game-elapsed" class="font-mono"><%= state.game.elapsed %></span>s</span>
                    </div>
                    <!-- Chess960 Full Board — stub for live electronic board integration -->
                    <div class="inline-block bg-throne-dark rounded-xl p-3 border border-gray-700" id="live-board" data-live-board="true" data-position="<%= state.game.chess960_position %>">
                        <%
                          const pieces = state.game.position.pieces;
                          const isKingWhite = kc === 'white';
                          const fileLabels = isKingWhite ? ['a','b','c','d','e','f','g','h'] : ['h','g','f','e','d','c','b','a'];
                          const rankLabels = isKingWhite ? [8,7,6,5,4,3,2,1] : [1,2,3,4,5,6,7,8];
                          const backRank = isKingWhite ? pieces : [...pieces].reverse();
                          const board = [];
                          if (isKingWhite) {
                            board.push(backRank.map(p => ({img: 'b' + p})));
                            board.push(Array(8).fill({img: 'bP'}));
                            for (let r = 0; r < 4; r++) board.push(Array(8).fill(null));
                            board.push(Array(8).fill({img: 'wP'}));
                            board.push(backRank.map(p => ({img: 'w' + p})));
                          } else {
                            board.push([...pieces].reverse().map(p => ({img: 'w' + p})));
                            board.push(Array(8).fill({img: 'wP'}));
                            for (let r = 0; r < 4; r++) board.push(Array(8).fill(null));
                            board.push(Array(8).fill({img: 'bP'}));
                            board.push([...pieces].reverse().map(p => ({img: 'b' + p})));
                          }
                        %>
                        <div class="inline-block">
                            <% board.forEach((row, r) => { %>
                            <div class="flex">
                                <div class="w-5 flex items-center justify-center text-xs text-gray-500 font-mono"><%= rankLabels[r] %></div>
                                <% row.forEach((sq, c) => { %>
                                <div class="board-square <%= (r + c) % 2 === 0 ? 'sq-light' : 'sq-dark' %>" data-square="<%= fileLabels[c] %><%= rankLabels[r] %>">
                                    <% if (sq) { %>
                                    <img src="/pieces/<%= sq.img %>.svg" class="piece-img" alt="<%= sq.img %>">
                                    <% } %>
                                </div>
                                <% }) %>
                            </div>
                            <% }) %>
                            <div class="flex">
                                <div class="w-5"></div>
                                <% fileLabels.forEach(f => { %>
                                <div class="board-square" style="height:auto;"><span class="text-xs text-gray-500 font-mono"><%= f %></span></div>
                                <% }) %>
                            </div>
                        </div>
                    </div>
                    <!-- Clock Display -->
                    <%
                      const tcBase = state.config.timeControl.base;
                      const clockWhite = (dgt && dgt.clock) ? dgt.clock.white : tcBase;
                      const clockBlack = (dgt && dgt.clock) ? dgt.clock.black : tcBase;
                      const fmtClock = (s) => Math.floor(s/60) + ':' + String(s%60).padStart(2,'0');
                    %>
                    <div id="dgt-clock-container" style="display:flex;align-items:center;justify-content:center;gap:24px;margin-top:12px;">
                        <div style="text-align:center">
                            <div style="font-size:12px;color:#9ca3af;margin-bottom:4px;">♔ White</div>
                            <div id="dgt-clock-white" class="dgt-clock dgt-clock-active"><%= fmtClock(clockWhite) %></div>
                        </div>
                        <div style="text-align:center">
                            <div style="font-size:12px;color:#9ca3af;margin-bottom:4px;">♚ Black</div>
                            <div id="dgt-clock-black" class="dgt-clock dgt-clock-active"><%= fmtClock(clockBlack) %></div>
                        </div>
                    </div>
                </div>
                <% } else if (state.king) { %>
                <div class="text-center text-gray-500">
                    <div class="mb-3"><%- include('partials/icon', { name: 'hourglass', size: 48, cls: 'text-gray-500' }) %></div>
                    <div class="text-xl">Waiting for challenger...</div>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Right: Queue (30%) -->
        <div class="flex-[3] bg-throne-dark border-l border-gray-800 flex flex-col">
            <div class="p-4 border-b border-gray-800">
                <h2 class="text-lg font-bold text-gray-300 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> Challengers</h2>
            </div>
            <div class="flex-1 overflow-y-auto p-4" id="queue-list">
                <% if (state.queue.length === 0) { %>
                <div class="text-center text-gray-600 mt-8">
                    <div class="mb-2"><%- include('partials/icon', { name: 'castle', size: 36, cls: 'text-gray-600' }) %></div>
                    <div>No challengers in line</div>
                    <div class="text-sm mt-1">Scan QR to join!</div>
                </div>
                <% } else { %>
                <% state.queue.forEach((entry, i) => { %>
                <div class="mb-2 p-3 rounded-lg <%= entry.status === 'on_deck' ? 'bg-throne-gold/20 border border-throne-gold on-deck-pulse' : 'bg-throne-darker' %>">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-2xl font-bold <%= entry.status === 'on_deck' ? 'text-throne-gold' : 'text-gray-600' %>">
                                <% if (entry.status === 'on_deck') { %><%- include('partials/icon', { name: 'bell', size: 24, cls: 'text-throne-gold' }) %><% } else { %>#<%= entry.position %><% } %>
                            </span>
                            <span class="<%= i === 0 ? 'text-2xl font-bold text-throne-gold' : 'text-lg' %>">
                                <%= entry.player_name %>
                            </span>
                        </div>
                        <% if (entry.status === 'on_deck') { %>
                        <span class="text-sm font-mono text-throne-gold" id="deck-timer">ON DECK</span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
                <% } %>
            </div>

            <!-- Venue Code & QR / Watch Live URL -->
            <div class="p-4 border-t border-gray-800 text-center">
                <% if (showVenueCode && state.venueCode) { %>
                <div class="text-xs text-gray-500 mb-2">Scan to join the line</div>
                <img src="/api/venue-qr.png" alt="QR" class="mx-auto rounded-lg mb-2" width="280" height="280" style="background: #fff; padding: 8px;">
                <div class="text-3xl font-mono font-bold text-throne-gold tracking-[0.3em]"><%= state.venueCode.code %></div>
                <% } else if (!showVenueCode) { %>
                <div class="text-sm text-gray-500 mb-2">🌐 Watch live at</div>
                <div class="text-lg font-mono text-throne-gold"><%= state.baseUrl ? state.baseUrl.replace(/^https?:\/\//, '') : '960throne.com' %>/live</div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Recent Games Ticker (bottom bar) -->
    <div class="bg-throne-dark border-t border-gray-800 px-6 py-2 flex items-center gap-6 overflow-x-auto text-sm">
        <span class="text-gray-500 shrink-0">Recent:</span>
        <% state.recentGames.forEach(g => { %>
        <span class="shrink-0 text-gray-400">
            <% if (g.result === 'king_won') { %>
                <%- include('partials/icon', { name: 'crown', size: 14, cls: 'text-throne-gold' }) %> <%= g.king_name %> def. <%= g.challenger_name %>
            <% } else if (g.result === 'challenger_won') { %>
                <%- include('partials/icon', { name: 'crossed-swords', size: 14, cls: 'text-red-400' }) %> <%= g.challenger_name %> dethroned <%= g.king_name %>!
            <% } else { %>
                <%- include('partials/icon', { name: 'handshake', size: 14, cls: '' }) %> <%= g.king_name %> drew vs <%= g.challenger_name %>
            <% } %>
            <span class="text-throne-gold ml-1"><%= g.sats_earned %> sats</span>
        </span>
        <% }) %>
    </div>

    <script>
        const socket = io();
        let reignStart = <%- state.reign ? `new Date('${state.reign.crowned_at}${state.reign.crowned_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        let gameStart = <%- state.game ? `new Date('${state.game.started_at}${state.game.started_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        const satRate = <%- state.config.satRate %>;
        // Base sats = total distributed minus current reign's live portion (which we recalculate)
        const baseSatsFromDb = <%- state.stats.totalSatsDistributed %>;
        const reignSatsAlreadyCounted = <%- state.reign ? state.liveSats : 0 %>;
        const baseSats = baseSatsFromDb - reignSatsAlreadyCounted; // sats from all previous reigns

        // Live counters — sats accumulate continuously from crowning, not just during games
        function updateCounters() {
            const now = Date.now();

            // Reign time + sat counter (continuous from crowning)
            let currentReignSats = 0;
            if (reignStart) {
                const reignSec = Math.floor((now - reignStart) / 1000);
                const el = document.getElementById('reign-time');
                const h = Math.floor(reignSec / 3600);
                const m = Math.floor((reignSec % 3600) / 60);
                const s = reignSec % 60;
                if (el) el.textContent = `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;

                // Sats = total reign time * rate
                currentReignSats = reignSec * satRate;
                const satEl = document.getElementById('sat-counter');
                if (satEl) satEl.textContent = currentReignSats.toLocaleString();
            }

            // Update total sats earned in top bar (base + current reign live)
            const totalEl = document.getElementById('total-sats-earned');
            if (totalEl) totalEl.textContent = (baseSats + currentReignSats).toLocaleString();

            // Game elapsed timer
            if (gameStart) {
                const gameSec = Math.floor((now - gameStart) / 1000);
                const el = document.getElementById('game-elapsed');
                if (el) el.textContent = gameSec;
            }
        }

        setInterval(updateCounters, 1000);
        updateCounters();

        // Socket events — refresh on state changes (but NOT if DGT board is active)
        let dgtActive = false;
        function safeReload() {
            if (!dgtActive) location.reload();
            // When DGT is active, skip reloads — the live board is what matters
        }
        socket.on('new_king', safeReload);
        socket.on('queue_updated', safeReload);
        socket.on('on_deck', safeReload);
        socket.on('player_removed_timeout', safeReload);

        // DGT Board live updates
        function createDgtBoard() {
            const gameSection = document.getElementById('game-section');
            if (!gameSection) return null;
            // Clear the section and create a fresh board
            gameSection.innerHTML = '';
            const wrapper = document.createElement('div');
            wrapper.className = 'text-center';
            const container = document.createElement('div');
            container.id = 'live-board';
            container.className = 'inline-block bg-throne-dark rounded-xl p-3 border border-gray-700';
            const inner = document.createElement('div');
            inner.className = 'inline-block';
            const files = ['a','b','c','d','e','f','g','h'];
            for (let r = 0; r < 8; r++) {
                const row = document.createElement('div');
                row.className = 'flex';
                const label = document.createElement('div');
                label.className = 'w-5 flex items-center justify-center text-xs text-gray-500 font-mono';
                label.textContent = 8 - r;
                row.appendChild(label);
                for (let f = 0; f < 8; f++) {
                    const sq = document.createElement('div');
                    sq.className = 'board-square ' + ((r + f) % 2 === 0 ? 'sq-light' : 'sq-dark');
                    sq.setAttribute('data-square', files[f] + (8 - r));
                    row.appendChild(sq);
                }
                inner.appendChild(row);
            }
            // File labels
            const labelRow = document.createElement('div');
            labelRow.className = 'flex';
            const spacer = document.createElement('div');
            spacer.className = 'w-5';
            labelRow.appendChild(spacer);
            files.forEach(f => {
                const d = document.createElement('div');
                d.className = 'board-square';
                d.style.height = 'auto';
                d.innerHTML = '<span class="text-xs text-gray-500 font-mono">' + f + '</span>';
                labelRow.appendChild(d);
            });
            inner.appendChild(labelRow);
            container.appendChild(inner);
            wrapper.appendChild(container);
            gameSection.appendChild(wrapper);
            return container;
        }

        // Position verification indicator
        function updatePositionVerification(pv) {
            let indicator = document.getElementById('pos-verify');
            if (!pv) {
                if (indicator) indicator.remove();
                return;
            }
            const gameSection = document.getElementById('game-section');
            if (!gameSection) return;
            if (!indicator) {
                indicator = document.createElement('div');
                indicator.id = 'pos-verify';
                indicator.style.cssText = 'text-align:center;padding:8px 16px;border-radius:8px;margin-bottom:8px;font-size:14px;font-weight:600;';
                gameSection.prepend(indicator);
            }
            if (pv.matches === true) {
                indicator.style.background = 'rgba(34,197,94,0.15)';
                indicator.style.border = '1px solid rgba(34,197,94,0.4)';
                indicator.style.color = '#22c55e';
                indicator.innerHTML = '🟢 Board ready — Position #' + pv.positionNumber;
            } else if (pv.matches === false) {
                indicator.style.background = 'rgba(239,68,68,0.15)';
                indicator.style.border = '1px solid rgba(239,68,68,0.4)';
                indicator.style.color = '#ef4444';
                const piecesStr = pv.pieces ? pv.pieces.join(' ') : '';
                indicator.innerHTML = '🔴 Set up Position #' + pv.positionNumber + ': <span class="font-mono">' + piecesStr + '</span>';
            } else {
                indicator.style.background = 'rgba(234,179,8,0.15)';
                indicator.style.border = '1px solid rgba(234,179,8,0.4)';
                indicator.style.color = '#eab308';
                indicator.innerHTML = '🟡 Waiting for DGT board — Position #' + pv.positionNumber;
            }
        }

        // ─── DGT Clock Display ───────────────────────────
        const tcBase = <%- state.config.timeControl.base %>;
        const tcIncrement = <%- state.config.timeControl.increment %>;
        let clockWhite = tcBase;
        let clockBlack = tcBase;
        let dgtClockOverride = false; // true once real DGT clock data arrives
        let clockTickTimer = null;
        let lastClockTick = null; // timestamp of last tick
        // Track whose turn it is: 'white' starts, toggles on board changes
        let currentTurn = 'white';
        let moveCount = 0; // track board changes to know whose turn it is
        let lastBoardJson = null; // detect board changes for turn toggling

        // On page load, if game already in progress, start the countdown from current time.
        // We don't know how much time each player has used, so we start both clocks at base time
        // and only tick the active player's clock from this moment forward.
        // DGT clock data will override with accurate values when available.

        function formatClockTime(seconds) {
            if (seconds == null || seconds < 0) seconds = 0;
            const m = Math.floor(seconds / 60);
            const s = seconds % 60;
            return m + ':' + String(s).padStart(2, '0');
        }

        function ensureClockDisplay() {
            if (document.getElementById('dgt-clock-container')) return;
            const gameSection = document.getElementById('game-section');
            if (!gameSection) return;
            // Insert clock container after the board
            const container = document.createElement('div');
            container.id = 'dgt-clock-container';
            container.style.cssText = 'display:flex;align-items:center;justify-content:center;gap:24px;margin-top:12px;';
            container.innerHTML = `
                <div style="text-align:center">
                    <div style="font-size:12px;color:#9ca3af;margin-bottom:4px;">♔ White</div>
                    <div id="dgt-clock-white" class="dgt-clock dgt-clock-active">` + formatClockTime(clockWhite) + `</div>
                </div>
                <div style="text-align:center">
                    <div style="font-size:12px;color:#9ca3af;margin-bottom:4px;">♚ Black</div>
                    <div id="dgt-clock-black" class="dgt-clock dgt-clock-inactive">` + formatClockTime(clockBlack) + `</div>
                </div>
            `;
            // Append to the wrapper div inside game-section
            const wrapper = gameSection.querySelector('.text-center') || gameSection;
            wrapper.appendChild(container);
        }

        function renderClockDisplay() {
            const whiteEl = document.getElementById('dgt-clock-white');
            const blackEl = document.getElementById('dgt-clock-black');
            if (whiteEl) whiteEl.textContent = formatClockTime(Math.round(clockWhite));
            if (blackEl) blackEl.textContent = formatClockTime(Math.round(clockBlack));
            // Active clock styling
            if (whiteEl) whiteEl.className = 'dgt-clock ' + (currentTurn === 'white' ? 'dgt-clock-active' : 'dgt-clock-inactive');
            if (blackEl) blackEl.className = 'dgt-clock ' + (currentTurn === 'black' ? 'dgt-clock-active' : 'dgt-clock-inactive');
        }

        function updateClockDisplay(clock) {
            if (!clock) return;
            // DGT hardware clock data overrides software countdown
            dgtClockOverride = true;
            clockWhite = clock.white;
            clockBlack = clock.black;
            ensureClockDisplay();
            renderClockDisplay();
        }

        // Software clock countdown — ticks the active player's clock down every 100ms
        function startClockCountdown() {
            if (clockTickTimer) return; // already running
            lastClockTick = Date.now();
            clockTickTimer = setInterval(() => {
                if (dgtClockOverride) return; // DGT hardware is providing clock data
                const now = Date.now();
                const elapsed = (now - lastClockTick) / 1000;
                lastClockTick = now;
                if (currentTurn === 'white') {
                    clockWhite = Math.max(0, clockWhite - elapsed);
                } else {
                    clockBlack = Math.max(0, clockBlack - elapsed);
                }
                renderClockDisplay();
            }, 100);
        }

        // Start countdown if there's an active game
        if (gameStart) {
            // Immediately update the server-rendered clock HTML with elapsed-adjusted values
            renderClockDisplay();
            startClockCountdown();
        }

        socket.on('dgt_board', (data) => {
            if (!data.board && !data.clock) return;
            dgtActive = true; // Stop page reloads — DGT board is live

            // Update position verification indicator
            updatePositionVerification(data.positionVerification);

            // Update board if board data present
            if (data.board) {
                // Detect board change → toggle turn for software clock
                const boardJson = JSON.stringify(data.board);
                if (lastBoardJson && boardJson !== lastBoardJson && !dgtClockOverride) {
                    // Board changed = a move was made. Add increment to the player who just moved, toggle turn.
                    if (currentTurn === 'white') {
                        clockWhite += tcIncrement;
                    } else {
                        clockBlack += tcIncrement;
                    }
                    currentTurn = currentTurn === 'white' ? 'black' : 'white';
                    moveCount++;
                    renderClockDisplay();
                    // Start countdown if not already running
                    startClockCountdown();
                }
                lastBoardJson = boardJson;

                let boardEl = document.getElementById('live-board');
                // Create board dynamically if it doesn't exist yet
                if (!boardEl) {
                    boardEl = createDgtBoard();
                    if (!boardEl) { return; }
                }

                const squares = boardEl.querySelectorAll('.board-square');
                if (squares.length >= 64) {
                    let idx = 0;
                    data.board.forEach((row, ri) => {
                        row.forEach((sq, fi) => {
                            const el = squares[idx];
                            if (!el) { idx++; return; }
                            el.classList.remove('sq-highlight');
                            if (data.lastMove && (sq.square === data.lastMove.from || sq.square === data.lastMove.to)) {
                                el.classList.add('sq-highlight');
                            }
                            const img = el.querySelector('img');
                            if (sq.piece) {
                                const src = '/pieces/' + sq.color + sq.piece + '.svg';
                                if (img) {
                                    img.src = src;
                                    img.alt = sq.piece;
                                } else {
                                    el.innerHTML = '<img src="' + src + '" class="piece-img" alt="' + sq.piece + '">';
                                }
                            } else {
                                if (img) img.remove();
                            }
                            idx++;
                        });
                    });
                }
            }

            // Update clock display AFTER board creation (so createDgtBoard doesn't nuke it)
            if (data.clock) {
                updateClockDisplay(data.clock);
            }
        });

        // Handle game lifecycle events for clock management
        socket.on('game_started', (data) => {
            if (dgtActive) {
                // Reset clocks for new game
                const tc = data.timeControl || { base: tcBase, increment: tcIncrement };
                clockWhite = tc.base;
                clockBlack = tc.base;
                currentTurn = 'white';
                moveCount = 0;
                lastBoardJson = null;
                dgtClockOverride = false;
                gameStart = Date.now();
                renderClockDisplay();
                startClockCountdown();
            } else {
                safeReload();
            }
        });

        socket.on('game_ended', (data) => {
            if (dgtActive) {
                // Stop clock countdown
                if (clockTickTimer) { clearInterval(clockTickTimer); clockTickTimer = null; }
            } else {
                safeReload();
            }
        });
    </script>
<script src="/vscale.js"></script>
</body>
</html>
