<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>960 Throne — Live</title>
    <link rel="stylesheet" href="/styles.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f1a; color: #fff; margin: 0; overflow: hidden; }
        .piece-img { width: 85%; height: 85%; object-fit: contain; }
        .color-box-white { display: inline-block; background: #fff; color: #1a1a1a; padding: 2px 10px; border-radius: 4px; border: 2px solid #fff; }
        .color-box-black { display: inline-block; background: #1a1a1a; color: #fff; padding: 2px 10px; border-radius: 4px; border: 2px solid #555; }
        @keyframes satsGlow { 0%,100% { text-shadow: 0 0 10px #FFD700; } 50% { text-shadow: 0 0 30px #FFD700, 0 0 60px #FFD700; } }
        .sats-glow { animation: satsGlow 2s ease-in-out infinite; }
        /* DGT 8×8 Board */
        .dgt-board { display: grid; grid-template-columns: repeat(8, 1fr); gap: 0; aspect-ratio: 1; width: 480px; max-width: 60vh; border: 2px solid #444; border-radius: 4px; overflow: hidden; margin: 0 auto; }
        .sq { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
        .sq-light { background: #f0d9b5; }
        .sq-dark { background: #b58863; }
        .sq-highlight { background: #cdd26a !important; }
    </style>
</head>
<body class="h-screen bg-throne-darker flex flex-col">
    <!-- Top Bar -->
    <div class="bg-throne-dark border-b border-gray-800 px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <span class="text-3xl">♚</span>
            <span class="text-xl font-bold text-throne-gold">960 Throne</span>
        </div>
        <div class="flex items-center gap-6">
            <div class="text-right">
                <div class="text-sm text-gray-400 flex items-center gap-1"><%- include('partials/icon', { name: 'lightning', size: 14, cls: 'text-gray-400' }) %> Sats Earned</div>
                <div class="text-lg font-mono font-bold text-throne-gold sats-glow" id="total-sats-earned"><%= state.stats.totalSatsDistributed.toLocaleString() %></div>
            </div>
            <div class="text-right">
                <div class="text-sm text-gray-400">Time Control</div>
                <div class="text-lg font-mono" id="time-control"><%= state.config.timeControl.base / 60 %>+<%= state.config.timeControl.increment %></div>
            </div>
        </div>
    </div>

    <div class="flex-1 flex">
        <!-- Left: King & Game (70%) -->
        <div class="flex-[7] flex flex-col p-6">
            <!-- King Section -->
            <div class="text-center mb-4" id="king-section">
                <% if (state.king) { %>
                <div class="inline-block">
                    <div class="mb-2 crown-drop"><%- include('partials/icon', { name: 'crown', size: 72, cls: 'text-throne-gold' }) %></div>
                    <div class="text-5xl font-bold text-throne-gold mb-3" id="king-name"><%= state.king.name %></div>
                    <div class="flex items-center justify-center gap-8 text-xl">
                        <div>
                            <span class="text-gray-400">Reign:</span>
                            <span class="font-mono" id="reign-time"><%= Math.floor(state.reignSeconds / 3600) %>:<%= String(Math.floor((state.reignSeconds % 3600) / 60)).padStart(2, '0') %>:<%= String(state.reignSeconds % 60).padStart(2, '0') %></span>
                        </div>
                        <div>
                            <span class="text-gray-400">Streak:</span>
                            <span class="font-mono" id="win-streak"><%= state.reign ? state.reign.consecutive_wins : 0 %></span>
                        </div>
                    </div>
                    <% if (state.king.times_as_king > 1 || state.king.total_sats_earned > 0) { %>
                    <div class="flex items-center justify-center gap-6 mt-2 text-sm text-gray-500">
                        <span>All-time: <%= state.king.total_sats_earned.toLocaleString() %> sats</span>
                        <span><%= Math.floor(state.king.total_reign_seconds / 60) %>m reign</span>
                        <span><%= state.king.times_as_king %> reigns</span>
                    </div>
                    <% } %>
                </div>
                <% } else { %>
                <div class="text-3xl text-gray-500">No King on the Throne</div>
                <div class="text-gray-600 mt-2">Waiting for the first player...</div>
                <% } %>
            </div>

            <!-- Sat Counter -->
            <% if (state.king) { %>
            <div class="text-center mb-6">
                <div class="text-7xl font-mono font-bold text-throne-gold sats-glow" id="sat-counter"><%= state.liveSats.toLocaleString() %></div>
                <div class="text-lg text-gray-400 mt-1">sats earned this reign (<%= state.config.satRate %>/sec)</div>
            </div>
            <% } %>

            <!-- Active Game / Chess960 Position -->
            <div class="flex-1 flex items-center justify-center" id="game-section">
                <% if (state.game) { %>
                <div class="text-center w-full">
                    <div class="text-lg font-mono text-gray-400 mb-2">Game #<%= state.stats.totalGames + 1 %></div>
                    <% const kc2 = state.game.king_color || 'white'; %>
                    <div class="flex items-center justify-center gap-4 mb-4">
                        <div class="text-2xl flex items-center gap-3">
                            <span class="<%= kc2 === 'white' ? 'color-box-white' : 'color-box-black' %> text-xl font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crown', size: 20, cls: '' }) %> <%= state.game.king_name %></span>
                            <span class="text-gray-500">vs</span>
                            <span class="<%= kc2 === 'white' ? 'color-box-black' : 'color-box-white' %> text-xl font-bold flex items-center gap-1"><%- include('partials/icon', { name: 'crossed-swords', size: 20, cls: '' }) %> <%= state.game.challenger_name %></span>
                        </div>
                    </div>
                    <!-- DGT Live Board / Chess960 Position -->
                    <div class="inline-block bg-throne-dark rounded-xl p-4 border border-gray-700">
                        <div class="text-sm text-gray-400 mb-2">Position #<%= state.game.chess960_position %></div>
                        <!-- Full 8x8 board (updated by DGT via Socket.io) -->
                        <div id="dgt-board" class="dgt-board">
                            <% if (dgt && dgt.board) { %>
                                <% dgt.board.forEach((row, ri) => { %>
                                    <% row.forEach((sq, fi) => { %>
                                        <div class="sq <%= (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark' %> <%= (dgt.lastMove && (sq.square === dgt.lastMove.from || sq.square === dgt.lastMove.to)) ? 'sq-highlight' : '' %>">
                                            <% if (sq.piece) { %>
                                                <img src="/pieces/<%= sq.color %><%= sq.piece %>.svg" class="piece-img" alt="<%= sq.piece %>">
                                            <% } %>
                                        </div>
                                    <% }) %>
                                <% }) %>
                            <% } else { %>
                                <%
                                  const pieces = state.game.position.pieces;
                                  const isKingWhite2 = kc2 === 'white';
                                  const piecePrefix2 = isKingWhite2 ? 'w' : 'b';
                                  const oppPrefix2 = isKingWhite2 ? 'b' : 'w';
                                  // Build starting 8x8 from Chess960 back rank
                                  const backRank = pieces;
                                %>
                                <% for (let ri = 0; ri < 8; ri++) { %>
                                    <% for (let fi = 0; fi < 8; fi++) { %>
                                        <div class="sq <%= (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark' %>">
                                            <% if (ri === 0) { %>
                                                <img src="/pieces/<%= oppPrefix2 %><%= backRank[fi] %>.svg" class="piece-img" alt="<%= backRank[fi] %>">
                                            <% } else if (ri === 1) { %>
                                                <img src="/pieces/<%= oppPrefix2 %>P.svg" class="piece-img" alt="P">
                                            <% } else if (ri === 6) { %>
                                                <img src="/pieces/<%= piecePrefix2 %>P.svg" class="piece-img" alt="P">
                                            <% } else if (ri === 7) { %>
                                                <img src="/pieces/<%= piecePrefix2 %><%= backRank[fi] %>.svg" class="piece-img" alt="<%= backRank[fi] %>">
                                            <% } %>
                                        </div>
                                    <% } %>
                                <% } %>
                            <% } %>
                        </div>
                        <!-- DGT Clocks -->
                        <div id="dgt-clocks" class="flex justify-between mt-3 text-lg font-mono" style="<%= (dgt && dgt.clock) ? '' : 'display:none' %>">
                            <div class="flex items-center gap-2">
                                <span class="w-4 h-4 rounded-sm bg-white inline-block border border-gray-500"></span>
                                <span id="dgt-clock-white"><%= (dgt && dgt.clock) ? Math.floor(dgt.clock.white/60)+':'+String(dgt.clock.white%60).padStart(2,'0') : '--:--' %></span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="w-4 h-4 rounded-sm bg-gray-800 inline-block border border-gray-500"></span>
                                <span id="dgt-clock-black"><%= (dgt && dgt.clock) ? Math.floor(dgt.clock.black/60)+':'+String(dgt.clock.black%60).padStart(2,'0') : '--:--' %></span>
                            </div>
                        </div>
                    </div>
                    <div class="text-sm text-gray-400 mt-3 font-mono" id="game-timer">
                        Game time: <span id="game-elapsed"><%= state.game.elapsed %></span>s
                    </div>
                </div>
                <% } else if (state.king) { %>
                <div class="text-center text-gray-500">
                    <div class="mb-3"><%- include('partials/icon', { name: 'hourglass', size: 48, cls: 'text-gray-500' }) %></div>
                    <div class="text-xl">Waiting for challenger...</div>
                </div>
                <% } %>
            </div>
        </div>

        <!-- Right: Queue (30%) -->
        <div class="flex-[3] bg-throne-dark border-l border-gray-800 flex flex-col">
            <div class="p-4 border-b border-gray-800">
                <h2 class="text-lg font-bold text-gray-300 flex items-center gap-2"><%- include('partials/icon', { name: 'queue', size: 20, cls: '' }) %> Challengers</h2>
            </div>
            <div class="flex-1 overflow-y-auto p-4" id="queue-list">
                <% if (state.queue.length === 0) { %>
                <div class="text-center text-gray-600 mt-8">
                    <div class="mb-2"><%- include('partials/icon', { name: 'castle', size: 36, cls: 'text-gray-600' }) %></div>
                    <div>No challengers in line</div>
                </div>
                <% } else { %>
                <% state.queue.forEach((entry, i) => { %>
                <div class="mb-2 p-3 rounded-lg <%= entry.status === 'on_deck' ? 'bg-throne-gold/20 border border-throne-gold on-deck-pulse' : 'bg-throne-darker' %>">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class="text-2xl font-bold <%= entry.status === 'on_deck' ? 'text-throne-gold' : 'text-gray-600' %>">
                                <% if (entry.status === 'on_deck') { %><%- include('partials/icon', { name: 'bell', size: 24, cls: 'text-throne-gold' }) %><% } else { %>#<%= entry.position %><% } %>
                            </span>
                            <span class="<%= i === 0 ? 'text-2xl font-bold text-throne-gold' : 'text-lg' %>">
                                <%= entry.player_name %>
                            </span>
                        </div>
                        <% if (entry.status === 'on_deck') { %>
                        <span class="text-sm font-mono text-throne-gold" id="deck-timer">ON DECK</span>
                        <% } %>
                    </div>
                </div>
                <% }) %>
                <% } %>
            </div>

            <!-- Stats Footer (no QR code on public live view) -->
            <div class="p-4 border-t border-gray-800 text-center">
                <div class="text-sm text-gray-500 mb-2">🌐 Watch live at</div>
                <div class="text-lg font-mono text-throne-gold"><%= state.baseUrl ? state.baseUrl.replace(/^https?:\/\//, '') : '960throne.com' %>/live</div>
            </div>

        </div>
    </div>

    <!-- Recent Games Ticker (bottom bar) -->
    <div class="bg-throne-dark border-t border-gray-800 px-6 py-2 flex items-center gap-6 overflow-x-auto text-sm">
        <span class="text-gray-500 shrink-0">Recent:</span>
        <% state.recentGames.forEach(g => { %>
        <span class="shrink-0 text-gray-400">
            <% if (g.result === 'king_won') { %>
                <%- include('partials/icon', { name: 'crown', size: 14, cls: 'text-throne-gold' }) %> <%= g.king_name %> def. <%= g.challenger_name %>
            <% } else if (g.result === 'challenger_won') { %>
                <%- include('partials/icon', { name: 'crossed-swords', size: 14, cls: 'text-red-400' }) %> <%= g.challenger_name %> dethroned <%= g.king_name %>!
            <% } else { %>
                <%- include('partials/icon', { name: 'handshake', size: 14, cls: '' }) %> <%= g.king_name %> drew vs <%= g.challenger_name %>
            <% } %>
            <span class="text-throne-gold ml-1"><%= g.sats_earned %> sats</span>
        </span>
        <% }) %>
    </div>

    <script>
        const socket = io();
        let reignStart = <%- state.reign ? `new Date('${state.reign.crowned_at}${state.reign.crowned_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        let gameStart = <%- state.game ? `new Date('${state.game.started_at}${state.game.started_at.endsWith('Z') ? '' : 'Z'}').getTime()` : 'null' %>;
        const satRate = <%- state.config.satRate %>;
        const baseSatsFromDb = <%- state.stats.totalSatsDistributed %>;
        const reignSatsAlreadyCounted = <%- state.reign ? state.liveSats : 0 %>;
        const baseSats = baseSatsFromDb - reignSatsAlreadyCounted;

        // Live counters — sats accumulate continuously from crowning, not just during games
        function updateCounters() {
            const now = Date.now();

            // Reign time + sat counter (continuous from crowning)
            let currentReignSats = 0;
            if (reignStart) {
                const reignSec = Math.floor((now - reignStart) / 1000);
                const el = document.getElementById('reign-time');
                const h = Math.floor(reignSec / 3600);
                const m = Math.floor((reignSec % 3600) / 60);
                const s = reignSec % 60;
                if (el) el.textContent = `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;

                currentReignSats = reignSec * satRate;
                const satEl = document.getElementById('sat-counter');
                if (satEl) satEl.textContent = currentReignSats.toLocaleString();
            }

            const totalEl = document.getElementById('total-sats-earned');
            if (totalEl) totalEl.textContent = (baseSats + currentReignSats).toLocaleString();

            // Game elapsed timer
            if (gameStart) {
                const gameSec = Math.floor((now - gameStart) / 1000);
                const el = document.getElementById('game-elapsed');
                if (el) el.textContent = gameSec;
            }
        }

        setInterval(updateCounters, 1000);
        updateCounters();

        // Socket events — refresh on state changes
        socket.on('new_king', () => location.reload());
        socket.on('game_started', () => location.reload());
        socket.on('game_ended', () => location.reload());
        socket.on('queue_updated', () => location.reload());
        socket.on('on_deck', () => location.reload());
        socket.on('player_removed_timeout', () => location.reload());

        // DGT Board live updates
        socket.on('dgt_board', (data) => {
            const boardEl = document.getElementById('dgt-board');
            const clocksEl = document.getElementById('dgt-clocks');
            if (!boardEl || !data.board) return;

            // Rebuild board
            let html = '';
            data.board.forEach((row, ri) => {
                row.forEach((sq, fi) => {
                    const light = (ri + fi) % 2 === 0 ? 'sq-light' : 'sq-dark';
                    const hl = (data.lastMove && (sq.square === data.lastMove.from || sq.square === data.lastMove.to)) ? 'sq-highlight' : '';
                    html += '<div class="sq ' + light + ' ' + hl + '">';
                    if (sq.piece) {
                        html += '<img src="/pieces/' + sq.color + sq.piece + '.svg" class="piece-img" alt="' + sq.piece + '">';
                    }
                    html += '</div>';
                });
            });
            boardEl.innerHTML = html;

            // Update clocks
            if (data.clock && clocksEl) {
                clocksEl.style.display = '';
                const wm = Math.floor(data.clock.white / 60);
                const ws = String(data.clock.white % 60).padStart(2, '0');
                const bm = Math.floor(data.clock.black / 60);
                const bs = String(data.clock.black % 60).padStart(2, '0');
                document.getElementById('dgt-clock-white').textContent = wm + ':' + ws;
                document.getElementById('dgt-clock-black').textContent = bm + ':' + bs;
            }
        });
    </script>
</body>
</html>
