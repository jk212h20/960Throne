<!doctype html>
<html>
<head>
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Join 960 Throne</title>
<style>
*{box-sizing:border-box}body{font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:radial-gradient(circle at 20% 20%,rgba(255,209,102,.18),transparent 28%),#08040f;color:white;display:grid;place-items:center;min-height:100dvh;margin:0;padding:6px;overflow-x:hidden}.card{width:min(480px,calc(100vw - 12px));max-width:100%;padding:18px;border-radius:22px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 80px rgba(0,0,0,.45);position:relative;overflow:hidden}h1{font-size:28px;margin:10px 0 14px}h2{font-size:22px;margin:10px 0 8px}h3{margin:8px 0 6px}p{margin:7px 0}input,button{width:100%;max-width:100%;min-width:0;padding:12px;border-radius:13px;border:0;margin:6px 0;font-size:16px;box-sizing:border-box}button{background:#ffd166;color:#100511;font-weight:900;cursor:pointer}button span{display:block;font-size:.82em;opacity:.86;margin-top:3px}button.secondary{background:#272238;color:#fff}button.danger{background:#7f1d1d;color:#fff}button.draw{background:#374151;color:#fff}button:disabled{opacity:.55;cursor:not-allowed}.muted{color:#aaa}.ok{color:#86efac}.bad{color:#fca5a5}.gold{color:#ffd166}.qr{display:block;width:min(220px,100%);margin:8px auto;border-radius:16px;background:#fff}.pill{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,209,102,.14);border:1px solid rgba(255,209,102,.35);color:#ffd166;font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.hide{display:none}a{color:#ffd166}.msg{display:none;margin-top:10px;padding:10px 12px;border-radius:14px;background:rgba(0,0,0,.24)}.queue,.report{margin-top:12px;border-top:1px solid rgba(255,255,255,.12);padding-top:10px}.q{padding:9px 11px;margin:6px 0;border-radius:13px;background:rgba(255,255,255,.08);font-weight:800}.q.me{background:rgba(255,209,102,.16);border:1px solid rgba(255,209,102,.45);color:#ffe29a}.small-link{display:inline-block;margin-top:10px;font-size:13px;color:#aaa;text-decoration:underline;background:none;border:0;padding:0;width:auto}.wallet-primary{font-size:18px;padding:14px}.fallback{margin-top:8px}.status-card{padding:11px;border-radius:15px;background:rgba(255,255,255,.08);margin:10px 0}.grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.grid button{margin:0}.logout{position:absolute;right:16px;top:14px;width:auto;padding:6px 10px;margin:0;border-radius:999px;background:rgba(255,255,255,.1);color:#ddd;font-size:12px;font-weight:800}@media(max-width:520px){.grid{grid-template-columns:1fr}.card{padding:14px;border-radius:18px}h1{font-size:22px;line-height:1.05}.pill{font-size:10px;max-width:68%;letter-spacing:.04em}.logout{right:10px;top:10px;font-size:11px;padding:5px 8px}.q{font-size:15px}.muted{font-size:14px}}
</style>
</head>
<body>
<div class="card">
  <div class="pill">Lightning required</div>
  <% if (player) { %><button class="logout" onclick="logout()" type="button">Log out</button><% } %>
  <h1>♛ Join the 960 Throne</h1>

  <% if (player) { %>
    <% if (!player.name) { %>
      <h2>Wallet verified</h2>
      <p class="ok">Your Lightning wallet login is complete.</p>
      <p class="muted">Choose the display name that will appear in the queue and on the throne screen.</p>
      <input id="display-name" maxlength="40" placeholder="Display name" autofocus>
      <button onclick="setName()">Save Name</button>
    <% } else { %>
      <h2>Welcome, <%= player.name %></h2>
      <p class="ok">Lightning wallet verified.</p>
      <div class="status-card"><h3>On the throne now</h3><p class="gold"><%= state.king ? state.king.name : 'No king yet' %></p><% if (state.game) { %><p class="muted">Current game: <%= state.game.king_name %> vs <%= state.game.challenger_name %></p><% } %></div>
      <p>Claimable balance: <%= player.sat_balance %> sats</p>
      <p>Record: <%= player.games_won || 0 %>-<%= player.games_lost || 0 %>-<%= player.games_drawn || 0 %></p>
      <% if (player.reserved_sats > 0) { %><p class="muted">Pending cashout: <b><%= player.reserved_sats.toLocaleString() %> sats</b>. Ask admin if this is stuck.</p><% } %>
      <% if (player.sat_balance >= 10) { %><div class="queue"><h3>Cash Out All</h3><p class="muted">Collect your full balance: <b><%= player.sat_balance.toLocaleString() %> sats</b>. Lightning is fastest; if routing fails for a large balance, request Bitcoin cashout below.</p><button class="secondary" id="cashout-btn" onclick="createCollectLink()">Create Lightning Collect Link</button><div id="collect-box" class="hide"><p class="ok" id="collect-title"></p><img id="collect-qr" class="qr" alt="Cashout collect QR"><button class="secondary" onclick="openCollectLink()" type="button">Open in Phoenix</button><button class="secondary" onclick="copyCollectLink()" type="button">Copy Collect Link</button><input id="collect-link" readonly onclick="this.select()"></div><h3>Bitcoin cashout</h3><p class="muted">For large balances or repeated Lightning route failures. This reserves your full balance; admin sends on-chain BTC and marks it paid.</p><input id="btc-address" placeholder="Bitcoin address, e.g. bc1..." autocomplete="off" autocapitalize="none"><button class="secondary" id="btc-cashout-btn" onclick="requestBitcoinCashout()" type="button">Request Bitcoin Cashout</button></div><% } %>
      <p>This event earned: <%= (player.total_sats_earned || 0).toLocaleString() %> sats</p>
      <p><a href="/leaderboard">Event leaderboard</a></p>
      <% const myQueueIndex = state.queue.findIndex(q => q.player_id === player.id); const inQueue = myQueueIndex >= 0; const isKing = state.king && state.king.id === player.id; const isChallenger = state.game && state.game.challenger_id === player.id; const isInCurrentGame = state.game && (state.game.king_id === player.id || state.game.challenger_id === player.id); const gameStarted = state.game && state.game.table_started_at; %>
      <% if (isKing) { %>
        <div class="status-card"><h2 class="gold">You are the king</h2><p class="muted"><%= state.game ? 'Defend the throne against ' + state.game.challenger_name + '.' : 'Waiting for the next challenger.' %></p></div>
      <% } else if (isChallenger) { %>
        <div class="status-card"><h2 class="gold">You are the challenger</h2><p class="muted">You are paired against <%= state.game.king_name %>.</p></div>
      <% } else if (inQueue) { %>
        <p class="ok">You are #<%= myQueueIndex + 1 %> in line.</p>
        <button class="secondary" onclick="leaveQueue()">Leave Queue</button>
      <% } else { %>
        <button onclick="joinQueue()">Join Queue</button>
      <% } %>
      <% if (isInCurrentGame) { %>
        <div class="report"><h3>Report Result</h3><% if (!gameStarted) { %><p class="muted">Result buttons unlock when the table game is started.</p><% } %><div class="grid"><button onclick="reportResult('king_won')" <%= gameStarted ? '' : 'disabled' %>>King Won<br><span>Rey ganó</span></button><button onclick="reportResult('challenger_won')" <%= gameStarted ? '' : 'disabled' %>>Challenger Won<br><span>Retador ganó</span></button><button class="draw" onclick="reportResult('draw')" <%= gameStarted ? '' : 'disabled' %>>Draw<br><span>Empate</span></button></div></div>
      <% } %>
      <div class="queue"><h3>Current Line</h3><% if (state.queue.length) { %><% state.queue.forEach((q,i)=>{ %><div class="q <%= q.player_id===player.id ? 'me' : '' %>">#<%= i+1 %> <%= q.player_name %><%= q.player_id===player.id ? ' · you' : '' %></div><% }) %><% } else { %><p class="muted">The line is open.</p><% } %></div>
    <% } %>
  <% } else { %>
    <h2>Log in with Lightning</h2>
    <p class="muted">Use Phoenix Wallet to log in before entering the line.</p>
    <button id="start" class="wallet-primary" onclick="startLightningLogin()">Log in with Phoenix</button>
    <p id="wallet-help" class="muted">Android opens Phoenix directly. iPhone tries Phoenix directly, with copy-code fallback if needed.</p>
    <p class="muted">No Phoenix? <a class="gold" id="phoenix-install" href="https://play.google.com/store/apps/details?id=fr.acinq.phoenix.mainnet">Install Phoenix</a>.</p>
    <button id="show-qr" class="small-link" onclick="showQrFallback()" type="button">show QR / copy code</button>
    <div class="queue"><h3>Camera not working?</h3><p class="muted">Type the code shown on the public screen.</p><input id="venue-code" placeholder="Screen code" autocomplete="off" autocapitalize="characters"><button class="secondary" onclick="verifyVenueCode()">Use Code</button></div>
    <div id="auth-box" class="hide fallback">
      <img id="qr" class="qr" alt="Lightning login QR">
      <button class="secondary" onclick="copyLoginCode()" type="button">Copy Login Code</button>
      <input id="login-code" readonly value="" onclick="this.select()" aria-label="Lightning login code">
      <p id="auth-status" class="muted">Waiting for Phoenix login…</p>
    </div>
  <% } %>

  <div id="out" class="msg"></div>
</div>
<script>
let currentChallenge=null,pollTimer=null;
const PHOENIX_ANDROID_PACKAGE='fr.acinq.phoenix.mainnet';
const PHOENIX_PLAY_STORE='https://play.google.com/store/apps/details?id=fr.acinq.phoenix.mainnet';
const PHOENIX_APP_STORE='https://apps.apple.com/app/phoenix-wallet/id1544097028';
function phoenixDeepLink(){return currentChallenge&&currentChallenge.deepLink?'phoenix:'+currentChallenge.deepLink:null}
function showMsg(text, ok=true){out.style.display='block';out.textContent=text;out.className='msg '+(ok?'ok':'bad')}
async function post(u,b={},reload=true){const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)});const j=await r.json().catch(()=>({error:'Request failed'}));if(!r.ok||j.error){showMsg(j.error||'Request failed',false);return j}showMsg(j.message||'Saved',true);if(reload)setTimeout(()=>location.reload(),450);return j}
async function setName(){const name=document.getElementById('display-name').value;await post('/api/auth/set-name',{name})}
async function joinQueue(){await post('/api/queue/join',{},true)}
async function leaveQueue(){await post('/api/queue/leave',{},true)}
async function reportResult(result){await post('/api/game/report',{result},true)}
let currentCollect=null;
async function createCollectLink(){if(!confirm('Cash out your full claimable balance now?'))return;const btn=document.getElementById('cashout-btn');btn.disabled=true;const r=await fetch('/api/claim/lnurl-withdraw',{method:'POST',headers:{'Content-Type':'application/json'},body:'{}'});const j=await r.json().catch(()=>({error:'Bad response'}));if(!r.ok||j.error){btn.disabled=false;showMsg(j.error||'Cashout failed',false);return}currentCollect=j;document.getElementById('collect-box').classList.remove('hide');document.getElementById('collect-title').textContent='Scan or tap to collect '+Number(j.amount).toLocaleString()+' sats';document.getElementById('collect-qr').src=j.qr;document.getElementById('collect-link').value=j.collectLink;showMsg('Collect link ready. Open with Phoenix to receive sats.',true)}
function openCollectLink(){if(currentCollect)location.href=currentCollect.phoenixLink||currentCollect.collectLink}
async function copyCollectLink(){if(!currentCollect)return;try{await navigator.clipboard.writeText(currentCollect.collectLink);showMsg('Collect link copied.',true)}catch(e){document.getElementById('collect-link').select();showMsg('Copy failed; select the link manually.',false)}}
async function requestBitcoinCashout(){const address=(document.getElementById('btc-address')?.value||'').trim();if(!address){showMsg('Enter a Bitcoin address first.',false);return}if(!confirm('Request full-balance Bitcoin cashout to this address? Admin will send it manually.'))return;const btn=document.getElementById('btc-cashout-btn');if(btn)btn.disabled=true;const r=await fetch('/api/claim/bitcoin-onchain',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address})});const j=await r.json().catch(()=>({error:'Bad response'}));if(!r.ok||j.error){if(btn)btn.disabled=false;showMsg(j.error||'Bitcoin cashout request failed',false);return}showMsg(j.message||('Bitcoin cashout requested for '+Number(j.amount).toLocaleString()+' sats.'),true);setTimeout(()=>location.reload(),1200)}
async function claimLightningAddress(){showMsg('Use Cash Out All to create a scan-to-collect link.',false)}
async function logout(){await post('/api/auth/logout',{},true)}
async function verifyVenueCode(){const code=document.getElementById('venue-code').value;const j=await post('/api/venue-code/verify',{code},false);if(j.success){showMsg('Code accepted. Open your wallet to log in.',true);setTimeout(startLightningLogin,250)}}
async function startLightningLogin(){
  const status=document.getElementById('auth-status');
  document.getElementById('start').disabled=true;
  const r=await fetch('/api/auth/lightning');
  const j=await r.json();
  if(!r.ok){showMsg(j.error||'Could not start wallet login',false);document.getElementById('start').disabled=false;return}
  currentChallenge=j;
  document.getElementById('qr').src=j.qr;
  document.getElementById('login-code').value=j.deepLink||('lightning:'+j.lnurl);
  status.textContent='Preparing Phoenix login…';
  if(pollTimer)clearInterval(pollTimer);
  pollTimer=setInterval(checkAuth,1200);
  openWallet();
  setTimeout(()=>{ if(currentChallenge) status.textContent='Waiting for wallet login…'; },900);
}
function showQrFallback(){document.getElementById('auth-box').classList.remove('hide'); if(!currentChallenge) startLightningLogin()}
function openWallet(){
  if(!currentChallenge||!currentChallenge.deepLink)return;
  const ua=navigator.userAgent||'';
  const lnurl=currentChallenge.lnurl||currentChallenge.deepLink.replace(/^lightning:/i,'');
  if(/iPhone|iPad|iPod/i.test(ua))document.getElementById('phoenix-install').href=PHOENIX_APP_STORE;
  if(/Android/i.test(ua)){
    // Android Chrome package-targeted intent: open Phoenix only; fallback to Play Store if missing.
    // Avoid the generic lightning: link here so Cash App/Blink do not win the chooser.
    location.href='intent:'+lnurl+'#Intent;scheme=lightning;package='+PHOENIX_ANDROID_PACKAGE+';S.browser_fallback_url='+encodeURIComponent(PHOENIX_PLAY_STORE)+';end';
    setTimeout(()=>{ if(currentChallenge) showMsg('If Phoenix did not open, install Phoenix or use the QR/login code.',true); },1200);
    return;
  }
  if(/iPhone|iPad|iPod/i.test(ua)){
    // Phoenix-specific iOS scheme. This avoids the shared lightning: handler that Cash App/Blink can intercept.
    showQrFallback();
    copyLoginCode(true);
    const link=phoenixDeepLink();
    if(link)location.href=link;
    setTimeout(()=>{ if(currentChallenge) showMsg('If Phoenix did not open, tap Copy Login Code, open/install Phoenix, and paste/use the code there.',true); },1200);
    return;
  }
  location.href=currentChallenge.deepLink;
}
async function copyLoginCode(silent=false){
  if(!currentChallenge)return showMsg('Start login first.',false);
  const code=currentChallenge.deepLink||('lightning:'+currentChallenge.lnurl);
  document.getElementById('login-code').value=code;
  try{await navigator.clipboard.writeText(code);if(!silent)showMsg('Login code copied. Open Phoenix and paste/use it there.',true)}catch(e){document.getElementById('login-code').select();if(!silent)showMsg('Copy failed; select/copy the code shown below, then open Phoenix.',false)}
}
async function checkAuth(){
  if(!currentChallenge)return;
  const r=await fetch('/api/auth/status?k1='+encodeURIComponent(currentChallenge.k1));
  const j=await r.json();
  const status=document.getElementById('auth-status');
  if(j.status==='complete'){
    clearInterval(pollTimer);
    status.textContent='Wallet verified. Loading…';
    status.className='ok';
    location.reload();
  } else if(j.status==='expired'||j.status==='failed'){
    clearInterval(pollTimer);
    status.textContent='Login '+j.status+'. Generate a new QR and try again.';
    status.className='bad';
    document.getElementById('start').disabled=false;
  } else {
    status.textContent='Waiting for wallet login…';
  }
}
</script>
</body>
</html>
