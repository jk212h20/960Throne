<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Join 960 Throne</title><style>body{font-family:system-ui;background:#08040f;color:white;display:grid;place-items:center;min-height:100vh;margin:0}.card{width:min(520px,92vw);padding:32px;border-radius:28px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16)}input,button{width:100%;padding:16px;border-radius:14px;border:0;margin:8px 0;font-size:18px}button{background:#ffd166;font-weight:900}.muted{color:#aaa}</style></head><body><div class="card"><h1>♛ Join the 960 Throne</h1><p class="muted">Code: <b><%= state.event.venueCode || '------' %></b></p><% if (player) { %><h2>Welcome, <%= player.name %></h2><p>Balance: <%= player.sat_balance %> sats</p><button onclick="post('/api/queue/join')">Join Queue</button><button onclick="post('/api/queue/leave')">Leave Queue</button><% if (state.game && (state.game.king_id===player.id || state.game.challenger_id===player.id)) { %><button onclick="post('/api/game/report',{result:'king_won'})">Report King Won</button><button onclick="post('/api/game/report',{result:'challenger_won'})">Report Challenger Won</button><button onclick="post('/api/game/report',{result:'draw'})">Report Draw</button><% } %><% } else { %><input id="name" placeholder="Your name"><button onclick="register()">Register</button><% } %><pre id="out"></pre></div><script>async function post(u,b={}){const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)});out.textContent=JSON.stringify(await r.json(),null,2);if(r.ok)setTimeout(()=>location.reload(),400)}function register(){post('/api/players/register',{name:document.getElementById('name').value})}</script></body></html>