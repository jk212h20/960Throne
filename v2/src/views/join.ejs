<!doctype html>
<html>
<head>
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Join 960 Throne</title>
<style>
body{font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:radial-gradient(circle at 20% 20%,rgba(255,209,102,.18),transparent 28%),#08040f;color:white;display:grid;place-items:center;min-height:100vh;margin:0}.card{width:min(540px,92vw);padding:30px;border-radius:28px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 80px rgba(0,0,0,.45)}input,button{width:100%;padding:16px;border-radius:14px;border:0;margin:8px 0;font-size:18px;box-sizing:border-box}button{background:#ffd166;color:#100511;font-weight:900;cursor:pointer}button.secondary{background:#272238;color:#fff}button:disabled{opacity:.55;cursor:not-allowed}.muted{color:#aaa}.ok{color:#86efac}.bad{color:#fca5a5}.qr{display:block;width:min(320px,100%);margin:12px auto;border-radius:18px;background:#fff}.pill{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,209,102,.14);border:1px solid rgba(255,209,102,.35);color:#ffd166;font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}.hide{display:none}a{color:#ffd166}.msg{display:none;margin-top:14px;padding:12px 14px;border-radius:14px;background:rgba(0,0,0,.24)}.queue{margin-top:18px;border-top:1px solid rgba(255,255,255,.12);padding-top:14px}.q{padding:11px 13px;margin:8px 0;border-radius:14px;background:rgba(255,255,255,.08);font-weight:800}.q.me{background:rgba(255,209,102,.16);border:1px solid rgba(255,209,102,.45);color:#ffe29a}.small-link{display:inline-block;margin-top:10px;font-size:13px;color:#aaa;text-decoration:underline;background:none;border:0;padding:0;width:auto}.wallet-primary{font-size:20px;padding:18px}.fallback{margin-top:10px}
</style>
</head>
<body>
<div class="card">
  <div class="pill">Lightning required</div>
  <h1>♛ Join the 960 Throne</h1>
  <p class="muted">Venue code: <b><%= state.event.venueCode || '------' %></b></p>

  <% if (player) { %>
    <% if (!player.name) { %>
      <h2>Wallet verified</h2>
      <p class="ok">Your Lightning wallet login is complete.</p>
      <p class="muted">Choose the display name that will appear in the queue and on the throne screen.</p>
      <input id="display-name" maxlength="40" placeholder="Display name" autofocus>
      <button onclick="setName()">Save Name</button>
    <% } else { %>
      <h2>Welcome, <%= player.name %></h2>
      <p class="ok">Lightning wallet verified.</p>
      <p>Claimable balance: <%= player.sat_balance %> sats</p>
      <p>This event earned: <%= (player.total_sats_earned || 0).toLocaleString() %> sats</p>
      <p><a href="/leaderboard">Event leaderboard</a></p>
      <% const myQueueIndex = state.queue.findIndex(q => q.player_id === player.id); const inQueue = myQueueIndex >= 0; %>
      <% if (inQueue) { %>
        <p class="ok">You are #<%= myQueueIndex + 1 %> in line.</p>
        <button class="secondary" onclick="leaveQueue()">Leave Queue</button>
      <% } else { %>
        <button onclick="joinQueue()">Join Queue</button>
      <% } %>
      <div class="queue"><h3>Current Line</h3><% if (state.queue.length) { %><% state.queue.forEach((q,i)=>{ %><div class="q <%= q.player_id===player.id ? 'me' : '' %>">#<%= i+1 %> <%= q.player_name %><%= q.player_id===player.id ? ' · you' : '' %></div><% }) %><% } else { %><p class="muted">The line is open.</p><% } %></div>
      <% if (state.game && (state.game.king_id===player.id || state.game.challenger_id===player.id)) { %>
        <hr style="border-color:rgba(255,255,255,.12)">
        <p class="muted">You are in the current table pairing. Results are reported on the table tablet.</p>
      <% } %>
    <% } %>
  <% } else { %>
    <h2>Log in with Lightning</h2>
    <p class="muted">Open your Lightning wallet to log in before entering the line.</p>
    <button id="start" class="wallet-primary" onclick="startLightningLogin()">Open Wallet and Log in</button>
    <button id="show-qr" class="small-link" onclick="showQrFallback()" type="button">show QR code</button>
    <div id="auth-box" class="hide fallback">
      <img id="qr" class="qr" alt="Lightning login QR">
      <p id="auth-status" class="muted">Waiting for wallet login…</p>
    </div>
  <% } %>

  <div id="out" class="msg"></div>
</div>
<script>
let currentChallenge=null,pollTimer=null;
function showMsg(text, ok=true){out.style.display='block';out.textContent=text;out.className='msg '+(ok?'ok':'bad')}
async function post(u,b={},reload=true){const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)});const j=await r.json().catch(()=>({error:'Request failed'}));if(!r.ok||j.error){showMsg(j.error||'Request failed',false);return j}showMsg(j.message||'Saved',true);if(reload)setTimeout(()=>location.reload(),450);return j}
async function setName(){const name=document.getElementById('display-name').value;await post('/api/auth/set-name',{name})}
async function joinQueue(){await post('/api/queue/join',{},true)}
async function leaveQueue(){await post('/api/queue/leave',{},true)}
async function startLightningLogin(){
  const status=document.getElementById('auth-status');
  document.getElementById('start').disabled=true;
  const r=await fetch('/api/auth/lightning');
  const j=await r.json();
  if(!r.ok){showMsg(j.error||'Could not start wallet login',false);document.getElementById('start').disabled=false;return}
  currentChallenge=j;
  document.getElementById('qr').src=j.qr;
  status.textContent='Opening wallet…';
  if(pollTimer)clearInterval(pollTimer);
  pollTimer=setInterval(checkAuth,1200);
  openWallet();
  setTimeout(()=>{ if(currentChallenge) status.textContent='Waiting for wallet login…'; },900);
}
function showQrFallback(){document.getElementById('auth-box').classList.remove('hide'); if(!currentChallenge) startLightningLogin()}
function openWallet(){if(currentChallenge&&currentChallenge.deepLink)location.href=currentChallenge.deepLink}
async function checkAuth(){
  if(!currentChallenge)return;
  const r=await fetch('/api/auth/status?k1='+encodeURIComponent(currentChallenge.k1));
  const j=await r.json();
  const status=document.getElementById('auth-status');
  if(j.status==='complete'){
    clearInterval(pollTimer);
    status.textContent='Wallet verified. Loading…';
    status.className='ok';
    location.reload();
  } else if(j.status==='expired'||j.status==='failed'){
    clearInterval(pollTimer);
    status.textContent='Login '+j.status+'. Generate a new QR and try again.';
    status.className='bad';
    document.getElementById('start').disabled=false;
  } else {
    status.textContent='Waiting for wallet login…';
  }
}
</script>
</body>
</html>
