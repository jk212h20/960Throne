<!doctype html>
<html>
<head>
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Join 960 Throne</title>
<style>
body{font-family:system-ui,-apple-system,Segoe UI,sans-serif;background:radial-gradient(circle at 20% 20%,rgba(255,209,102,.18),transparent 28%),#08040f;color:white;display:grid;place-items:center;min-height:100vh;margin:0}.card{width:min(540px,92vw);padding:30px;border-radius:28px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);box-shadow:0 24px 80px rgba(0,0,0,.45)}input,button{width:100%;padding:16px;border-radius:14px;border:0;margin:8px 0;font-size:18px;box-sizing:border-box}button{background:#ffd166;color:#100511;font-weight:900;cursor:pointer}button.secondary{background:#272238;color:#fff}button:disabled{opacity:.55;cursor:not-allowed}.muted{color:#aaa}.ok{color:#86efac}.bad{color:#fca5a5}.qr{display:block;width:min(360px,100%);margin:18px auto;border-radius:18px;background:#fff}.pill{display:inline-block;padding:6px 10px;border-radius:999px;background:rgba(255,209,102,.14);border:1px solid rgba(255,209,102,.35);color:#ffd166;font-size:13px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}pre{white-space:pre-wrap;background:rgba(0,0,0,.25);padding:12px;border-radius:12px;overflow:auto}.hide{display:none}a{color:#ffd166}
</style>
</head>
<body>
<div class="card">
  <div class="pill">Lightning required</div>
  <h1>♛ Join the 960 Throne</h1>
  <p class="muted">Venue code: <b><%= state.event.venueCode || '------' %></b></p>

  <% if (player) { %>
    <% if (!player.name) { %>
      <h2>Wallet verified</h2>
      <p class="ok">Your Lightning wallet login is complete.</p>
      <p class="muted">Choose the display name that will appear in the queue and on the throne screen.</p>
      <input id="display-name" maxlength="40" placeholder="Display name" autofocus>
      <button onclick="setName()">Save Name</button>
    <% } else { %>
      <h2>Welcome, <%= player.name %></h2>
      <p class="ok">Lightning wallet verified.</p>
      <p>Claimable balance: <%= player.sat_balance %> sats</p>
      <p>This event earned: <%= (player.total_sats_earned || 0).toLocaleString() %> sats</p>
      <p><a href="/leaderboard">Event leaderboard</a></p>
      <button onclick="post('/api/queue/join')">Join Queue</button>
      <button class="secondary" onclick="post('/api/queue/leave')">Leave Queue</button>
      <% if (state.game && (state.game.king_id===player.id || state.game.challenger_id===player.id)) { %>
        <hr style="border-color:rgba(255,255,255,.12)">
        <p class="muted">Current game report</p>
        <button onclick="post('/api/game/report',{result:'king_won'})">Report King Won</button>
        <button onclick="post('/api/game/report',{result:'challenger_won'})">Report Challenger Won</button>
        <button onclick="post('/api/game/report',{result:'draw'})">Report Draw</button>
      <% } %>
    <% } %>
  <% } else { %>
    <h2>Log in with Lightning</h2>
    <p class="muted">Scan with a wallet that supports LNURL-auth. This proves you have a Lightning wallet before entering the line.</p>
    <button id="start" onclick="startLightningLogin()">Show Lightning Login QR</button>
    <div id="auth-box" class="hide">
      <img id="qr" class="qr" alt="Lightning login QR">
      <button id="open-wallet" class="secondary" onclick="openWallet()">Open Wallet</button>
      <p id="auth-status" class="muted">Waiting for wallet scan…</p>
    </div>
  <% } %>

  <pre id="out"></pre>
</div>
<script>
let currentChallenge=null,pollTimer=null;
async function post(u,b={}){const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)});const j=await r.json().catch(()=>({error:'Bad JSON'}));out.textContent=JSON.stringify(j,null,2);if(r.ok)setTimeout(()=>location.reload(),450);return j}
async function setName(){const name=document.getElementById('display-name').value;await post('/api/auth/set-name',{name})}
async function startLightningLogin(){
  const status=document.getElementById('auth-status');
  document.getElementById('start').disabled=true;
  const r=await fetch('/api/auth/lightning');
  const j=await r.json();
  if(!r.ok){out.textContent=JSON.stringify(j,null,2);document.getElementById('start').disabled=false;return}
  currentChallenge=j;
  document.getElementById('qr').src=j.qr;
  document.getElementById('auth-box').classList.remove('hide');
  status.textContent='Waiting for wallet scan…';
  if(pollTimer)clearInterval(pollTimer);
  pollTimer=setInterval(checkAuth,1200);
}
function openWallet(){if(currentChallenge&&currentChallenge.deepLink)location.href=currentChallenge.deepLink}
async function checkAuth(){
  if(!currentChallenge)return;
  const r=await fetch('/api/auth/status?k1='+encodeURIComponent(currentChallenge.k1));
  const j=await r.json();
  const status=document.getElementById('auth-status');
  if(j.status==='complete'){
    clearInterval(pollTimer);
    status.textContent='Wallet verified. Loading…';
    status.className='ok';
    location.reload();
  } else if(j.status==='expired'||j.status==='failed'){
    clearInterval(pollTimer);
    status.textContent='Login '+j.status+'. Generate a new QR and try again.';
    status.className='bad';
    document.getElementById('start').disabled=false;
  } else {
    status.textContent='Waiting for wallet scan…';
  }
}
</script>
</body>
</html>
