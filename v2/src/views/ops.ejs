<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Ops v2</title><style>body{font-family:ui-monospace,monospace;background:#050505;color:#d1fae5;padding:20px}.ok{color:#86efac}.bad{color:#fca5a5}.card{border:1px solid #164e63;border-radius:16px;padding:16px;margin:12px 0;background:#071014}pre{white-space:pre-wrap}</style></head><body><h1>960 Throne v2 Ops</h1><div class="card"><h2>Live checks</h2><p>DGT: <b class="<%= state.dgt && !state.dgt.stale ? 'ok':'bad' %>"><%= state.dgt && !state.dgt.stale ? 'LIVE':'STALE/OFFLINE' %></b> age=<%= state.dgt.ageMs %>ms</p><p>Setup: <b class="<%= state.dgt.setupOk ? 'ok':'bad' %>"><%= state.dgt.setupMessage %></b></p><p>Event locked: <%= state.event.locked %></p><p>Venue code: <%= state.event.venueCode %></p></div><div class="card"><h2>State</h2><pre><%- JSON.stringify(state,null,2) %></pre></div></body></html>