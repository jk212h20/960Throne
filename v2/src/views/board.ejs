<!DOCTYPE html><html><head><title>Board · 960 Throne</title><meta name="viewport" content="width=device-width,initial-scale=1"><script src="/socket.io/socket.io.js"></script><style>
:root{--gold:#ffd166;--cyan:#35f2ff;--ink:#05030a}*{box-sizing:border-box}body{margin:0;height:100vh;overflow:hidden;background:radial-gradient(circle at 20% 10%,rgba(255,209,102,.18),transparent 28%),radial-gradient(circle at 80% 20%,rgba(53,242,255,.12),transparent 30%),#05030a;color:#fff;font-family:Inter,ui-sans-serif,system-ui,sans-serif}.wrap{height:100vh;display:grid;grid-template-rows:auto minmax(0,1fr) auto;place-items:center;padding:18px;gap:10px}.band{width:min(96vw,74vh);display:grid;grid-template-columns:1fr auto;align-items:center;gap:14px;border:1px solid rgba(255,255,255,.12);border-radius:20px;background:rgba(0,0,0,.28);padding:10px 14px}.king{border-color:rgba(255,209,102,.28)}.name{font-size:clamp(24px,3.2vw,54px);font-weight:1000;line-height:.95;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.king .name{color:var(--gold);text-shadow:0 0 28px rgba(255,209,102,.5)}.clock{font-size:clamp(24px,3.5vw,60px);font-weight:1000;font-variant-numeric:tabular-nums;line-height:.9;color:rgba(255,255,255,.82)}.clock.active{color:var(--cyan);text-shadow:0 0 26px rgba(53,242,255,.55)}.captures{width:min(96vw,74vh);height:clamp(24px,3.2vh,42px);display:flex;align-items:center;justify-content:center;gap:3px;overflow:hidden}.cap-piece{font-size:clamp(20px,2.7vh,38px);line-height:1;width:clamp(17px,2.25vh,32px);text-align:center;font-family:Georgia,'Times New Roman',serif}.cap-piece.white{color:#fff;text-shadow:0 0 10px rgba(255,255,255,.55)}.cap-piece.black{color:transparent;-webkit-text-fill-color:transparent;-webkit-text-stroke:1.35px #fff;text-shadow:none}.board{display:grid;grid-template-columns:repeat(8,minmax(38px,8.7vh));grid-template-rows:repeat(8,minmax(35px,8.0vh));border-radius:20px;overflow:hidden;box-shadow:0 0 0 8px rgba(255,255,255,.06),0 35px 90px rgba(0,0,0,.65)}.sq{display:grid;place-items:center}.light{background:linear-gradient(145deg,#f3d89b,#d4a957)}.dark{background:linear-gradient(145deg,#6b2138,#26152d)}.piece-img{width:82%;height:82%;object-fit:contain;filter:drop-shadow(0 3px 2px rgba(0,0,0,.45))}.muted{color:rgba(255,255,255,.45)}
</style></head><body><div class="wrap"><div class="band king"><div class="name" id="king"><%= state.king ? 'King ' + state.king.name : 'No king yet' %></div><div class="clock" id="clock-black">3:00</div></div><div class="captures" id="captures-white"></div><div class="board" id="board"></div><div class="captures" id="captures-black"></div><div class="band"><div class="name" id="challenger"><%= state.game ? state.game.challenger_name : 'Awaiting challenger' %></div><div class="clock" id="clock-white">3:00</div></div></div><script>
const socket=io();let state=<%- JSON.stringify(state) %>;const fmt=s=>{s=Number(s||0);return Math.floor(s/60)+':'+String(s%60).padStart(2,'0')};
function piecesFor(pos){let p=Array(8).fill(null),n=pos|0,n2=Math.floor(n/4);p[(n%4)*2+1]='B';let n3=Math.floor(n2/4);p[(n2%4)*2]='B';let n4=Math.floor(n3/6),q=n3%6,e=0;for(let i=0;i<8;i++)if(!p[i]){if(e===q){p[i]='Q';break}e++}let kp=[[0,1],[0,2],[0,3],[0,4],[1,2],[1,3],[1,4],[2,3],[2,4],[3,4]][n4];e=0;let k=0;for(let i=0;i<8&&k<2;i++)if(!p[i]){if((k===0&&e===kp[0])||(k===1&&e===kp[1])){p[i]='N';k++}e++}let r=p.map((x,i)=>x?null:i).filter(x=>x!==null);p[r[0]]='R';p[r[1]]='K';p[r[2]]='R';return p}
function pcFromFen(ch){if(!ch)return null;return [(ch===ch.toUpperCase()?'w':'b'),ch.toUpperCase()]}
function drawRows(rows){const b=document.getElementById('board');b.innerHTML='';rows.forEach((row,r)=>row.forEach((pc,c)=>{const sq=document.createElement('div');sq.className='sq '+((r+c)%2?'dark':'light');if(pc){const img=document.createElement('img');img.className='piece-img';img.alt=pc[0]+pc[1];img.src='/public/pieces/'+pc[0]+pc[1]+'.svg';sq.appendChild(img)}b.appendChild(sq)}))}
function rowsFromFen(fen){const ranks=String(fen||'').split(' ')[0].split('/');if(ranks.length!==8)return null;const rows=[];for(const rank of ranks){const row=[];for(const ch of rank){if(/[1-8]/.test(ch)){for(let i=0;i<Number(ch);i++)row.push(null)}else row.push(pcFromFen(ch))}if(row.length!==8)return null;rows.push(row)}return rows}

function materialFromFen(fen){const counts={w:{Q:0,R:0,B:0,N:0,P:0},b:{Q:0,R:0,B:0,N:0,P:0}};const board=String(fen||'').split(' ')[0];for(const ch of board){const up=ch.toUpperCase();if(counts[ch===up?'w':'b']&&counts[ch===up?'w':'b'][up]!=null)counts[ch===up?'w':'b'][up]++}return counts}
function startMaterial(){return {w:{Q:1,R:2,B:2,N:2,P:8},b:{Q:1,R:2,B:2,N:2,P:8}}}
function capturedPieces(fen){const cur=materialFromFen(fen),start=startMaterial(),order=['Q','R','B','N','P'];return {white:order.flatMap(k=>Array(Math.max(0,start.w[k]-cur.w[k])).fill(k)),black:order.flatMap(k=>Array(Math.max(0,start.b[k]-cur.b[k])).fill(k))}}
function renderCaptured(s){const top=document.getElementById('captures-white'),bot=document.getElementById('captures-black');if(!top||!bot)return;const fen=s.dgt&&s.dgt.fen;const caps=fen?capturedPieces(fen):{white:[],black:[]};const solid={Q:'♛',R:'♜',B:'♝',N:'♞',P:'♟'},outline={Q:'♕',R:'♖',B:'♗',N:'♘',P:'♙'};top.innerHTML=caps.white.map(p=>`<span class="cap-piece white">${solid[p]}</span>`).join('');bot.innerHTML=caps.black.map(p=>`<span class="cap-piece black">${outline[p]}</span>`).join('')}
function drawBoard(pos){const back=piecesFor(pos||518);drawRows([back.map(x=>['b',x]),Array(8).fill(['b','P']),...Array(4).fill(0).map(()=>Array(8).fill(null)),Array(8).fill(['w','P']),back.map(x=>['w',x])])}
function drawFen(fen){const rows=rowsFromFen(fen);if(rows)drawRows(rows)}
let lastBoardKey=null;function render(s){state=s;document.getElementById('king').textContent=s.king?'King '+s.king.name:'No king yet';document.getElementById('challenger').textContent=s.game?s.game.challenger_name:'Awaiting challenger';const clock=s.dgt&&s.dgt.clock;const whiteSrc=s.config.dgtClockSwapSides?'white':'black';const blackSrc=s.config.dgtClockSwapSides?'black':'white';const cw=clock?clock[whiteSrc]:s.config.timeControl.base;const cb=clock?clock[blackSrc]:s.config.timeControl.base;document.getElementById('clock-white').textContent=fmt(cw);document.getElementById('clock-black').textContent=fmt(cb);document.getElementById('clock-white').classList.toggle('active',clock&&clock.activeSide===whiteSrc);document.getElementById('clock-black').classList.toggle('active',clock&&clock.activeSide===blackSrc);renderCaptured(s);const pos=s.game?s.game.chess960_position:518;const key=s.dgt&&s.dgt.fen?'fen:'+s.dgt.fen:'pos:'+pos;if(key!==lastBoardKey){if(s.dgt&&s.dgt.fen)drawFen(s.dgt.fen);else drawBoard(pos);lastBoardKey=key}}
socket.on('state',render);socket.on('dgt_state',d=>{state.dgt={...(state.dgt||{}),...d};render(state)});render(state);
</script></body></html>
