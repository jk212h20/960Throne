<!doctype html>
<html>
<head><meta name="viewport" content="width=device-width,initial-scale=1"><title>960 Throne Leaderboard</title><style>body{font-family:system-ui;background:#08040f;color:#fff;margin:0;padding:24px}.wrap{max-width:900px;margin:0 auto}.card{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);border-radius:20px;padding:18px;margin:12px 0}.row{display:grid;grid-template-columns:60px 1fr 140px 100px 100px;gap:12px;align-items:center;border-bottom:1px solid rgba(255,255,255,.1);padding:10px 0}.row:last-child{border-bottom:0}.muted{color:#aaa}.gold{color:#ffd166;font-weight:900}a{color:#ffd166}@media(max-width:650px){.row{grid-template-columns:42px 1fr 100px}.hide-sm{display:none}}</style></head>
<body><div class="wrap"><h1>♛ Event Leaderboard</h1><p class="muted">This page uses this-event counters. Claimable balances may include sats from prior events.</p><p><a href="/stage">Stage</a> · <a href="/join">Join</a></p><div class="card"><% const rows = state.players.filter(p=>p.auth_type==='lightning' && p.name).slice().sort((a,b)=>(b.total_sats_earned-a.total_sats_earned)||(b.games_won-a.games_won)||a.name.localeCompare(b.name)); %><% if (!rows.length) { %><p class="muted">No event results yet.</p><% } %><% rows.forEach((p,i)=>{ %><div class="row"><div class="gold">#<%= i+1 %></div><div><b><%= p.name %></b><div class="muted">W/L/D <%= p.games_won %>/<%= p.games_lost %>/<%= p.games_drawn %></div></div><div><span class="gold"><%= (p.total_sats_earned||0).toLocaleString() %></span> sats</div><div class="hide-sm"><%= p.times_as_king %> reigns</div><div class="hide-sm"><%= p.games_played %> games</div></div><% }) %></div></div></body></html>
