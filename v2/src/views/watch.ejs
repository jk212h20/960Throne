<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Watch 960 Throne</title><style>body{font-family:system-ui;background:#090912;color:white;margin:0;padding:20px}.card{background:#171725;border-radius:20px;padding:20px;margin:12px 0}</style></head><body><h1>960 Throne</h1><div class="card"><h2><%= state.king ? state.king.name : 'No king' %> on the throne</h2><p><%= state.liveSats %> sats this reign</p></div><div class="card"><h2>Current Game</h2><% if(state.game){ %><p>White: <%= state.game.challenger_name %> vs Black King: <%= state.game.king_name %></p><p>Position #<%= state.game.chess960_position %></p><% } else { %><p>No active game.</p><% } %></div><div class="card"><h2>Queue</h2><ol><% state.queue.forEach(q=>{ %><li><%= q.player_name %></li><% }) %></ol></div></body></html>