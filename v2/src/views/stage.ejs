<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>960 // Public Display</title>
<script src="/socket.io/socket.io.js"></script>
<style>
:root{--gold:#ffd166;--red:#ff3b6b;--cyan:#35f2ff;--ink:#05030a;--line:rgba(255,255,255,.16)}
*{box-sizing:border-box}body{margin:0;overflow:hidden;background:#05030a;color:#fff;font-family:Inter,ui-sans-serif,system-ui,sans-serif;height:100vh}body:before{content:"";position:fixed;inset:-10%;background:radial-gradient(circle at 18% 18%,rgba(255,209,102,.24),transparent 25%),radial-gradient(circle at 78% 28%,rgba(53,242,255,.15),transparent 24%),radial-gradient(circle at 50% 88%,rgba(255,59,107,.16),transparent 36%),linear-gradient(180deg,#06030c,#100511 65%,#08030a);z-index:-2}body:after{content:"";position:fixed;inset:0;background:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:52px 52px;mask-image:radial-gradient(circle,#000 25%,transparent 86%);z-index:-1}
.stage{height:100vh;padding:22px;display:grid;grid-template-columns:28vw 1fr 28vw;gap:18px}.panel{border:1px solid var(--line);border-radius:34px;background:linear-gradient(180deg,rgba(255,255,255,.09),rgba(255,255,255,.035));box-shadow:0 20px 80px rgba(0,0,0,.48),inset 0 0 60px rgba(255,255,255,.03);backdrop-filter:blur(18px);position:relative;overflow:hidden}.panel:before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent 35%,rgba(255,255,255,.05));pointer-events:none}.join-panel{padding:28px;display:flex;flex-direction:column;align-items:center;justify-content:space-between;text-align:center}.brand{font-size:clamp(24px,2.7vw,48px);font-weight:1000;line-height:.9;letter-spacing:.06em;text-transform:uppercase}.brand b{color:var(--gold);text-shadow:0 0 30px rgba(255,209,102,.65)}.join-copy{font-size:clamp(32px,2.9vw,52px);font-weight:900}.qr-shell{width:min(24vw,42vh,360px);height:min(24vw,42vh,360px);background:#fff;border-radius:26px;padding:16px;box-shadow:0 0 0 8px rgba(255,255,255,.16),0 0 55px rgba(53,242,255,.42),0 28px 90px rgba(0,0,0,.55);z-index:1}.qr-shell img{width:100%;height:100%;display:block;image-rendering:pixelated}.code{font-size:clamp(37px,4.4vw,75px);font-weight:1000;color:var(--cyan);letter-spacing:.08em;text-shadow:0 0 34px rgba(53,242,255,.68);line-height:1}.center-panel{padding:20px 24px;display:grid;grid-template-rows:auto 1fr auto;gap:14px;align-items:center}.meta{display:flex;justify-content:center;gap:22px;align-items:center;min-height:34px;color:rgba(255,255,255,.62);font-size:13px;letter-spacing:.16em;text-transform:uppercase}.pos-num{font-weight:1000;color:#fff}.dot{display:inline-block;width:12px;height:12px;border-radius:50%;background:#ef4444;box-shadow:0 0 15px #ef4444}.dot.ok{background:#22c55e;box-shadow:0 0 18px #22c55e}.player-band{display:grid;grid-template-columns:1fr auto;gap:12px;align-items:center;border:1px solid rgba(255,255,255,.1);border-radius:22px;background:rgba(0,0,0,.25);padding:10px 16px;min-width:0;margin:0 10px}.player-band.king{border-color:rgba(255,209,102,.22)}.name{font-size:clamp(20px,2.05vw,42px);font-weight:1000;line-height:.95;text-wrap:balance;min-width:0}.king .name{color:var(--gold);text-shadow:0 0 28px rgba(255,209,102,.5)}.clock{font-size:clamp(27px,3.2vw,58px);font-weight:1000;font-variant-numeric:tabular-nums;padding:6px 14px;border-radius:20px;background:rgba(0,0,0,.42);border:1px solid rgba(255,255,255,.14);white-space:nowrap}.clock.active{border-color:rgba(53,242,255,.65);box-shadow:0 0 38px rgba(53,242,255,.28)}.king-extra{display:flex;gap:12px;align-items:center;justify-content:flex-end}.name-line{display:flex;align-items:baseline;gap:14px;min-width:0}.sats{font-size:clamp(18px,1.9vw,34px);font-weight:1000;color:#facc15;text-shadow:0 0 24px rgba(250,204,21,.45);white-space:nowrap}.board-wrap{display:grid;place-items:center;min-height:0}.board{display:grid;grid-template-columns:repeat(8,minmax(36px,7.4vh));grid-template-rows:repeat(8,minmax(36px,7.4vh));border-radius:18px;overflow:hidden;box-shadow:0 0 0 8px rgba(255,255,255,.06),0 35px 90px rgba(0,0,0,.65)}.sq{display:grid;place-items:center}.light{background:linear-gradient(145deg,#f3d89b,#d4a957)}.dark{background:linear-gradient(145deg,#6b2138,#26152d)}.piece-img{width:82%;height:82%;object-fit:contain;filter:drop-shadow(0 3px 2px rgba(0,0,0,.45))}.line-panel{padding:28px 22px;display:flex;flex-direction:column;gap:12px}.queue-items{display:flex;flex-direction:column;gap:12px;overflow:hidden}.q{padding:14px 16px;border-radius:18px;background:rgba(255,255,255,.08);font-weight:900;font-size:clamp(16px,1.45vw,26px);line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.q:first-child{background:rgba(255,209,102,.16);border:1px solid rgba(255,209,102,.36);color:#ffe29a}.empty-line{color:rgba(255,255,255,.42);font-size:clamp(18px,1.7vw,30px);font-weight:900;text-align:center;margin:auto 0}
</style>
</head><body><div class="stage">
<section class="panel join-panel"><div class="brand"><b>Chess960</b></div><div class="join-copy">SCAN TO PLAY</div><div class="qr-shell"><img id="join-qr" alt="QR code to register" src="/api/join-qr-img?u=<%= encodeURIComponent(joinUrl) %>"></div><div class="code" id="venue"><%= state.event.venueCode || '------' %></div></section>
<section class="panel center-panel"><div class="meta"><span id="game-id"><%= state.game ? 'Game #' + state.game.id : '' %></span><span class="pos-num" id="position"><%= state.game ? '#' + state.game.chess960_position : '' %></span><span id="pause-status" style="color:<%= state.event.paused ? '#ffd166' : 'rgba(255,255,255,.55)' %>"><%= state.event.paused ? 'Intermission' : '' %></span><span><span class="dot <%= state.dgt && !state.dgt.stale ? 'ok' : '' %>" id="dgt-dot"></span> <span id="dgt-text"><%= state.dgt && !state.dgt.stale ? 'LIVE' : '' %></span></span></div><div class="player-band king"><div class="name-line"><div class="name" id="king"><%= state.king ? 'King ' + state.king.name : 'No king yet' %></div><div class="sats"><span id="sats"><%= (state.liveSats||0).toLocaleString() %></span> sats</div></div><div class="king-extra"><div class="clock" id="clock-black">3:00</div></div></div><div class="board-wrap"><div class="board" id="board"></div></div><div class="player-band challenger"><div class="name" id="challenger"><%= state.game ? state.game.challenger_name : 'Awaiting challenger' %></div><div class="clock" id="clock-white">3:00</div></div></section>
<aside class="panel line-panel"><div class="queue-items" id="queue"><% if (state.queue.length) { const qs = state.queue.length > 10 ? state.queue.slice(0,9).concat([state.queue[state.queue.length-1]]) : state.queue.slice(0,10); qs.forEach((q,i)=>{ const n = state.queue.length > 10 && i === 9 ? state.queue.length : i + 1; %><div class="q">#<%= n %> <%= q.player_name %></div><% }) } else { %><div class="empty-line">The line is open</div><% } %></div></aside>
</div><script>
const socket=io();let state=<%- JSON.stringify(state) %>;const fmt=s=>{s=Number(s||0);return Math.floor(s/60)+':'+String(s%60).padStart(2,'0')};
function piecesFor(pos){let p=Array(8).fill(null),n=pos|0,n2=Math.floor(n/4);p[(n%4)*2+1]='B';let n3=Math.floor(n2/4);p[(n2%4)*2]='B';let n4=Math.floor(n3/6),q=n3%6,e=0;for(let i=0;i<8;i++)if(!p[i]){if(e===q){p[i]='Q';break}e++}let kp=[[0,1],[0,2],[0,3],[0,4],[1,2],[1,3],[1,4],[2,3],[2,4],[3,4]][n4];e=0;let k=0;for(let i=0;i<8&&k<2;i++)if(!p[i]){if((k===0&&e===kp[0])||(k===1&&e===kp[1])){p[i]='N';k++}e++}let r=p.map((x,i)=>x?null:i).filter(x=>x!==null);p[r[0]]='R';p[r[1]]='K';p[r[2]]='R';return p}
function drawBoard(pos){const b=document.getElementById('board');b.innerHTML='';const back=piecesFor(pos||518);const rows=[back.map(x=>['b',x]),Array(8).fill(['b','P']),...Array(4).fill(0).map(()=>Array(8).fill(null)),Array(8).fill(['w','P']),back.map(x=>['w',x])];rows.forEach((row,r)=>row.forEach((pc,c)=>{const sq=document.createElement('div');sq.className='sq '+((r+c)%2?'dark':'light');if(pc){const img=document.createElement('img');img.className='piece-img';img.alt=pc[0]+pc[1];img.src='/public/pieces/'+pc[0]+pc[1]+'.svg';sq.appendChild(img)}b.appendChild(sq)}))}
let lastBoardPos=null;function render(s){state=s;document.getElementById('venue').textContent=s.event.venueCode||'------';const pause=document.getElementById('pause-status');if(pause){pause.textContent=s.event.paused?'Intermission':'';pause.style.color=s.event.paused?'#ffd166':'rgba(255,255,255,.55)'}document.getElementById('king').textContent=s.king?'King '+s.king.name:'No king yet';document.getElementById('challenger').textContent=s.game?s.game.challenger_name:'Awaiting challenger';document.getElementById('game-id').textContent=s.game?'Game #'+s.game.id:'';const pos=s.game?s.game.chess960_position:518;document.getElementById('position').textContent=s.game?'#'+pos:'';document.getElementById('sats').textContent=Number(s.liveSats||0).toLocaleString();const dot=document.getElementById('dgt-dot');dot.className='dot '+(!s.dgt.stale?'ok':'');document.getElementById('dgt-text').textContent=!s.dgt.stale?'LIVE':'';const cw=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.black:s.dgt.clock.white):s.config.timeControl.base;const cb=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.white:s.dgt.clock.black):s.config.timeControl.base;document.getElementById('clock-white').textContent=fmt(cw);document.getElementById('clock-black').textContent=fmt(cb);document.getElementById('clock-white').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='white');document.getElementById('clock-black').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='black');document.getElementById('queue').innerHTML=queueHtml(s.queue);if(pos!==lastBoardPos){drawBoard(pos);lastBoardPos=pos}}
function queueHtml(queue){if(!queue.length)return '<div class="empty-line">The line is open</div>';const shown=queue.length>10?queue.slice(0,9).concat([queue[queue.length-1]]):queue.slice(0,10);return shown.map((q,i)=>{const n=queue.length>10&&i===9?queue.length:i+1;return `<div class="q">#${n} ${q.player_name}</div>`}).join('')}
socket.on('state',render);socket.on('sats_tick',p=>{document.getElementById('sats').textContent=Number(p.liveSats||0).toLocaleString()});render(state);
</script></body></html>
