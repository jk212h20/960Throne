<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>960 Throne // Stage</title>
<script src="/socket.io/socket.io.js"></script>
<style>
:root{--gold:#ffd166;--red:#ff3b6b;--cyan:#35f2ff;--ink:#05030a;--panel:rgba(12,10,24,.72);--line:rgba(255,255,255,.14)}
*{box-sizing:border-box}body{margin:0;overflow:hidden;background:#05030a;color:white;font-family:Inter,ui-sans-serif,system-ui,sans-serif;height:100vh}
body:before{content:"";position:fixed;inset:-20%;background:radial-gradient(circle at 50% 20%,rgba(255,209,102,.22),transparent 28%),radial-gradient(circle at 20% 80%,rgba(53,242,255,.16),transparent 30%),radial-gradient(circle at 80% 75%,rgba(255,59,107,.14),transparent 30%),linear-gradient(180deg,#080410,#07020a 60%,#120606);z-index:-3}
body:after{content:"";position:fixed;inset:0;background:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:44px 44px;mask-image:radial-gradient(circle,#000 20%,transparent 80%);z-index:-2}.aurora{position:fixed;inset:-10%;background:conic-gradient(from 90deg,transparent,var(--cyan),transparent,var(--red),transparent,var(--gold),transparent);filter:blur(90px);opacity:.14;z-index:-1}
.stage{height:100vh;display:grid;grid-template-rows:112px 1fr 98px;gap:14px;padding:18px}.top,.ticker{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;border:1px solid var(--line);border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.09),rgba(255,255,255,.035));box-shadow:0 20px 80px rgba(0,0,0,.45),inset 0 0 60px rgba(255,255,255,.03);backdrop-filter:blur(18px)}.brand{font-weight:900;font-size:34px;letter-spacing:.08em;text-transform:uppercase;padding-left:28px}.brand b{color:var(--gold);text-shadow:0 0 24px rgba(255,209,102,.7)}.join{display:flex;align-items:center;gap:18px}.qr{width:86px;height:86px;border-radius:14px;background:white;padding:6px;box-shadow:0 0 24px rgba(53,242,255,.28)}.qr img{width:100%;height:100%;display:block}.status{text-align:left}.status .code{font-size:34px;font-weight:950;color:var(--cyan);text-shadow:0 0 26px rgba(53,242,255,.65)}.join-url{font-size:12px;color:rgba(255,255,255,.56);max-width:340px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.small{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.58)}.dgt{justify-self:end;padding-right:28px;text-align:right}.dot{display:inline-block;width:12px;height:12px;border-radius:50%;background:#ef4444;box-shadow:0 0 15px #ef4444}.dot.ok{background:#22c55e;box-shadow:0 0 18px #22c55e}.main{display:grid;grid-template-columns:minmax(260px,1fr) minmax(560px,1.35fr) minmax(260px,1fr);gap:16px;min-height:0}.player,.arena{border:1px solid var(--line);border-radius:34px;background:var(--panel);backdrop-filter:blur(22px);box-shadow:0 20px 80px rgba(0,0,0,.4);position:relative;overflow:hidden}.player:before,.arena:before{content:"";position:absolute;inset:0;background:linear-gradient(120deg,rgba(255,255,255,.12),transparent 30%,rgba(255,255,255,.06));pointer-events:none}.player{display:flex;flex-direction:column;align-items:center;justify-content:space-between;padding:28px}.role{font-size:16px;color:rgba(255,255,255,.6);letter-spacing:.2em;text-transform:uppercase}.name{font-size:clamp(34px,4.5vw,78px);font-weight:950;text-align:center;line-height:.95;text-wrap:balance;text-shadow:0 4px 0 rgba(0,0,0,.35)}.challenger .name{color:#f8fafc}.king .name{color:var(--gold);text-shadow:0 0 32px rgba(255,209,102,.45),0 4px 0 #000}.crown{font-size:96px;filter:drop-shadow(0 0 30px rgba(255,209,102,.7))}.clock{font-size:clamp(44px,6vw,110px);font-weight:950;font-variant-numeric:tabular-nums;padding:10px 24px;border-radius:24px;background:rgba(0,0,0,.38);border:1px solid rgba(255,255,255,.12)}.clock.active{box-shadow:0 0 45px rgba(53,242,255,.28);border-color:rgba(53,242,255,.55)}.sats{font-size:44px;color:#facc15;font-weight:950;text-shadow:0 0 25px rgba(250,204,21,.45)}
.arena{padding:20px;display:grid;grid-template-rows:auto 1fr auto;gap:14px}.game-meta{text-align:center}.pos{font-size:48px;font-weight:950}.setup{display:inline-flex;gap:10px;align-items:center;margin-top:6px;padding:8px 16px;border-radius:999px;background:rgba(0,0,0,.3);border:1px solid var(--line)}.setup.ok{color:#86efac;border-color:rgba(34,197,94,.5)}.setup.warn{color:#fde68a;border-color:rgba(250,204,21,.5)}.board-wrap{display:grid;place-items:center;min-height:0}.board{display:grid;grid-template-columns:repeat(8,minmax(42px,8vh));grid-template-rows:repeat(8,minmax(42px,8vh));border-radius:18px;overflow:hidden;box-shadow:0 0 0 8px rgba(255,255,255,.06),0 35px 90px rgba(0,0,0,.65)}.sq{display:grid;place-items:center}.light{background:linear-gradient(145deg,#f3d89b,#d4a957)}.dark{background:linear-gradient(145deg,#6b2138,#26152d)}.piece-img{width:82%;height:82%;object-fit:contain;filter:drop-shadow(0 3px 2px rgba(0,0,0,.45))}.versus{text-align:center;font-size:24px;letter-spacing:.28em;color:rgba(255,255,255,.55)}.ticker{padding:0 24px;overflow:hidden}.recent{white-space:nowrap;color:rgba(255,255,255,.78)}.empty{color:rgba(255,255,255,.42);font-size:24px;text-align:center;margin-top:30px}
@media (prefers-reduced-motion:no-preference){.crown{animation:float 3s ease-in-out infinite}@keyframes float{50%{transform:translateY(-10px) rotate(2deg)}}.recent{animation:scroll 35s linear infinite}@keyframes scroll{from{transform:translateX(70%)}to{transform:translateX(-100%)}}}
</style>
</head><body><div class="aurora"></div><div class="stage">
<header class="top"><div class="brand"><b>960</b> THRONE</div><div class="join"><div class="qr"><img id="join-qr" alt="Join QR"></div><div class="status"><div class="small">Scan to register · venue code</div><div class="code" id="venue"><%= state.event.venueCode || '------' %></div><div class="join-url" id="join-url"></div></div></div><div class="dgt"><div class="small">DGT Link</div><div><span class="dot <%= state.dgt && !state.dgt.stale ? 'ok' : '' %>" id="dgt-dot"></span> <span id="dgt-text"><%= state.dgt && !state.dgt.stale ? 'LIVE' : 'WAITING' %></span></div></div></header>
<main class="main"><section class="player challenger"><div class="role">White Challenger</div><div class="name" id="challenger"><%= state.game ? state.game.challenger_name : 'Awaiting challenger' %></div><div class="clock" id="clock-white">3:00</div><div class="small">blade raised</div></section>
<section class="arena"><div class="game-meta"><div class="small" id="game-id"><%= state.game ? 'Game #' + state.game.id : 'No active game' %></div><div class="pos" id="position"><%= state.game ? '#' + state.game.chess960_position : 'THE COURT IS EMPTY' %></div><div class="setup <%= state.dgt && state.dgt.setupOk ? 'ok' : 'warn' %>" id="setup"><%= state.dgt && state.dgt.setupMessage ? state.dgt.setupMessage : 'Awaiting board' %></div></div><div class="board-wrap"><div class="board" id="board"></div></div><div class="versus">CHALLENGE THE CROWN</div></section>
<section class="player king"><div class="role">Black King</div><div class="crown">♛</div><div class="name" id="king"><%= state.king ? state.king.name : 'No king yet' %></div><div class="clock" id="clock-black">3:00</div><div class="sats"><span id="sats"><%= (state.liveSats||0).toLocaleString() %></span> sats</div></section></main>
<footer class="ticker"><div class="small">Court</div><div class="recent" id="recent"><% if (state.recentGames.length) { %><%= state.recentGames.map(g => `${g.king_name} vs ${g.challenger_name}: ${g.result}`).join('   ✦   ') %><% } else { %>The throne awaits its first battle...<% } %></div><div class="small" style="text-align:right">Day <%= state.event.day %></div></footer>
</div><script>
const socket=io();let state=<%- JSON.stringify(state) %>;const fmt=s=>{s=Number(s||0);return Math.floor(s/60)+':'+String(s%60).padStart(2,'0')};
const joinUrl=location.origin+'/join';document.getElementById('join-url').textContent=joinUrl;document.getElementById('join-qr').src='/api/join-qr-img?u='+encodeURIComponent(joinUrl);
function piecesFor(pos){let p=Array(8).fill(null),n=pos|0,n2=Math.floor(n/4);p[(n%4)*2+1]='B';let n3=Math.floor(n2/4);p[(n2%4)*2]='B';let n4=Math.floor(n3/6),q=n3%6,e=0;for(let i=0;i<8;i++)if(!p[i]){if(e===q){p[i]='Q';break}e++}let kp=[[0,1],[0,2],[0,3],[0,4],[1,2],[1,3],[1,4],[2,3],[2,4],[3,4]][n4];e=0;let k=0;for(let i=0;i<8&&k<2;i++)if(!p[i]){if((k===0&&e===kp[0])||(k===1&&e===kp[1])){p[i]='N';k++}e++}let r=p.map((x,i)=>x?null:i).filter(x=>x!==null);p[r[0]]='R';p[r[1]]='K';p[r[2]]='R';return p}
function drawBoard(pos){const b=document.getElementById('board');b.innerHTML='';const back=piecesFor(pos||518);const rows=[back.map(x=>['b',x]),Array(8).fill(['b','P']),...Array(4).fill(0).map(()=>Array(8).fill(null)),Array(8).fill(['w','P']),back.map(x=>['w',x])];rows.forEach((row,r)=>row.forEach((pc,c)=>{const sq=document.createElement('div');sq.className='sq '+((r+c)%2?'dark':'light');if(pc){const img=document.createElement('img');img.className='piece-img';img.alt=pc[0]+pc[1];img.src='/public/pieces/'+pc[0]+pc[1]+'.svg';sq.appendChild(img)}b.appendChild(sq)}))}
let lastBoardPos=null;function render(s){state=s;document.getElementById('venue').textContent=s.event.venueCode||'------';document.getElementById('king').textContent=s.king?s.king.name:'No king yet';document.getElementById('challenger').textContent=s.game?s.game.challenger_name:'Awaiting challenger';document.getElementById('game-id').textContent=s.game?'Game #'+s.game.id:'No active game';const pos=s.game?s.game.chess960_position:518;document.getElementById('position').textContent=s.game?'#'+pos:'THE COURT IS EMPTY';document.getElementById('sats').textContent=Number(s.liveSats||0).toLocaleString();document.getElementById('setup').textContent=s.dgt.setupMessage||'Awaiting board';document.getElementById('setup').className='setup '+(s.dgt.setupOk?'ok':'warn');const dot=document.getElementById('dgt-dot');dot.className='dot '+(!s.dgt.stale?'ok':'');document.getElementById('dgt-text').textContent=!s.dgt.stale?'LIVE':'WAITING';const cw=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.black:s.dgt.clock.white):s.config.timeControl.base;const cb=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.white:s.dgt.clock.black):s.config.timeControl.base;document.getElementById('clock-white').textContent=fmt(cw);document.getElementById('clock-black').textContent=fmt(cb);document.getElementById('clock-white').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='white');document.getElementById('clock-black').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='black');if(pos!==lastBoardPos){drawBoard(pos);lastBoardPos=pos}}
socket.on('state',render);socket.on('sats_tick',p=>{document.getElementById('sats').textContent=Number(p.liveSats||0).toLocaleString()});render(state);
</script></body></html>
