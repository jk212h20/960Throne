<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>960 Throne // Public Display</title>
<script src="/socket.io/socket.io.js"></script>
<style>
:root{--gold:#ffd166;--red:#ff3b6b;--cyan:#35f2ff;--ink:#05030a;--panel:rgba(12,10,24,.76);--line:rgba(255,255,255,.16)}
*{box-sizing:border-box}body{margin:0;overflow:hidden;background:#05030a;color:#fff;font-family:Inter,ui-sans-serif,system-ui,sans-serif;height:100vh}body:before{content:"";position:fixed;inset:-10%;background:radial-gradient(circle at 18% 18%,rgba(255,209,102,.24),transparent 25%),radial-gradient(circle at 78% 28%,rgba(53,242,255,.15),transparent 24%),radial-gradient(circle at 50% 88%,rgba(255,59,107,.16),transparent 36%),linear-gradient(180deg,#06030c,#100511 65%,#08030a);z-index:-2}body:after{content:"";position:fixed;inset:0;background:linear-gradient(rgba(255,255,255,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px);background-size:52px 52px;mask-image:radial-gradient(circle,#000 25%,transparent 86%);z-index:-1}.stage{height:100vh;padding:22px;display:grid;grid-template-columns:34vw 1fr;grid-template-rows:1fr 104px;gap:18px}.join-panel,.show-panel,.ticker{border:1px solid var(--line);border-radius:34px;background:linear-gradient(180deg,rgba(255,255,255,.09),rgba(255,255,255,.035));box-shadow:0 20px 80px rgba(0,0,0,.48),inset 0 0 60px rgba(255,255,255,.03);backdrop-filter:blur(18px);position:relative;overflow:hidden}.join-panel{padding:30px;display:flex;flex-direction:column;align-items:center;justify-content:space-between;text-align:center}.join-panel:before,.show-panel:before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent 35%,rgba(255,255,255,.05));pointer-events:none}.brand{font-size:clamp(34px,4vw,70px);font-weight:1000;line-height:.9;letter-spacing:.06em;text-transform:uppercase}.brand b{color:var(--gold);text-shadow:0 0 30px rgba(255,209,102,.65)}.join-copy{font-size:clamp(22px,2vw,36px);font-weight:900}.qr-shell{width:min(29vw,48vh,430px);height:min(29vw,48vh,430px);background:#fff;border-radius:28px;padding:18px;box-shadow:0 0 0 8px rgba(255,255,255,.16),0 0 55px rgba(53,242,255,.42),0 28px 90px rgba(0,0,0,.55);z-index:1}.qr-shell img{width:100%;height:100%;display:block;image-rendering:pixelated}.code-label{font-size:13px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.58)}.code{font-size:clamp(48px,5.8vw,98px);font-weight:1000;color:var(--cyan);letter-spacing:.08em;text-shadow:0 0 34px rgba(53,242,255,.68);line-height:1}.url{font-size:clamp(15px,1.3vw,24px);color:rgba(255,255,255,.74);max-width:100%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.show-panel{padding:22px;display:grid;grid-template-rows:92px 1fr 96px;gap:14px}.topline{display:grid;grid-template-columns:1fr auto 1fr;align-items:center}.small{font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.58)}.dgt{text-align:right}.dot{display:inline-block;width:13px;height:13px;border-radius:50%;background:#ef4444;box-shadow:0 0 15px #ef4444}.dot.ok{background:#22c55e;box-shadow:0 0 18px #22c55e}.pos{text-align:center}.pos-num{font-size:56px;font-weight:1000;line-height:.95}.setup{display:inline-flex;margin-top:8px;padding:7px 14px;border-radius:999px;background:rgba(0,0,0,.3);border:1px solid var(--line);font-size:14px}.setup.ok{color:#86efac;border-color:rgba(34,197,94,.5)}.setup.warn{color:#fde68a;border-color:rgba(250,204,21,.5)}.battle{display:grid;grid-template-columns:minmax(190px,.75fr) minmax(480px,1.2fr) minmax(190px,.75fr);gap:14px;min-height:0}.side{border:1px solid rgba(255,255,255,.1);border-radius:28px;background:rgba(0,0,0,.25);padding:22px;display:flex;flex-direction:column;justify-content:space-between;align-items:center;min-width:0}.role{font-size:14px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.58)}.name{font-size:clamp(30px,3.2vw,64px);font-weight:1000;line-height:.95;text-align:center;text-wrap:balance}.king .name{color:var(--gold);text-shadow:0 0 28px rgba(255,209,102,.5)}.crown{font-size:86px;filter:drop-shadow(0 0 28px rgba(255,209,102,.7))}.clock{font-size:clamp(42px,5vw,92px);font-weight:1000;font-variant-numeric:tabular-nums;padding:8px 18px;border-radius:20px;background:rgba(0,0,0,.42);border:1px solid rgba(255,255,255,.14)}.clock.active{border-color:rgba(53,242,255,.65);box-shadow:0 0 38px rgba(53,242,255,.28)}.sats{font-size:clamp(28px,3vw,52px);font-weight:1000;color:#facc15;text-shadow:0 0 24px rgba(250,204,21,.45)}.board-wrap{display:grid;place-items:center;min-height:0}.board{display:grid;grid-template-columns:repeat(8,minmax(38px,7.3vh));grid-template-rows:repeat(8,minmax(38px,7.3vh));border-radius:18px;overflow:hidden;box-shadow:0 0 0 8px rgba(255,255,255,.06),0 35px 90px rgba(0,0,0,.65)}.sq{display:grid;place-items:center}.light{background:linear-gradient(145deg,#f3d89b,#d4a957)}.dark{background:linear-gradient(145deg,#6b2138,#26152d)}.piece-img{width:82%;height:82%;object-fit:contain;filter:drop-shadow(0 3px 2px rgba(0,0,0,.45))}.queue-row{display:grid;grid-template-columns:auto 1fr;gap:16px;align-items:center;border:1px solid rgba(255,255,255,.1);border-radius:24px;background:rgba(0,0,0,.22);padding:14px 18px;overflow:hidden}.queue-items{display:flex;gap:12px;overflow:hidden}.q{padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.08);white-space:nowrap;font-weight:800}.ticker{grid-column:1/3;padding:0 26px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;overflow:hidden}.recent{white-space:nowrap;color:rgba(255,255,255,.78)}
@media (prefers-reduced-motion:no-preference){.crown{animation:float 3s ease-in-out infinite}@keyframes float{50%{transform:translateY(-8px) rotate(2deg)}}.recent{animation:scroll 38s linear infinite}@keyframes scroll{from{transform:translateX(75%)}to{transform:translateX(-100%)}}}
</style>
</head><body><div class="stage">
<section class="join-panel"><div class="brand"><b>960</b><br>THRONE</div><div class="join-copy">SCAN TO PLAY</div><div class="qr-shell"><img id="join-qr" alt="QR code to register" src="/api/join-qr-img?u=<%= encodeURIComponent(joinUrl) %>"></div><div><div class="code-label">Venue Code</div><div class="code" id="venue"><%= state.event.venueCode || '------' %></div><div class="url" id="join-url"><%= joinUrl %></div></div></section>
<section class="show-panel"><div class="topline"><div><div class="small">Current Battle</div><div id="game-id"><%= state.game ? 'Game #' + state.game.id : 'No active game' %></div><div id="pause-status" style="margin-top:8px;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:<%= state.event.paused ? '#ffd166' : 'rgba(255,255,255,.55)' %>"><%= state.event.paused ? 'Intermission: next game paused' : 'Throne active' %></div></div><div class="pos"><div class="small">Chess960 Position</div><div class="pos-num" id="position"><%= state.game ? '#' + state.game.chess960_position : '—' %></div><div class="setup <%= state.dgt && state.dgt.setupOk ? 'ok' : 'warn' %>" id="setup"><%= state.dgt && state.dgt.setupMessage ? state.dgt.setupMessage : 'Awaiting board' %></div></div><div class="dgt"><div class="small">DGT Link</div><div><span class="dot <%= state.dgt && !state.dgt.stale ? 'ok' : '' %>" id="dgt-dot"></span> <span id="dgt-text"><%= state.dgt && !state.dgt.stale ? 'LIVE' : 'WAITING' %></span></div></div></div>
<div class="battle"><section class="side challenger"><div class="role">White Challenger</div><div class="name" id="challenger"><%= state.game ? state.game.challenger_name : 'Awaiting challenger' %></div><div class="clock" id="clock-white">3:00</div></section><div class="board-wrap"><div class="board" id="board"></div></div><section class="side king"><div class="role">Black King</div><div class="crown">♛</div><div class="name" id="king"><%= state.king ? state.king.name : 'No king yet' %></div><div class="clock" id="clock-black">3:00</div><div class="sats"><span id="sats"><%= (state.liveSats||0).toLocaleString() %></span> sats</div></section></div>
<div class="queue-row"><div class="small">Line</div><div class="queue-items" id="queue"><% state.queue.slice(0,8).forEach((q,i)=>{ %><div class="q">#<%= i+1 %> <%= q.player_name %></div><% }) %></div></div></section>
<footer class="ticker"><div class="small">Court</div><div class="recent" id="recent"><% if (state.recentGames.length) { %><%= state.recentGames.map(g => `${g.king_name} vs ${g.challenger_name}: ${g.result}`).join('   ✦   ') %><% } else { %>The throne awaits its first battle...<% } %></div><div class="small">Day <%= state.event.day %></div></footer>
</div><script>
const socket=io();let state=<%- JSON.stringify(state) %>;const fmt=s=>{s=Number(s||0);return Math.floor(s/60)+':'+String(s%60).padStart(2,'0')};
function piecesFor(pos){let p=Array(8).fill(null),n=pos|0,n2=Math.floor(n/4);p[(n%4)*2+1]='B';let n3=Math.floor(n2/4);p[(n2%4)*2]='B';let n4=Math.floor(n3/6),q=n3%6,e=0;for(let i=0;i<8;i++)if(!p[i]){if(e===q){p[i]='Q';break}e++}let kp=[[0,1],[0,2],[0,3],[0,4],[1,2],[1,3],[1,4],[2,3],[2,4],[3,4]][n4];e=0;let k=0;for(let i=0;i<8&&k<2;i++)if(!p[i]){if((k===0&&e===kp[0])||(k===1&&e===kp[1])){p[i]='N';k++}e++}let r=p.map((x,i)=>x?null:i).filter(x=>x!==null);p[r[0]]='R';p[r[1]]='K';p[r[2]]='R';return p}
function drawBoard(pos){const b=document.getElementById('board');b.innerHTML='';const back=piecesFor(pos||518);const rows=[back.map(x=>['b',x]),Array(8).fill(['b','P']),...Array(4).fill(0).map(()=>Array(8).fill(null)),Array(8).fill(['w','P']),back.map(x=>['w',x])];rows.forEach((row,r)=>row.forEach((pc,c)=>{const sq=document.createElement('div');sq.className='sq '+((r+c)%2?'dark':'light');if(pc){const img=document.createElement('img');img.className='piece-img';img.alt=pc[0]+pc[1];img.src='/public/pieces/'+pc[0]+pc[1]+'.svg';sq.appendChild(img)}b.appendChild(sq)}))}
let lastBoardPos=null;function render(s){state=s;document.getElementById('venue').textContent=s.event.venueCode||'------';const pause=document.getElementById('pause-status');if(pause){pause.textContent=s.event.paused?'Intermission: next game paused':'Throne active';pause.style.color=s.event.paused?'#ffd166':'rgba(255,255,255,.55)'}document.getElementById('king').textContent=s.king?s.king.name:'No king yet';document.getElementById('challenger').textContent=s.game?s.game.challenger_name:'Awaiting challenger';document.getElementById('game-id').textContent=s.game?'Game #'+s.game.id:'No active game';const pos=s.game?s.game.chess960_position:518;document.getElementById('position').textContent=s.game?'#'+pos:'—';document.getElementById('sats').textContent=Number(s.liveSats||0).toLocaleString();document.getElementById('setup').textContent=s.dgt.setupMessage||'Awaiting board';document.getElementById('setup').className='setup '+(s.dgt.setupOk?'ok':'warn');const dot=document.getElementById('dgt-dot');dot.className='dot '+(!s.dgt.stale?'ok':'');document.getElementById('dgt-text').textContent=!s.dgt.stale?'LIVE':'WAITING';const cw=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.black:s.dgt.clock.white):s.config.timeControl.base;const cb=s.dgt.clock?(s.config.dgtClockSwapSides?s.dgt.clock.white:s.dgt.clock.black):s.config.timeControl.base;document.getElementById('clock-white').textContent=fmt(cw);document.getElementById('clock-black').textContent=fmt(cb);document.getElementById('clock-white').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='white');document.getElementById('clock-black').classList.toggle('active',s.dgt.clock&&s.dgt.clock.activeSide==='black');document.getElementById('queue').innerHTML=s.queue.slice(0,8).map((q,i)=>`<div class="q">#${i+1} ${q.player_name}</div>`).join('');if(pos!==lastBoardPos){drawBoard(pos);lastBoardPos=pos}}
socket.on('state',render);socket.on('sats_tick',p=>{document.getElementById('sats').textContent=Number(p.liveSats||0).toLocaleString()});render(state);
</script></body></html>
