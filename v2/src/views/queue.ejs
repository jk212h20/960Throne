<!DOCTYPE html><html><head><title>Queue · 960 Throne</title><meta name="viewport" content="width=device-width,initial-scale=1"><script src="/socket.io/socket.io.js"></script><style>
*{box-sizing:border-box}body{margin:0;min-height:100vh;overflow:hidden;background:linear-gradient(90deg,#05030a,#100817 48%,#05030a);color:#fff;font-family:Inter,ui-sans-serif,system-ui,sans-serif}.wrap{height:100vh;display:flex;align-items:center;gap:22px;padding:18px 28px}.label{flex:0 0 auto;color:#ffd166;font-size:clamp(22px,3.2vw,54px);font-weight:1000;letter-spacing:.06em;text-transform:uppercase;text-shadow:0 0 28px rgba(255,209,102,.5);white-space:nowrap}.line{min-width:0;flex:1;display:flex;align-items:center;gap:14px;overflow:hidden}.q{flex:0 0 auto;min-width:clamp(155px,15vw,260px);max-width:clamp(155px,15vw,260px);height:clamp(72px,10vh,124px);border-radius:20px;border:1px solid rgba(255,255,255,.16);background:linear-gradient(180deg,rgba(255,255,255,.13),rgba(255,255,255,.05));box-shadow:0 18px 52px rgba(0,0,0,.38),inset 0 0 40px rgba(255,255,255,.03);display:grid;grid-template-rows:auto 1fr;align-items:center;padding:10px 14px}.num{color:#35f2ff;font-size:clamp(13px,1.2vw,22px);font-weight:1000;line-height:1;text-shadow:0 0 18px rgba(53,242,255,.48)}.name{font-size:clamp(18px,2vw,34px);font-weight:1000;line-height:1.02;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.empty{font-size:clamp(26px,4vw,72px);font-weight:1000;color:rgba(255,255,255,.56)}.more{flex:0 0 auto;color:rgba(255,255,255,.6);font-size:clamp(18px,2.2vw,38px);font-weight:1000}.king{flex:0 0 auto;text-align:right;min-width:clamp(180px,18vw,330px);border-left:2px solid rgba(255,209,102,.35);padding-left:22px}.king small{display:block;color:rgba(255,255,255,.55);font-size:clamp(12px,1vw,18px);font-weight:800;text-transform:uppercase;letter-spacing:.08em}.king b{display:block;color:#ffd166;font-size:clamp(22px,3vw,52px);line-height:1;text-shadow:0 0 28px rgba(255,209,102,.5);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
</style></head><body><div class="wrap"><div class="label">Line</div><div class="line" id="line"></div><div class="king"><small>Throne</small><b id="king"><%= state.king ? state.king.name : 'Open' %></b></div></div><script>
const socket=io();let state=<%- JSON.stringify(state) %>;
function esc(s){return String(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]))}
function render(s){state=s;document.getElementById('king').textContent=s.king?s.king.name:'Open';const q=s.queue||[];const line=document.getElementById('line');if(!q.length){line.innerHTML='<div class="empty">The line is open</div>';return}const max=8;const shown=q.slice(0,max);line.innerHTML=shown.map((p,i)=>`<div class="q"><div class="num">#${i+1}</div><div class="name">${esc(p.player_name)}</div></div>`).join('')+(q.length>max?`<div class="more">+${q.length-max}</div>`:'')}
socket.on('state',render);render(state);
</script></body></html>
