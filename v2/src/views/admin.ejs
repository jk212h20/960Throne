<!doctype html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>960 Admin v2</title><style>body{font-family:system-ui;background:#0b0b12;color:#eee;margin:0;padding:24px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px}.card{background:#171725;border:1px solid #333;border-radius:18px;padding:18px}button,input,select{padding:10px;border-radius:10px;margin:4px}button{background:#ffd166;border:0;font-weight:800}pre{white-space:pre-wrap;background:#06060a;padding:12px;border-radius:12px;max-height:360px;overflow:auto}</style></head><body><h1>♛ 960 Throne v2 Admin</h1><div class="card"><input id="pw" type="password" placeholder="admin password"><button onclick="post('/api/admin/login',{password:pw.value})">Login</button><a href="/ops">Ops</a> · <a href="/stage">Stage</a></div><div class="grid"><div class="card"><h2>Game</h2><p>King: <b><%= state.king ? state.king.name : 'none' %></b></p><p>Game: <%= state.game ? '#'+state.game.id+' '+state.game.king_name+' vs '+state.game.challenger_name : 'none' %></p><button onclick="result('king_won')">King won</button><button onclick="result('challenger_won')">Challenger won</button><button onclick="result('draw')">Draw</button><button onclick="result('no_show')">No show</button></div><div class="card"><h2>Event</h2><button onclick="post('/api/admin/rotate-code')">Rotate Code</button><button onclick="post('/api/admin/lock',{locked:true})">Lock</button><button onclick="post('/api/admin/lock',{locked:false})">Unlock</button><button onclick="post('/api/admin/backup')">Backup</button><button onclick="confirm('Reset event?')&&post('/api/admin/reset')">Reset</button></div><div class="card"><h2>Queue</h2><ol><% state.queue.forEach(q=>{ %><li><%= q.player_name %> (#<%= q.player_id %>)</li><% }) %></ol></div><div class="card"><h2>Players</h2><% state.players.forEach(p=>{ %><div><button onclick="post('/api/admin/crown',{playerId:<%= p.id %>})">Crown</button> <%= p.name %> — <%= p.sat_balance %> sats</div><% }) %></div></div><pre id="out"></pre><script>async function post(u,b={}){const r=await fetch(u,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(b)});out.textContent=JSON.stringify(await r.json(),null,2);if(r.ok)setTimeout(()=>location.reload(),600)}function result(x){post('/api/admin/result',{gameId:<%= state.game ? state.game.id : 0 %>,result:x})}</script></body></html>